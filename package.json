{
  "name": "english-library-site",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "audit:content": "node --experimental-strip-types scripts/audit-content.mjs",
    "practice:generate": "node --experimental-strip-types scripts/build-practice.mjs",
    "practice:check": "node --experimental-strip-types scripts/check-practice.mjs",
    "practice:stats": "node --experimental-strip-types scripts/practice-stats.mjs",
    "links:check": "node scripts/check-site-links.mjs",
    "qa": "pnpm check && pnpm test && pnpm audit:content && pnpm practice:check && pnpm build && pnpm links:check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "astro": "^6.1.3",
    "marked": "^17.0.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.9.3"
  }
}
