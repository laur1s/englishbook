---
import type { LibraryEntry } from "../lib/content";
import type { ParsedSection } from "../lib/markdown";

import BaseLayout from "./BaseLayout.astro";
import { getCollectionHref, getEntryHref } from "../lib/content";
import { getContentSessionByHref } from "../lib/course-path";

type Props = {
  entry: LibraryEntry;
  description?: string;
  introHtml: string;
  sections: ParsedSection[];
  previous?: LibraryEntry;
  next?: LibraryEntry;
  totalEntries?: number;
  answerHref?: string;
  answerSnippetHtml?: string;
  practiceCallout?: {
    href: string;
    title: string;
    ltTitle: string;
    description: string;
    buttonLabel: string;
  };
};

const {
  entry,
  description,
  introHtml,
  sections,
  previous,
  next,
  totalEntries,
  answerHref,
  answerSnippetHtml,
  practiceCallout,
} = Astro.props;

const collectionTitle =
  entry.data.collection === "grey-book"
    ? "Grey's Book"
    : entry.data.collection === "a2-units"
      ? "A2 Course"
      : entry.data.collection === "resources"
        ? "Resources"
        : "Library";
const isTrackLesson = entry.data.collection === "grey-book" || entry.data.collection === "a2-units";
const lessonCourseHref = entry.data.collection === "grey-book"
  ? `/grey-book/${entry.data.slug}`
  : entry.data.collection === "a2-units"
    ? `/a2/${entry.data.slug}`
    : undefined;
const lessonSession = lessonCourseHref ? getContentSessionByHref(lessonCourseHref) : undefined;
const lessonRevision = lessonSession?.revision ?? 1;
const studySteps = entry.data.collection === "grey-book"
  ? [
      { id: "notice", label: "Notice", copy: "I read the story and said two useful lines aloud.", ltCopy: "Perskaičiau istoriją ir garsiai pasakiau dvi naudingas eilutes." },
      { id: "retrieve", label: "Retrieve", copy: "I closed the story and answered one question from memory.", ltCopy: "Užverčiau istoriją ir į vieną klausimą atsakiau iš atminties." },
      { id: "produce", label: "Produce", copy: "I retold three events in my own words.", ltCopy: "Savais žodžiais papasakojau tris įvykius." },
      { id: "correct", label: "Check", copy: "I checked one detail, corrected it if needed, and tried again without looking.", ltCopy: "Patikrinau vieną detalę ir prireikus ją pataisiau. Tada užverčiau tekstą ir pabandžiau dar kartą." },
    ]
  : [
      { id: "notice", label: "Notice", copy: "I read the examples and said two aloud.", ltCopy: "Perskaičiau pavyzdžius ir du iš jų pasakiau garsiai." },
      { id: "retrieve", label: "Retrieve", copy: "I closed the notes and did one exercise without help.", ltCopy: "Užverčiau užrašus ir vieną pratimą atlikau be pagalbos." },
      { id: "produce", label: "Produce", copy: "I made three sentences of my own using the lesson language.", ltCopy: "Sukūriau tris savo sakinius su pamokos žodžiais ar gramatika." },
      { id: "correct", label: "Check", copy: "I checked one answer, corrected it if needed, and tried again without looking.", ltCopy: "Patikrinau vieną atsakymą ir prireikus jį pataisiau. Tada užverčiau užrašus ir pabandžiau dar kartą." },
    ];
const sequenceLabel =
  entry.data.collection === "grey-book"
    ? `Chapter ${entry.data.order}${totalEntries ? ` of ${totalEntries}` : ""}`
    : entry.data.collection === "a2-units"
      ? `Unit ${entry.data.order}${totalEntries ? ` of ${totalEntries}` : ""}`
      : entry.data.collection.replace("-", " ");
const readerNavigationLabel = entry.data.collection === "grey-book"
  ? "Chapter navigation"
  : entry.data.collection === "a2-units"
    ? "Unit navigation"
    : entry.data.collection === "resources"
      ? "Resource navigation"
      : "Reader navigation";
const outlineStartsCollapsed = sections.length > 24;
---

<BaseLayout title={`${entry.data.title} | English Library`} description={description} enableTranslation>
  <section class="reader-hero">
    <p class="eyebrow">{sequenceLabel}</p>
    <h1>{entry.data.title}</h1>
    <p class="hero-subtitle lt-text" lang="lt">{entry.data.ltTitle}</p>

    <div class="badge-row">
      <span class="badge">{entry.data.level}</span>
      <span class="badge">{entry.data.contentType}</span>
      {entry.data.grammarFocus.map((focus) => <span class="badge soft">{focus}</span>)}
    </div>

    <p class="topic-row">
      {entry.data.topics.map((topic) => <span>{topic}</span>)}
    </p>
  </section>

  <nav class="reader-nav-bar" aria-label={readerNavigationLabel}>
    <a class="reader-nav-link reader-nav-back" href={getCollectionHref(entry.data.collection)}>
      <span class="pager-label">Back to collection</span>
      <strong>{collectionTitle}</strong>
    </a>

    {previous ? (
      <a class="reader-nav-link" href={getEntryHref(previous)}>
        <span class="pager-label">Previous</span>
        <strong>{previous.data.title}</strong>
      </a>
    ) : (
      <span class="reader-nav-link reader-nav-empty" />
    )}

    {next ? (
      <a class="reader-nav-link align-right" href={getEntryHref(next)}>
        <span class="pager-label">Next</span>
        <strong>{next.data.title}</strong>
      </a>
    ) : (
      <span class="reader-nav-link reader-nav-empty" />
    )}

    {answerSnippetHtml ? (
      <a class="reader-nav-link reader-nav-answer" href="#answer-preview">
        <span class="pager-label">Jump to answer preview</span>
        <strong>Review only when ready</strong>
      </a>
    ) : null}
  </nav>

  <div class="reader-shell">
    <aside class="reader-sidebar" aria-label="Page outline">
      <a class="reader-skip-outline" href="#reader-lesson-content">Skip outline and start reading</a>
      <details class="toc-card reader-toc" open={!outlineStartsCollapsed}>
        <summary>
          <span>
            <strong>On this page</strong>
            <small class="lt-text sidebar-subtitle" lang="lt">Šio puslapio turinys</small>
          </span>
          <span class="toc-summary-count">{sections.length + (answerSnippetHtml ? 1 : 0)} sections</span>
        </summary>
        <ul>
          {sections.map((section) => (
            <li>
              <a href={`#${section.id}`} set:html={section.titleHtml} />
            </li>
          ))}
          {answerSnippetHtml && <li><a href="#answer-preview">Answer preview</a></li>}
        </ul>
      </details>
    </aside>

    <article class="reader-content" id="reader-lesson-content" tabindex="-1">
      <aside class="translation-guide" aria-label="Dictionary help">
        <p><span class="translation-guide-sample">Dotted underline</span> = Lithuanian translation. Click or tap a word, or select up to four words.</p>
        <p class="lt-text" lang="lt"><span class="translation-guide-sample">Punktyrinis pabraukimas</span> = vertimas į lietuvių kalbą. Spustelėkite arba bakstelėkite žodį arba pažymėkite iki keturių žodžių.</p>
      </aside>

      {isTrackLesson && (
        <section
          class="study-coach"
          data-lesson-progress
          data-lesson-slug={entry.data.slug}
          data-lesson-revision={lessonRevision}
        >
          <div class="study-coach-head">
            <div>
              <p class="eyebrow">Active study loop</p>
              <h2>Show what you did</h2>
              <p>Tick each step after you really do it. This study loop is ready when all four are checked.</p>
              <p class="lt-text" lang="lt">Pažymėkite tik atliktus žingsnius. Mokymosi ciklas baigtas, kai atlikti visi keturi.</p>
            </div>
            <div class="study-coach-actions">
              <strong class="study-step-count" data-lesson-step-count>0 of 4 steps</strong>
              <button type="button" class="secondary-button" data-lesson-complete disabled>
                Complete study loop
              </button>
              <button type="button" class="text-button" data-lesson-reset hidden>
                Start again
              </button>
            </div>
          </div>

          <fieldset class="study-step-list">
            <legend class="sr-only">Lesson study evidence</legend>
            {studySteps.map((step) => (
              <label class="study-step">
                <input type="checkbox" data-study-step={step.id} />
                <span>
                  <strong>{step.label}:</strong> {step.copy}
                  <small class="lt-text" lang="lt">{step.ltCopy}</small>
                </span>
              </label>
            ))}
          </fieldset>

          <p
            class="study-progress-note"
            data-lesson-completion-status
            role="status"
            aria-live="polite"
            aria-atomic="true"
          >
            Complete the four steps to finish this study loop. Progress is saved on this device.
          </p>
        </section>
      )}

      {introHtml && <div class="prose intro-block" set:html={introHtml} />}

      {practiceCallout && (
        <section class="support-callout">
          <div class="support-callout-copy">
            <p class="eyebrow">Speaking mission</p>
            <h2>{practiceCallout.title}</h2>
            <p class="lt-text" lang="lt">{practiceCallout.ltTitle}</p>
            <p>{practiceCallout.description}</p>
          </div>
          <a class="primary-button" href={practiceCallout.href}>
            {practiceCallout.buttonLabel}
          </a>
        </section>
      )}

      {sections.map((section) =>
        section.collapsible ? (
          <details
            class="content-panel collapsible"
            id={section.id}
            data-persist-key={`${entry.data.slug}:${section.id}`}
          >
            <summary set:html={section.titleHtml} />
            <div class="prose" set:html={section.html} />
          </details>
        ) : (
          <section class="content-panel" id={section.id}>
            <h2 set:html={section.titleHtml} />
            <div class="prose" set:html={section.html} />
          </section>
        ),
      )}

      {answerSnippetHtml && (
        <details
          class="content-panel collapsible answer-preview"
          id="answer-preview"
          data-persist-key={`${entry.data.slug}:answer-preview`}
        >
          <summary>Answer preview <span class="lt-text" lang="lt">Atsakymų peržiūra</span></summary>
          <div class="prose" set:html={answerSnippetHtml} />
          {answerHref && (
            <p class="answer-link-row">
              <a class="inline-link" href={answerHref}>
                Open full answer key
                <span class="lt-text" lang="lt">Atidaryti pilną atsakymų raktą</span>
              </a>
            </p>
          )}
        </details>
      )}
    </article>
  </div>
</BaseLayout>
