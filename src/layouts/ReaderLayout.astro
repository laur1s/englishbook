---
import type { LibraryEntry } from "../lib/content";
import type { ParsedSection } from "../lib/markdown";

import BaseLayout from "./BaseLayout.astro";
import { getCollectionHref, getEntryHref } from "../lib/content";

type Props = {
  entry: LibraryEntry;
  description?: string;
  introHtml: string;
  sections: ParsedSection[];
  previous?: LibraryEntry;
  next?: LibraryEntry;
  totalEntries?: number;
  answerHref?: string;
  answerSnippetHtml?: string;
  practiceCallout?: {
    href: string;
    title: string;
    ltTitle: string;
    description: string;
    buttonLabel: string;
  };
};

const {
  entry,
  description,
  introHtml,
  sections,
  previous,
  next,
  totalEntries,
  answerHref,
  answerSnippetHtml,
  practiceCallout,
} = Astro.props;

const collectionTitle =
  entry.data.collection === "grey-book"
    ? "Grey's Book"
    : entry.data.collection === "a2-units"
      ? "A2 Course"
      : entry.data.collection === "resources"
        ? "Resources"
        : "Library";
const isTrackLesson = entry.data.collection === "grey-book" || entry.data.collection === "a2-units";
const sequenceLabel =
  entry.data.collection === "grey-book"
    ? `Chapter ${entry.data.order}${totalEntries ? ` of ${totalEntries}` : ""}`
    : entry.data.collection === "a2-units"
      ? `Unit ${entry.data.order}${totalEntries ? ` of ${totalEntries}` : ""}`
      : entry.data.collection.replace("-", " ");
---

<BaseLayout title={`${entry.data.title} | English Library`} description={description} enableTranslation>
  <section class="reader-hero">
    <p class="eyebrow">{sequenceLabel}</p>
    <h1>{entry.data.title}</h1>
    <p class="hero-subtitle lt-text" lang="lt">{entry.data.ltTitle}</p>

    <div class="badge-row">
      <span class="badge">{entry.data.level}</span>
      <span class="badge">{entry.data.contentType}</span>
      {entry.data.grammarFocus.map((focus) => <span class="badge soft">{focus}</span>)}
    </div>

    <p class="topic-row">
      {entry.data.topics.map((topic) => <span>{topic}</span>)}
    </p>
  </section>

  <nav class="reader-nav-bar" aria-label="Chapter navigation">
    <a class="reader-nav-link reader-nav-back" href={getCollectionHref(entry.data.collection)}>
      <span class="pager-label">Back to collection</span>
      <strong>{collectionTitle}</strong>
    </a>

    {previous ? (
      <a class="reader-nav-link" href={getEntryHref(previous)}>
        <span class="pager-label">Previous</span>
        <strong>{previous.data.title}</strong>
      </a>
    ) : (
      <span class="reader-nav-link reader-nav-empty" />
    )}

    {next ? (
      <a class="reader-nav-link align-right" href={getEntryHref(next)}>
        <span class="pager-label">Next</span>
        <strong>{next.data.title}</strong>
      </a>
    ) : (
      <span class="reader-nav-link reader-nav-empty" />
    )}

    {answerSnippetHtml ? (
      <a class="reader-nav-link reader-nav-answer" href="#answer-preview">
        <span class="pager-label">Jump to answer preview</span>
        <strong>Review only when ready</strong>
      </a>
    ) : null}
  </nav>

  <div class="reader-shell">
    <aside class="reader-sidebar">
      <div class="toc-card">
        <h2>On this page</h2>
        <p class="lt-text sidebar-subtitle" lang="lt">Šio puslapio turinys</p>
        <ul>
          {sections.map((section) => (
            <li>
              <a href={`#${section.id}`} set:html={section.titleHtml} />
            </li>
          ))}
          {answerSnippetHtml && <li><a href="#answer-preview">Answer preview</a></li>}
        </ul>
      </div>
    </aside>

    <article class="reader-content">
      {isTrackLesson && (
        <section class="study-coach" data-lesson-progress data-lesson-slug={entry.data.slug}>
          <div class="study-coach-head">
            <div>
              <p class="eyebrow">Active study loop</p>
              <h2>Try first. Check later.</h2>
              <p class="lt-text" lang="lt">Pirmiausia pabandykite, tada tikrinkite atsakymus.</p>
            </div>
            <button type="button" class="secondary-button" data-lesson-complete aria-pressed="false">
              Mark lesson complete
            </button>
          </div>

          <ol class="study-step-list">
            <li><strong>Notice:</strong> read the examples and say two of them aloud.</li>
            <li><strong>Retrieve:</strong> close the notes and complete one exercise without help.</li>
            <li><strong>Produce:</strong> make three true sentences about your own life.</li>
            <li><strong>Correct:</strong> check the key, fix one error, and retry it tomorrow.</li>
          </ol>

          <p class="study-progress-note" data-lesson-completion-status aria-live="polite">
            Progress is saved only on this device.
          </p>
        </section>
      )}

      {introHtml && <div class="prose intro-block" set:html={introHtml} />}

      {practiceCallout && (
        <section class="support-callout">
          <div class="support-callout-copy">
            <p class="eyebrow">Speaking mission</p>
            <h2>{practiceCallout.title}</h2>
            <p class="lt-text" lang="lt">{practiceCallout.ltTitle}</p>
            <p>{practiceCallout.description}</p>
          </div>
          <a class="primary-button" href={practiceCallout.href}>
            {practiceCallout.buttonLabel}
          </a>
        </section>
      )}

      {sections.map((section) =>
        section.collapsible ? (
          <details
            class="content-panel collapsible"
            id={section.id}
            data-persist-key={`${entry.data.slug}:${section.id}`}
          >
            <summary set:html={section.titleHtml} />
            <div class="prose" set:html={section.html} />
          </details>
        ) : (
          <section class="content-panel" id={section.id}>
            <h2 set:html={section.titleHtml} />
            <div class="prose" set:html={section.html} />
          </section>
        ),
      )}

      {answerSnippetHtml && (
        <details
          class="content-panel collapsible answer-preview"
          id="answer-preview"
          data-persist-key={`${entry.data.slug}:answer-preview`}
        >
          <summary>Answer preview <span class="lt-text" lang="lt">Atsakymų peržiūra</span></summary>
          <div class="prose" set:html={answerSnippetHtml} />
          {answerHref && (
            <p class="answer-link-row">
              <a class="inline-link" href={answerHref}>
                Open full answer key
                <span class="lt-text" lang="lt">Atidaryti pilną atsakymų raktą</span>
              </a>
            </p>
          )}
        </details>
      )}
    </article>
  </div>
</BaseLayout>
