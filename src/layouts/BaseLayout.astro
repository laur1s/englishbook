---
import "../styles/global.css";

import { NAV_LINKS, withBase } from "../lib/constants";
import { getTranslationDictionary } from "../lib/translation-dictionary";

type Props = {
  title: string;
  description?: string;
  enableTranslation?: boolean;
};

const { title, description = "Bilingual English learning library for Lithuanian learners.", enableTranslation = false } =
  Astro.props;
const currentPath = Astro.url.pathname.replace(import.meta.env.BASE_URL.replace(/\/$/, ""), "") || "/";
const pathSegments = currentPath.split("/").filter(Boolean);
const serializeForInlineScript = (value: unknown) => JSON.stringify(value).replace(/</g, "\\u003c");
const translationDictionary = serializeForInlineScript(
  enableTranslation ? getTranslationDictionary() : {},
);
const resumeContext =
  pathSegments.length === 2 && (pathSegments[0] === "grey-book" || pathSegments[0] === "a2")
    ? {
        key: "english-library.resume",
        href: withBase(currentPath),
        title: title.replace(/\s+\|\s+English Library$/, ""),
        track: pathSegments[0] === "grey-book" ? "Grey's Book" : "A2 Course",
      }
    : null;
---

<!doctype html>
<html lang="en" data-lt="shown">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>

    <header class="site-header">
      <a class="brand" href={withBase("/")}>
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 32 28">
            <path d="M2.5 3.5c4.8-.8 9.1.3 13.5 3.2v18.1c-4.4-2.9-8.7-4-13.5-3.2V3.5Z" />
            <path d="M29.5 3.5c-4.8-.8-9.1.3-13.5 3.2v18.1c4.4-2.9 8.7-4 13.5-3.2V3.5Z" />
            <path d="M2.5 24.2c4.8-.8 9.1.3 13.5 3.2 4.4-2.9 8.7-4 13.5-3.2" />
          </svg>
        </span>
        <span class="brand-copy">
          <strong>English Library</strong>
        </span>
      </a>

      <nav class="site-nav" id="primary-navigation" aria-label="Primary">
        {NAV_LINKS.map((link) => (
          <a
            class:list={[currentPath === link.href || currentPath.startsWith(`${link.href}/`) ? "active" : ""]}
            href={withBase(link.href)}
            aria-current={currentPath === link.href || currentPath.startsWith(`${link.href}/`) ? "page" : undefined}
          >
            <span>{link.label}</span>
            <span class="lt-text nav-lt" lang="lt">{link.ltLabel}</span>
          </a>
        ))}
      </nav>

      <button class="toggle-button" type="button" data-lt-toggle aria-pressed="true">
        <span>LT notes</span>
        <span class="toggle-state" data-lt-state>On</span>
      </button>

      <button
        class="nav-menu-button"
        type="button"
        data-nav-toggle
        aria-controls="primary-navigation"
        aria-expanded="false"
        aria-label="Open navigation"
      >
        <span></span><span></span><span></span>
      </button>
    </header>

    <main id="main-content">
      <slot />
    </main>

    {enableTranslation && (
      <div class="translation-popover" data-translation-popover role="region" aria-label="Lithuanian translation" aria-live="polite" hidden>
        <button class="translation-close" type="button" data-translation-close aria-label="Close translation">×</button>
        <p class="translation-kicker">Lithuanian translation</p>
        <strong data-translation-word></strong>
        <ul data-translation-list></ul>
        <p class="translation-hint">
          Select another word to translate it.
          <span class="lt-text" lang="lt">Pažymėkite kitą žodį vertimui.</span>
        </p>
      </div>
    )}

    <script is:inline type="application/json" id="translation-dictionary-data" set:html={translationDictionary} />
    <script is:inline type="application/json" id="resume-context-data" set:html={serializeForInlineScript(resumeContext)} />

    <script is:inline>
      const storageKey = "english-library.lt-visible";
      const root = document.documentElement;
      const siteHeader = document.querySelector(".site-header");
      const navButton = document.querySelector("[data-nav-toggle]");
      const siteNavigation = document.getElementById("primary-navigation");
      const button = document.querySelector("[data-lt-toggle]");
      const state = document.querySelector("[data-lt-state]");
      const getStoredValue = (key) => {
        try {
          return localStorage.getItem(key);
        } catch {
          return null;
        }
      };
      const setStoredValue = (key, value) => {
        try {
          localStorage.setItem(key, value);
        } catch {}
      };
      const getStoredJson = (key, fallback = {}) => {
        try {
          const raw = localStorage.getItem(key);
          const parsed = raw ? JSON.parse(raw) : fallback;
          return parsed && typeof parsed === "object" && !Array.isArray(parsed)
            ? parsed
            : fallback;
        } catch {
          return fallback;
        }
      };
      const translationDictionary = JSON.parse(
        document.getElementById("translation-dictionary-data")?.textContent || "{}",
      );
      const resumeContext = JSON.parse(
        document.getElementById("resume-context-data")?.textContent || "null",
      );
      const translationPopover = document.querySelector("[data-translation-popover]");
      const translationClose = document.querySelector("[data-translation-close]");
      const translationWord = document.querySelector("[data-translation-word]");
      const translationList = document.querySelector("[data-translation-list]");
      const setState = (isVisible) => {
        root.dataset.lt = isVisible ? "shown" : "hidden";
        setStoredValue(storageKey, String(isVisible));
        if (state) state.textContent = isVisible ? "On" : "Off";
        button?.setAttribute("aria-pressed", String(isVisible));
      };

      const savedState = getStoredValue(storageKey);
      setState(savedState === null ? true : savedState === "true");

      button?.addEventListener("click", () => {
        setState(root.dataset.lt !== "shown");
      });

      navButton?.addEventListener("click", () => {
        const isOpen = siteHeader?.classList.toggle("nav-open") ?? false;
        navButton.setAttribute("aria-expanded", String(isOpen));
        navButton.setAttribute("aria-label", isOpen ? "Close navigation" : "Open navigation");
      });

      siteNavigation?.addEventListener("click", (event) => {
        if (event.target instanceof Element && event.target.closest("a")) {
          siteHeader?.classList.remove("nav-open");
          navButton?.setAttribute("aria-expanded", "false");
          navButton?.setAttribute("aria-label", "Open navigation");
        }
      });

      if (resumeContext) {
        setStoredValue(resumeContext.key, JSON.stringify(resumeContext));
      }

      document.querySelectorAll("details[data-persist-key]").forEach((element) => {
        const key = `english-library.details.${element.dataset.persistKey}`;
        const saved = getStoredValue(key);

        if (saved !== null) {
          element.open = saved === "true";
        }

        element.addEventListener("toggle", () => {
          setStoredValue(key, String(element.open));
        });
      });

      const openHashTarget = (hash = window.location.hash) => {
        if (!hash) {
          return;
        }

        let id = hash.slice(1);

        try {
          id = decodeURIComponent(id);
        } catch {}

        const target = document.getElementById(id);

        if (target instanceof HTMLDetailsElement) {
          target.open = true;
          window.requestAnimationFrame(() => {
            target.querySelector("summary")?.focus({ preventScroll: true });
          });
        }
      };

      openHashTarget();
      window.addEventListener("hashchange", () => openHashTarget());
      document.addEventListener("click", (event) => {
        const anchor = event.target instanceof Element ? event.target.closest("a[href]") : null;

        if (!anchor) {
          return;
        }

        const url = new URL(anchor.href, window.location.href);

        if (
          url.origin === window.location.origin &&
          url.pathname === window.location.pathname &&
          url.hash
        ) {
          openHashTarget(url.hash);
        }
      });

      document.querySelectorAll("[data-filter-root]").forEach((rootElement) => {
        const cards = [...rootElement.querySelectorAll("[data-card]")];
        const buttons = [...rootElement.querySelectorAll("[data-filter-button]")];
        const status = rootElement.querySelector("[data-filter-status]");
        const clearButton = rootElement.querySelector("[data-filter-clear]");
        const emptyState = rootElement.querySelector("[data-filter-empty]");
        const itemLabel = rootElement.dataset.filterItemLabel || "items";
        const active = {
          level: new Set(),
          grammar: new Set(),
          topic: new Set(),
        };

        const applyFilters = () => {
          let visibleCount = 0;

          cards.forEach((card) => {
            const levels = (card.dataset.levels || "").split("|").filter(Boolean);
            const grammar = (card.dataset.grammar || "").split("|").filter(Boolean);
            const topics = (card.dataset.topics || "").split("|").filter(Boolean);

            const levelMatch = !active.level.size || levels.some((value) => active.level.has(value));
            const grammarMatch =
              !active.grammar.size || grammar.some((value) => active.grammar.has(value));
            const topicMatch = !active.topic.size || topics.some((value) => active.topic.has(value));

            const isVisible = levelMatch && grammarMatch && topicMatch;
            card.hidden = !isVisible;

            if (isVisible) {
              visibleCount += 1;
            }
          });

          const activeCount = Object.values(active).reduce((count, values) => count + values.size, 0);

          if (status) {
            status.textContent = `Showing ${visibleCount} of ${cards.length} ${itemLabel}`;
          }

          if (clearButton) {
            clearButton.hidden = activeCount === 0;
          }

          if (emptyState) {
            emptyState.hidden = visibleCount !== 0;
          }
        };

        buttons.forEach((buttonElement) => {
          buttonElement.addEventListener("click", () => {
            const group = buttonElement.dataset.filterGroup;
            const value = buttonElement.dataset.filterValue;

            if (!group || !value || !(group in active)) return;

            if (active[group].has(value)) {
              active[group].delete(value);
              buttonElement.classList.remove("selected");
              buttonElement.setAttribute("aria-pressed", "false");
            } else {
              active[group].add(value);
              buttonElement.classList.add("selected");
              buttonElement.setAttribute("aria-pressed", "true");
            }

            applyFilters();
          });
        });

        clearButton?.addEventListener("click", () => {
          Object.values(active).forEach((values) => values.clear());
          buttons.forEach((buttonElement) => {
            buttonElement.classList.remove("selected");
            buttonElement.setAttribute("aria-pressed", "false");
          });
          applyFilters();
        });

        applyFilters();
      });

      const lessonProgressKey = "english-library.lesson-progress";
      const lessonProgress = getStoredJson(lessonProgressKey);

      const syncLessonCards = () => {
        document.querySelectorAll("[data-lesson-card]").forEach((card) => {
          const slug = card.dataset.lessonSlug;
          const label = card.querySelector("[data-lesson-card-status]");

          if (label && slug) {
            const isComplete = Boolean(lessonProgress[slug]?.completedAt);
            label.textContent = isComplete ? "Completed" : "Not completed";
            label.classList.toggle("complete", isComplete);
          }
        });
      };

      document.querySelectorAll("[data-lesson-progress]").forEach((progressRoot) => {
        const slug = progressRoot.dataset.lessonSlug;
        const completeButton = progressRoot.querySelector("[data-lesson-complete]");
        const completionStatus = progressRoot.querySelector("[data-lesson-completion-status]");

        if (!slug || !completeButton) {
          return;
        }

        const syncLessonProgress = () => {
          const isComplete = Boolean(lessonProgress[slug]?.completedAt);
          completeButton.setAttribute("aria-pressed", String(isComplete));
          completeButton.classList.toggle("is-complete", isComplete);
          completeButton.textContent = isComplete ? "Completed — mark incomplete" : "Mark lesson complete";

          if (completionStatus) {
            completionStatus.textContent = isComplete
              ? "Completed on this device. Reopen the lesson later for spaced review."
              : "Progress is saved only on this device.";
          }
        };

        completeButton.addEventListener("click", () => {
          if (lessonProgress[slug]?.completedAt) {
            delete lessonProgress[slug];
          } else {
            lessonProgress[slug] = { completedAt: new Date().toISOString() };
          }

          setStoredValue(lessonProgressKey, JSON.stringify(lessonProgress));
          syncLessonProgress();
          syncLessonCards();
        });

        syncLessonProgress();
      });

      syncLessonCards();

      const MAX_SELECTION_WORDS = 4;
      let selectionTimer = null;
      let suppressSelectionClickUntil = 0;

      const normalizeWord = (value) =>
        value
          .toLowerCase()
          .normalize("NFKD")
          .replace(/[\u0300-\u036f]/g, "")
          .replace(/(^[^a-z]+|[^a-z]+$)/g, "");

      const wordCandidates = (value) => {
        const normalized = normalizeWord(value);
        const variants = [normalized];

        if (normalized.endsWith("ies") && normalized.length > 4) {
          variants.push(`${normalized.slice(0, -3)}y`);
        }

        if (normalized.endsWith("es") && normalized.length > 4) {
          variants.push(normalized.slice(0, -2));
        }

        if (normalized.endsWith("s") && normalized.length > 3) {
          variants.push(normalized.slice(0, -1));
        }

        return [...new Set(variants.filter(Boolean))];
      };

      const isEligibleTarget = (target) => {
        if (!target || !(target instanceof Node)) {
          return false;
        }

        const element =
          target instanceof Element ? target : target.parentElement;

        if (!element) {
          return false;
        }

        return !element.closest(
          "a, button, summary, input, textarea, select, code, pre, .lt-text, .translation-popover",
        );
      };

      const closeTranslationPopover = () => {
        translationPopover?.setAttribute("hidden", "");
      };

      const showTranslationPopover = ({ word, translations, x, y }) => {
        if (!translationPopover || !translationWord || !translationList) {
          return;
        }

        translationWord.textContent = word;
        translationList.innerHTML = "";

        translations.slice(0, 6).forEach((translation) => {
          const item = document.createElement("li");
          item.textContent = translation;
          translationList.appendChild(item);
        });

        translationPopover.removeAttribute("hidden");

        const rect = translationPopover.getBoundingClientRect();
        const left = Math.min(
          Math.max(12, x - rect.width / 2),
          window.innerWidth - rect.width - 12,
        );
        const top = Math.min(
          Math.max(12, y + 18),
          window.innerHeight - rect.height - 12,
        );

        translationPopover.style.left = `${left}px`;
        translationPopover.style.top = `${top}px`;
      };

      const lookupTranslation = (terms) => {
        for (const term of terms) {
          for (const candidate of wordCandidates(term)) {
            const translations = translationDictionary[candidate];

            if (translations?.length) {
              return {
                matchedTerm: term,
                translations,
              };
            }
          }
        }

        return null;
      };

      const getSelectionTarget = () => {
        const selection = document.getSelection();

        if (!selection || selection.isCollapsed || !selection.rangeCount) {
          return;
        }

        if (!isEligibleTarget(selection.anchorNode) || !isEligibleTarget(selection.focusNode)) {
          return null;
        }

        const range = selection.getRangeAt(0).cloneRange();
        const selectedText = selection.toString().replace(/\s+/g, " ").trim();
        const words = selectedText.split(" ").filter(Boolean);

        if (!selectedText || !words.length || words.length > MAX_SELECTION_WORDS) {
          return null;
        }

        const rect = range.getBoundingClientRect();

        if (!rect.width && !rect.height) {
          return null;
        }

        return {
          displayWord: selectedText,
          terms: [selectedText],
          x: rect.left + rect.width / 2,
          y: rect.bottom,
        };
      };

      const syncSelectionTranslation = () => {
        const selectionTarget = getSelectionTarget();

        if (!selectionTarget) {
          closeTranslationPopover();
          return;
        }

        const translationResult = lookupTranslation(selectionTarget.terms);

        if (!translationResult) {
          closeTranslationPopover();
          return;
        }

        suppressSelectionClickUntil = Date.now() + 250;
        showTranslationPopover({
          word: translationResult.matchedTerm || selectionTarget.displayWord,
          translations: translationResult.translations,
          x: selectionTarget.x,
          y: selectionTarget.y,
        });
      };

      document.addEventListener("selectionchange", () => {
        window.clearTimeout(selectionTimer);
        selectionTimer = window.setTimeout(syncSelectionTranslation, 50);
      });

      window.addEventListener("scroll", closeTranslationPopover, { passive: true });
      translationClose?.addEventListener("click", closeTranslationPopover);

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeTranslationPopover();
        }
      });

      document.addEventListener("click", (event) => {
        if (Date.now() < suppressSelectionClickUntil && isEligibleTarget(event.target)) {
          suppressSelectionClickUntil = 0;
          event.preventDefault();
          event.stopPropagation();
          return;
        }

        if (!translationPopover?.contains(event.target)) {
          closeTranslationPopover();
        }
      });

    </script>
  </body>
</html>
