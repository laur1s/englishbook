---
import "../styles/global.css";

import { NAV_LINKS, withBase } from "../lib/constants";
import { getTranslationDictionary } from "../lib/translation-dictionary";

type Props = {
  title: string;
  description?: string;
  enableTranslation?: boolean;
};

const { title, description = "Bilingual English learning library for Lithuanian learners.", enableTranslation = false } =
  Astro.props;
const currentPath = Astro.url.pathname.replace(import.meta.env.BASE_URL.replace(/\/$/, ""), "") || "/";
const pathSegments = currentPath.split("/").filter(Boolean);
const serializeForInlineScript = (value: unknown) => JSON.stringify(value).replace(/</g, "\\u003c");
const translationDictionary = serializeForInlineScript(
  enableTranslation ? getTranslationDictionary() : {},
);
const resumeContext =
  pathSegments.length === 2 && (pathSegments[0] === "grey-book" || pathSegments[0] === "a2")
    ? {
        key: "english-library.resume",
        href: withBase(currentPath),
        title: title.replace(/\s+\|\s+English Library$/, ""),
        track: pathSegments[0] === "grey-book" ? "Grey's Book" : "A2 Course",
      }
    : null;
---

<!doctype html>
<html lang="en" data-lt="shown">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>

    <header class="site-header">
      <a class="brand" href={withBase("/")}>
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 32 28">
            <path d="M2.5 3.5c4.8-.8 9.1.3 13.5 3.2v18.1c-4.4-2.9-8.7-4-13.5-3.2V3.5Z" />
            <path d="M29.5 3.5c-4.8-.8-9.1.3-13.5 3.2v18.1c4.4-2.9 8.7-4 13.5-3.2V3.5Z" />
            <path d="M2.5 24.2c4.8-.8 9.1.3 13.5 3.2 4.4-2.9 8.7-4 13.5-3.2" />
          </svg>
        </span>
        <span class="brand-copy">
          <strong>English Library</strong>
        </span>
      </a>

      <nav class="site-nav" id="primary-navigation" aria-label="Primary">
        {NAV_LINKS.map((link) => (
          <a
            class:list={[currentPath === link.href || currentPath.startsWith(`${link.href}/`) ? "active" : ""]}
            href={withBase(link.href)}
            aria-current={currentPath === link.href || currentPath.startsWith(`${link.href}/`) ? "page" : undefined}
          >
            <span>{link.label}</span>
            <span class="lt-text nav-lt" lang="lt">{link.ltLabel}</span>
          </a>
        ))}
      </nav>

      <button class="toggle-button" type="button" data-lt-toggle aria-pressed="true">
        <span>LT notes</span>
        <span class="toggle-state" data-lt-state>On</span>
      </button>

      <button
        class="nav-menu-button"
        type="button"
        data-nav-toggle
        aria-controls="primary-navigation"
        aria-expanded="false"
        aria-label="Open navigation"
      >
        <span></span><span></span><span></span>
      </button>
    </header>

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    {enableTranslation && (
      <div id="translation-popover" class="translation-popover" data-translation-popover role="region" aria-label="Lithuanian translation" aria-live="polite" hidden>
        <button class="translation-close" type="button" data-translation-close aria-label="Close translation">×</button>
        <p class="translation-kicker">Lithuanian translation</p>
        <strong data-translation-word></strong>
        <ul data-translation-list></ul>
        <p class="translation-hint">
          Click or tap another underlined word, or select up to four words.
          <span class="lt-text" lang="lt">Spustelėkite arba bakstelėkite kitą pabrauktą žodį arba pažymėkite iki keturių žodžių.</span>
        </p>
      </div>
    )}

    <script is:inline type="application/json" id="translation-dictionary-data" set:html={translationDictionary} />
    <script is:inline type="application/json" id="resume-context-data" set:html={serializeForInlineScript(resumeContext)} />

    <script is:inline>
      const storageKey = "english-library.lt-visible";
      const root = document.documentElement;
      const siteHeader = document.querySelector(".site-header");
      const navButton = document.querySelector("[data-nav-toggle]");
      const siteNavigation = document.getElementById("primary-navigation");
      const button = document.querySelector("[data-lt-toggle]");
      const state = document.querySelector("[data-lt-state]");
      const mobileNavigation = window.matchMedia("(max-width: 680px)");
      const getStoredValue = (key) => {
        try {
          return localStorage.getItem(key);
        } catch {
          return null;
        }
      };
      const setStoredValue = (key, value) => {
        try {
          localStorage.setItem(key, value);
        } catch {}
      };
      const resumeContext = JSON.parse(
        document.getElementById("resume-context-data")?.textContent || "null",
      );
      const setState = (isVisible) => {
        root.dataset.lt = isVisible ? "shown" : "hidden";
        setStoredValue(storageKey, String(isVisible));
        if (state) state.textContent = isVisible ? "On" : "Off";
        button?.setAttribute("aria-pressed", String(isVisible));
      };

      const savedState = getStoredValue(storageKey);
      setState(savedState === null ? true : savedState === "true");

      button?.addEventListener("click", () => {
        setState(root.dataset.lt !== "shown");
      });

      const setNavigationOpen = (isOpen, { focusMenu = false, restoreFocus = false } = {}) => {
        siteHeader?.classList.toggle("nav-open", isOpen);
        navButton?.setAttribute("aria-expanded", String(isOpen));
        navButton?.setAttribute("aria-label", isOpen ? "Close navigation" : "Open navigation");

        if (focusMenu) {
          window.requestAnimationFrame(() => siteNavigation?.querySelector("a")?.focus());
        } else if (restoreFocus) {
          navButton?.focus();
        }
      };

      navButton?.addEventListener("click", () => {
        const willOpen = !siteHeader?.classList.contains("nav-open");
        setNavigationOpen(willOpen, { focusMenu: willOpen });
      });

      siteNavigation?.addEventListener("click", (event) => {
        if (event.target instanceof Element && event.target.closest("a")) {
          setNavigationOpen(false);
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && siteHeader?.classList.contains("nav-open")) {
          setNavigationOpen(false, { restoreFocus: true });
        }
      });

      mobileNavigation.addEventListener("change", (event) => {
        if (!event.matches) setNavigationOpen(false);
      });

      if (resumeContext) {
        setStoredValue(resumeContext.key, JSON.stringify(resumeContext));
      }

      document.querySelectorAll("details[data-persist-key]").forEach((element) => {
        const key = `english-library.details.${element.dataset.persistKey}`;
        const saved = getStoredValue(key);

        if (saved !== null) {
          element.open = saved === "true";
        }

        element.addEventListener("toggle", () => {
          setStoredValue(key, String(element.open));
        });
      });

      const openHashTarget = (hash = window.location.hash) => {
        if (!hash) {
          return;
        }

        let id = hash.slice(1);

        try {
          id = decodeURIComponent(id);
        } catch {}

        const target = document.getElementById(id);

        if (target instanceof HTMLDetailsElement) {
          target.open = true;
          window.requestAnimationFrame(() => {
            target.querySelector("summary")?.focus({ preventScroll: true });
          });
        }
      };

      openHashTarget();
      window.addEventListener("hashchange", () => openHashTarget());
      document.addEventListener("click", (event) => {
        const anchor = event.target instanceof Element ? event.target.closest("a[href]") : null;

        if (!anchor) {
          return;
        }

        const url = new URL(anchor.href, window.location.href);

        if (
          url.origin === window.location.origin &&
          url.pathname === window.location.pathname &&
          url.hash
        ) {
          openHashTarget(url.hash);
        }
      });

      document.querySelectorAll("[data-filter-root]").forEach((rootElement) => {
        const cards = [...rootElement.querySelectorAll("[data-card]")];
        const buttons = [...rootElement.querySelectorAll("[data-filter-button]")];
        const status = rootElement.querySelector("[data-filter-status]");
        const clearButton = rootElement.querySelector("[data-filter-clear]");
        const emptyState = rootElement.querySelector("[data-filter-empty]");
        const itemLabel = rootElement.dataset.filterItemLabel || "items";
        const active = {
          level: new Set(),
          grammar: new Set(),
          topic: new Set(),
        };

        const applyFilters = () => {
          let visibleCount = 0;

          cards.forEach((card) => {
            const levels = (card.dataset.levels || "").split("|").filter(Boolean);
            const grammar = (card.dataset.grammar || "").split("|").filter(Boolean);
            const topics = (card.dataset.topics || "").split("|").filter(Boolean);

            const levelMatch = !active.level.size || levels.some((value) => active.level.has(value));
            const grammarMatch =
              !active.grammar.size || grammar.some((value) => active.grammar.has(value));
            const topicMatch = !active.topic.size || topics.some((value) => active.topic.has(value));

            const isVisible = levelMatch && grammarMatch && topicMatch;
            card.hidden = !isVisible;

            if (isVisible) {
              visibleCount += 1;
            }
          });

          const activeCount = Object.values(active).reduce((count, values) => count + values.size, 0);

          if (status) {
            status.textContent = `Showing ${visibleCount} of ${cards.length} ${itemLabel}`;
          }

          if (clearButton) {
            clearButton.hidden = activeCount === 0;
          }

          if (emptyState) {
            emptyState.hidden = visibleCount !== 0;
          }
        };

        buttons.forEach((buttonElement) => {
          buttonElement.addEventListener("click", () => {
            const group = buttonElement.dataset.filterGroup;
            const value = buttonElement.dataset.filterValue;

            if (!group || !value || !(group in active)) return;

            if (active[group].has(value)) {
              active[group].delete(value);
              buttonElement.classList.remove("selected");
              buttonElement.setAttribute("aria-pressed", "false");
            } else {
              active[group].add(value);
              buttonElement.classList.add("selected");
              buttonElement.setAttribute("aria-pressed", "true");
            }

            applyFilters();
          });
        });

        clearButton?.addEventListener("click", () => {
          Object.values(active).forEach((values) => values.clear());
          buttons.forEach((buttonElement) => {
            buttonElement.classList.remove("selected");
            buttonElement.setAttribute("aria-pressed", "false");
          });
          applyFilters();
        });

        applyFilters();
      });

    </script>

    <script>
      import {
        findTranslationMatches,
        lookupTranslation,
        MAX_LOOKUP_WORDS,
        type TranslationDictionary,
      } from "../lib/translation-lookup";

      const dictionaryElement = document.getElementById("translation-dictionary-data");
      const translationPopover = document.querySelector<HTMLElement>("[data-translation-popover]");
      const translationClose = document.querySelector<HTMLButtonElement>("[data-translation-close]");
      const translationWord = document.querySelector<HTMLElement>("[data-translation-word]");
      const translationList = document.querySelector<HTMLUListElement>("[data-translation-list]");

      if (dictionaryElement && translationPopover && translationWord && translationList) {
        const translationDictionary = JSON.parse(
          dictionaryElement.textContent || "{}",
        ) as TranslationDictionary;
        const excludedTranslationSelector = [
          "a",
          "button",
          "summary",
          "input",
          "textarea",
          "select",
          "code",
          "pre",
          ".lt-text",
          "[lang='lt']",
          ".translation-popover",
        ].join(", ");
        const excludedDecorationSelector = `${excludedTranslationSelector}, [data-translation-term]`;
        let selectionTimer: number | undefined;
        let suppressSelectionClickUntil = 0;
        let activeTranslationTrigger: HTMLElement | null = null;
        let translationTermIndex = 0;

        const isEligibleTarget = (
          target: EventTarget | Node | null,
          excludedSelector = excludedTranslationSelector,
        ) => {
          if (!target || !(target instanceof Node)) {
            return false;
          }

          const element = target instanceof Element ? target : target.parentElement;
          return Boolean(element && !element.closest(excludedSelector));
        };

        const closeTranslationPopover = ({ restoreFocus = false } = {}) => {
          const trigger = activeTranslationTrigger;
          translationPopover.setAttribute("hidden", "");
          translationPopover.removeAttribute("aria-labelledby");
          trigger?.setAttribute("aria-expanded", "false");
          activeTranslationTrigger = null;

          if (restoreFocus && trigger?.isConnected) {
            window.requestAnimationFrame(() => trigger.focus({ preventScroll: true }));
          }
        };

        const showTranslationPopover = ({
          word,
          translations,
          x,
          topY,
          bottomY,
          trigger,
        }: {
          word: string;
          translations: string[];
          x: number;
          topY: number;
          bottomY: number;
          trigger?: HTMLElement;
        }) => {
          if (activeTranslationTrigger && activeTranslationTrigger !== trigger) {
            activeTranslationTrigger.setAttribute("aria-expanded", "false");
          }
          activeTranslationTrigger = trigger ?? null;
          if (trigger) {
            trigger.setAttribute("aria-expanded", "true");
            translationPopover.setAttribute("aria-labelledby", trigger.id);
          } else {
            translationPopover.removeAttribute("aria-labelledby");
          }
          translationWord.textContent = word;
          translationList.replaceChildren(
            ...translations.slice(0, 6).map((translation) => {
              const item = document.createElement("li");
              item.textContent = translation;
              return item;
            }),
          );
          translationPopover.removeAttribute("hidden");

          const rect = translationPopover.getBoundingClientRect();
          const viewportInset = 12;
          const anchorGap = 18;
          const left = Math.min(
            Math.max(viewportInset, x - rect.width / 2),
            window.innerWidth - rect.width - viewportInset,
          );
          const below = bottomY + anchorGap;
          const above = topY - rect.height - anchorGap;
          const top = below + rect.height <= window.innerHeight - viewportInset
            ? below
            : Math.max(
                viewportInset,
                Math.min(above, window.innerHeight - rect.height - viewportInset),
              );

          translationPopover.style.left = `${left}px`;
          translationPopover.style.top = `${top}px`;
        };

        const activateTranslationTerm = (marker: HTMLElement) => {
          const dictionaryKey = marker.dataset.translationTerm;

          if (!dictionaryKey) {
            return;
          }

          const translations = translationDictionary[dictionaryKey];

          if (!translations?.length) {
            return;
          }

          const rect = marker.getBoundingClientRect();
          showTranslationPopover({
            word: marker.textContent?.trim() || dictionaryKey,
            translations,
            x: rect.left + rect.width / 2,
            topY: rect.top,
            bottomY: rect.bottom,
            trigger: marker,
          });
        };

        const decorateTranslationTerms = () => {
          document.querySelectorAll<HTMLElement>(".reader-content .prose").forEach((root) => {
            const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
              acceptNode(node) {
                if (!node.textContent?.trim() || !isEligibleTarget(node, excludedDecorationSelector)) {
                  return NodeFilter.FILTER_REJECT;
                }

                return NodeFilter.FILTER_ACCEPT;
              },
            });
            const textNodes: Text[] = [];

            while (walker.nextNode()) {
              textNodes.push(walker.currentNode as Text);
            }

            textNodes.forEach((textNode) => {
              const text = textNode.textContent || "";
              const matches = findTranslationMatches(text, translationDictionary);

              if (!matches.length || !textNode.parentNode) {
                return;
              }

              const fragment = document.createDocumentFragment();
              let cursor = 0;

              matches.forEach((match) => {
                fragment.append(text.slice(cursor, match.start));

                const visibleTerm = text.slice(match.start, match.end);
                const marker = document.createElement("span");
                marker.className = "translation-term";
                marker.id = `translation-term-${++translationTermIndex}`;
                marker.dataset.translationTerm = match.key;
                marker.setAttribute("role", "button");
                marker.setAttribute("tabindex", "-1");
                marker.setAttribute("aria-controls", translationPopover.id);
                marker.setAttribute("aria-expanded", "false");
                marker.setAttribute(
                  "aria-label",
                  `${visibleTerm}. Show Lithuanian translation`,
                );
                marker.title = "Show Lithuanian translation";
                marker.textContent = visibleTerm;
                fragment.append(marker);
                cursor = match.end;
              });

              fragment.append(text.slice(cursor));
              textNode.parentNode.replaceChild(fragment, textNode);
            });
          });
        };

        const getSelectionTarget = () => {
          const selection = document.getSelection();

          if (!selection || selection.isCollapsed || !selection.rangeCount) {
            return null;
          }

          if (!isEligibleTarget(selection.anchorNode) || !isEligibleTarget(selection.focusNode)) {
            return null;
          }

          const range = selection.getRangeAt(0).cloneRange();
          const selectedText = selection.toString().replace(/\s+/g, " ").trim();
          const words = selectedText.split(" ").filter(Boolean);

          if (!selectedText || !words.length || words.length > MAX_LOOKUP_WORDS) {
            return null;
          }

          const rect = range.getBoundingClientRect();

          if (!rect.width && !rect.height) {
            return null;
          }

          return {
            displayWord: selectedText,
            terms: [selectedText],
            x: rect.left + rect.width / 2,
            topY: rect.top,
            bottomY: rect.bottom,
          };
        };

        const syncSelectionTranslation = () => {
          const selectionTarget = getSelectionTarget();

          if (!selectionTarget) {
            closeTranslationPopover();
            return;
          }

          const translationResult = lookupTranslation(
            selectionTarget.terms,
            translationDictionary,
          );

          if (!translationResult) {
            closeTranslationPopover();
            return;
          }

          suppressSelectionClickUntil = Date.now() + 250;
          showTranslationPopover({
            word: translationResult.matchedTerm || selectionTarget.displayWord,
            translations: translationResult.translations,
            x: selectionTarget.x,
            topY: selectionTarget.topY,
            bottomY: selectionTarget.bottomY,
          });
        };

        decorateTranslationTerms();

        document.addEventListener("selectionchange", () => {
          window.clearTimeout(selectionTimer);
          selectionTimer = window.setTimeout(syncSelectionTranslation, 50);
        });

        window.addEventListener("scroll", () => closeTranslationPopover(), { passive: true });
        translationClose?.addEventListener("click", () => {
          closeTranslationPopover({ restoreFocus: true });
        });

        document.addEventListener("keydown", (event) => {
          const marker = event.target instanceof Element
            ? event.target.closest<HTMLElement>("[data-translation-term]")
            : null;

          if (marker && (event.key === "Enter" || event.key === " ")) {
            event.preventDefault();
            activateTranslationTerm(marker);
            return;
          }

          if (event.key === "Escape" && !translationPopover.hidden) {
            closeTranslationPopover({ restoreFocus: true });
          }
        });

        document.addEventListener("click", (event) => {
          if (Date.now() < suppressSelectionClickUntil && isEligibleTarget(event.target)) {
            suppressSelectionClickUntil = 0;
            event.preventDefault();
            event.stopPropagation();
            return;
          }

          const marker = event.target instanceof Element
            ? event.target.closest<HTMLElement>("[data-translation-term]")
            : null;

          if (marker) {
            event.preventDefault();
            activateTranslationTerm(marker);
            return;
          }

          if (!translationPopover.contains(event.target as Node)) {
            closeTranslationPopover();
          }
        });
      }
    </script>

    <script>
      import {
        LESSON_PROGRESS_KEY,
        completeLessonStudy,
        getLessonStudyState,
        isLessonStudyCompleted,
        parseLessonProgress,
        resetLessonStudy,
        setLessonStudyStep,
        uncompleteLessonStudy,
        type LessonProgress,
        type StudyStepId,
      } from "../lib/lesson-progress";

      const readLessonProgress = (): LessonProgress => {
        try {
          return parseLessonProgress(window.localStorage.getItem(LESSON_PROGRESS_KEY));
        } catch {
          return {};
        }
      };

      let lessonProgress = readLessonProgress();

      const writeLessonProgress = () => {
        try {
          window.localStorage.setItem(LESSON_PROGRESS_KEY, JSON.stringify(lessonProgress));
          window.dispatchEvent(new CustomEvent("english-library:lesson-progress"));
          return true;
        } catch {
          return false;
        }
      };

      const lessonRevision = (element: HTMLElement) => {
        const revision = Number(element.dataset.lessonRevision);
        return Number.isInteger(revision) && revision > 0 ? revision : 1;
      };

      const syncLessonCards = () => {
        document.querySelectorAll<HTMLElement>("[data-lesson-card]").forEach((card) => {
          const slug = card.dataset.lessonSlug;
          const label = card.querySelector<HTMLElement>("[data-lesson-card-status]");
          if (!label || !slug) return;

          const isComplete = isLessonStudyCompleted(lessonProgress, slug, lessonRevision(card));
          label.textContent = isComplete ? "Study checks done" : "Study checks open";
          label.classList.toggle("complete", isComplete);
        });
      };

      const lessonRoots = [
        ...document.querySelectorAll<HTMLElement>("[data-lesson-progress]"),
      ];

      const syncLessonRoot = (progressRoot: HTMLElement, announcement?: string) => {
        const slug = progressRoot.dataset.lessonSlug;
        if (!slug) return;

        const revision = lessonRevision(progressRoot);
        const state = getLessonStudyState(lessonProgress, slug, revision);
        const completeButton = progressRoot.querySelector<HTMLButtonElement>("[data-lesson-complete]");
        const resetButton = progressRoot.querySelector<HTMLButtonElement>("[data-lesson-reset]");
        const completionStatus = progressRoot.querySelector<HTMLElement>(
          "[data-lesson-completion-status]",
        );
        const stepCount = progressRoot.querySelector<HTMLElement>("[data-lesson-step-count]");

        progressRoot.querySelectorAll<HTMLInputElement>("[data-study-step]").forEach((checkbox) => {
          const stepId = checkbox.dataset.studyStep as StudyStepId | undefined;
          if (stepId) checkbox.checked = state.steps[stepId];
        });

        if (stepCount) {
          stepCount.textContent = state.isCompleted
            ? `${state.checkedCount} of ${state.totalCount} · complete`
            : `${state.checkedCount} of ${state.totalCount} steps`;
        }

        if (completeButton) {
          completeButton.disabled = !state.isReady;
          completeButton.classList.toggle("is-complete", state.isCompleted);
          completeButton.textContent = state.isCompleted
            ? "Mark study loop incomplete"
            : "Complete study loop";
        }

        if (resetButton) resetButton.hidden = state.checkedCount === 0;

        if (completionStatus) {
          completionStatus.textContent = announcement ?? (
            state.isCompleted
              ? "Study loop complete. Return to your guided path to continue."
              : state.isReady
                ? "All four steps are checked. Complete the study loop when you are ready."
                : state.checkedCount
                  ? `${state.totalCount - state.checkedCount} step${state.totalCount - state.checkedCount === 1 ? "" : "s"} left. Progress is saved on this device.`
                  : "Complete the four steps to finish this study loop. Progress is saved on this device."
          );
        }
      };

      const syncAllLessonProgress = () => {
        lessonRoots.forEach((root) => syncLessonRoot(root));
        syncLessonCards();
      };

      lessonRoots.forEach((progressRoot) => {
        const slug = progressRoot.dataset.lessonSlug;
        if (!slug) return;
        const revision = lessonRevision(progressRoot);

        progressRoot.querySelectorAll<HTMLInputElement>("[data-study-step]").forEach((checkbox) => {
          checkbox.addEventListener("change", () => {
            const stepId = checkbox.dataset.studyStep as StudyStepId | undefined;
            if (!stepId) return;
            lessonProgress = setLessonStudyStep(
              lessonProgress,
              slug,
              stepId,
              checkbox.checked,
              { revision },
            );
            const saved = writeLessonProgress();
            syncLessonRoot(
              progressRoot,
              saved ? undefined : "This browser did not allow your study checks to be saved.",
            );
            syncLessonCards();
          });
        });

        progressRoot.querySelector<HTMLButtonElement>("[data-lesson-complete]")
          ?.addEventListener("click", () => {
            const state = getLessonStudyState(lessonProgress, slug, revision);
            lessonProgress = state.isCompleted
              ? uncompleteLessonStudy(lessonProgress, slug, { revision })
              : completeLessonStudy(lessonProgress, slug, { revision });
            const saved = writeLessonProgress();
            syncLessonRoot(
              progressRoot,
              saved
                ? state.isCompleted
                  ? "Study loop marked incomplete. Your four checks are still saved."
                  : "Study loop complete. Return to your guided path to continue."
                : "This browser did not allow your study checks to be saved.",
            );
            syncLessonCards();
          });

        progressRoot.querySelector<HTMLButtonElement>("[data-lesson-reset]")
          ?.addEventListener("click", () => {
            lessonProgress = resetLessonStudy(lessonProgress, slug);
            const saved = writeLessonProgress();
            syncLessonRoot(
              progressRoot,
              saved
                ? "Study checks cleared. Start again when you are ready."
                : "This browser did not allow your study checks to be saved.",
            );
            syncLessonCards();
            progressRoot.querySelector<HTMLInputElement>("[data-study-step]")?.focus();
          });
      });

      window.addEventListener("storage", (event) => {
        if (event.key !== LESSON_PROGRESS_KEY) return;
        lessonProgress = readLessonProgress();
        syncAllLessonProgress();
      });
      window.addEventListener("english-library:lesson-progress", () => {
        lessonProgress = readLessonProgress();
        syncAllLessonProgress();
      });
      window.addEventListener("pageshow", () => {
        lessonProgress = readLessonProgress();
        syncAllLessonProgress();
      });

      syncAllLessonProgress();
    </script>
  </body>
</html>
