---
import SpeakingMissionCard from "../../components/SpeakingMissionCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getA2Entries, getSpeakingMissionEntries } from "../../lib/content";
import { getContentSessionByHref } from "../../lib/course-path";
import { SPEAKING_PROGRESS_KEY, MISSION_TYPE_LABELS } from "../../lib/speaking";

const entries = await getSpeakingMissionEntries();
const sourceUnits = await getA2Entries();
const durations = [...new Set(entries.map((entry) => entry.data.durationMinutes))].sort(
  (left, right) => left - right,
);
const topics = [...new Set(entries.flatMap((entry) => entry.data.topics))].sort((left, right) =>
  left.localeCompare(right),
);
const availableMissionTypes = [
  ...new Set(entries.map((entry) => entry.data.missionType)),
];
const sourceTitleMap = new Map(sourceUnits.map((entry) => [entry.data.slug, entry.data.title]));
---

<BaseLayout
  title="Speaking Lab | English Library"
  description="Short, mobile-friendly A2 speaking missions for Lithuanian learners."
>
  <section class="collection-hero">
    <p class="eyebrow">Speaking-First Support Track</p>
    <h1>Speaking Lab</h1>
    <p class="hero-subtitle lt-text" lang="lt">Trumpa kalbėjimo praktika A2 mokiniams</p>
    <p class="collection-description">
      Use short rehearsal missions when you want to turn a grammar unit into real speech instead of
      another silent exercise. A2.1–A2.4 are internal stages within CEFR A2.
    </p>
  </section>

  <section class="speaking-summary-row">
    <article class="summary-chip">
      <span>Total missions</span>
      <strong>{entries.length}</strong>
    </article>
    <article class="summary-chip">
      <span>Completed locally</span>
      <strong data-speaking-completed aria-live="polite">0</strong>
    </article>
    <article class="summary-chip">
      <span>Average confidence</span>
      <strong data-speaking-confidence aria-live="polite">Not rated</strong>
    </article>
    <article class="summary-chip">
      <span>Visible now</span>
      <strong data-speaking-visible aria-live="polite">{entries.length}</strong>
    </article>
  </section>

  <section class="speaking-filter-shell" data-speaking-root>
    <div class="speaking-filter-bar">
      <fieldset class="filter-group">
        <legend>Mission type</legend>
        <div class="chip-row">
          {availableMissionTypes.map((missionType) => (
            <button
              type="button"
              class="chip"
              data-speaking-filter-button
              data-filter-group="missionType"
              data-filter-value={missionType}
              aria-pressed="false"
            >
              {MISSION_TYPE_LABELS[missionType]}
            </button>
          ))}
        </div>
      </fieldset>

      <fieldset class="filter-group">
        <legend>Duration</legend>
        <div class="chip-row">
          {durations.map((minutes) => (
            <button
              type="button"
              class="chip"
              data-speaking-filter-button
              data-filter-group="duration"
              data-filter-value={String(minutes)}
              aria-pressed="false"
            >
              {minutes} min
            </button>
          ))}
        </div>
      </fieldset>

      <fieldset class="filter-group">
        <legend>Topics</legend>
        <div class="chip-row">
          {topics.map((topic) => (
            <button
              type="button"
              class="chip"
              data-speaking-filter-button
              data-filter-group="topic"
              data-filter-value={topic}
              aria-pressed="false"
            >
              {topic}
            </button>
          ))}
        </div>
      </fieldset>

      <div class="filter-results-bar">
        <p role="status" aria-live="polite">Use one or more filters to find a focused rehearsal.</p>
        <button type="button" class="text-button" data-speaking-filter-clear hidden>Clear filters</button>
      </div>
    </div>

    <div class="speaking-grid">
      {entries.map((entry) => (
        <SpeakingMissionCard
          entry={entry}
          missionRevision={getContentSessionByHref(`/speaking/${entry.data.slug}`)?.revision ?? 1}
          sourceTitle={sourceTitleMap.get(entry.data.sourceRefs[0]) ?? "A2 unit"}
        />
      ))}
    </div>

    <p class="empty-state" data-speaking-empty role="status" hidden>
      No speaking missions match these filters. Try clearing one or more choices.
    </p>
  </section>

  <script is:inline define:vars={{ progressKey: SPEAKING_PROGRESS_KEY }}>
    const readSpeakingProgress = () => {
      try {
        const raw = localStorage.getItem(progressKey);

        if (!raw) {
          return {};
        }

        const parsed = JSON.parse(raw);
        return parsed && typeof parsed === "object" && !Array.isArray(parsed) ? parsed : {};
      } catch {
        return {};
      }
    };

    const averageConfidence = (records) => {
      if (!records.length) {
        return "Not rated";
      }

      const total = records.reduce((sum, value) => sum + value, 0);
      return `${(total / records.length).toFixed(1)}/5`;
    };

    document.querySelectorAll("[data-speaking-root]").forEach((root) => {
      const cards = [...root.querySelectorAll("[data-speaking-card]")];
      const buttons = [...root.querySelectorAll("[data-speaking-filter-button]")];
      const completedValue = document.querySelector("[data-speaking-completed]");
      const confidenceValue = document.querySelector("[data-speaking-confidence]");
      const visibleValue = document.querySelector("[data-speaking-visible]");
      const clearButton = root.querySelector("[data-speaking-filter-clear]");
      const emptyState = root.querySelector("[data-speaking-empty]");
      const active = {
        missionType: new Set(),
        duration: new Set(),
        topic: new Set(),
      };

      const syncProgress = () => {
        const progress = readSpeakingProgress();
        let completedCount = 0;
        const confidenceScores = [];

        cards.forEach((card) => {
          const slug = card.dataset.missionSlug;
          const revision = Number(card.dataset.missionRevision || 1);
          const label = card.querySelector("[data-progress-label]");
          const storedValue = slug ? progress[slug] : undefined;
          const storedRecord = storedValue && typeof storedValue === "object" && !Array.isArray(storedValue)
            ? storedValue
            : undefined;
          const storedRevision = Number(storedRecord?.revision ?? 1);
          const record = storedRevision === revision ? storedRecord : undefined;

          if (record?.completed === true) {
            completedCount += 1;
          }

          const confidence = Number(record?.lastConfidence);
          const hasValidConfidence = Number.isInteger(confidence) && confidence >= 1 && confidence <= 5;

          if (hasValidConfidence) {
            confidenceScores.push(confidence);
          }

          if (label) {
            label.textContent = record?.completed === true
              ? hasValidConfidence
                ? `Done • ${confidence}/5`
                : "Completed"
              : record?.startedAt
                ? "In progress"
                : "Not started";
          }
        });

        if (completedValue) {
          completedValue.textContent = String(completedCount);
        }

        if (confidenceValue) {
          confidenceValue.textContent = averageConfidence(confidenceScores);
        }
      };

      const applyFilters = () => {
        let visibleCount = 0;

        cards.forEach((card) => {
          const missionType = card.dataset.missionType || "";
          const duration = card.dataset.duration || "";
          const topics = (card.dataset.topics || "").split("|").filter(Boolean);

          const missionTypeMatch =
            !active.missionType.size || active.missionType.has(missionType);
          const durationMatch = !active.duration.size || active.duration.has(duration);
          const topicMatch = !active.topic.size || topics.some((topic) => active.topic.has(topic));
          const isVisible = missionTypeMatch && durationMatch && topicMatch;

          card.hidden = !isVisible;

          if (isVisible) {
            visibleCount += 1;
          }
        });

        if (visibleValue) {
          visibleValue.textContent = String(visibleCount);
        }

        const activeCount = Object.values(active).reduce((count, values) => count + values.size, 0);

        if (clearButton) {
          clearButton.hidden = activeCount === 0;
        }

        if (emptyState) {
          emptyState.hidden = visibleCount !== 0;
        }
      };

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const group = button.dataset.filterGroup;
          const value = button.dataset.filterValue;

          if (!group || !value || !(group in active)) {
            return;
          }

          if (active[group].has(value)) {
            active[group].delete(value);
            button.classList.remove("selected");
            button.setAttribute("aria-pressed", "false");
          } else {
            active[group].add(value);
            button.classList.add("selected");
            button.setAttribute("aria-pressed", "true");
          }

          applyFilters();
        });
      });

      clearButton?.addEventListener("click", () => {
        Object.values(active).forEach((values) => values.clear());
        buttons.forEach((button) => {
          button.classList.remove("selected");
          button.setAttribute("aria-pressed", "false");
        });
        applyFilters();
      });

      window.addEventListener("storage", (event) => {
        if (event.key === progressKey || event.key === null) syncProgress();
      });
      window.addEventListener("pageshow", syncProgress);
      window.addEventListener("focus", syncProgress);
      window.addEventListener("english-library:speaking-progress", syncProgress);
      document.addEventListener("visibilitychange", () => {
        if (document.visibilityState === "visible") syncProgress();
      });

      syncProgress();
      applyFilters();
    });
  </script>
</BaseLayout>
