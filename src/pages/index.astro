---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getA2Entries, getGreyBookEntries, getResourceEntries } from "../lib/content";
import { withBase } from "../lib/constants";

const [greyBookEntries, a2Entries, resources] = await Promise.all([
  getGreyBookEntries(),
  getA2Entries(),
  getResourceEntries(),
]);
---

<BaseLayout title="English Library" description="GitHub-deployable bilingual English learning library.">
  <section class="landing-hero">
    <div class="hero-copy">
      <p class="eyebrow">Flagship reading track</p>
      <h1>Learn English through Grey's Book first.</h1>
      <p class="hero-intro">
        Grey's Book is now the main way into the library: a guided hospital drama with bilingual support,
        chapter-by-chapter practice, and controlled answer reveals for Lithuanian learners.
      </p>
      <p class="hero-subtitle lt-text">
        Pirmiausia skaitykite Grey's Book, tada naudokite A2 kursą ir gramatiką kaip pagalbinius įrankius.
      </p>
      <p class="hero-promise">
        Read real English with Lithuanian support, one chapter at a time.
      </p>
      <div class="hero-actions">
        <a class="primary-button" href={withBase("/grey-book/chapter-01")}>Read Chapter 1</a>
        <a class="secondary-button" href={withBase("/a2")}>Practice Grammar in A2</a>
      </div>
    </div>

    <div class="hero-panel">
      <dl>
        <div>
          <dt>Start here</dt>
          <dd>Grey's Book</dd>
        </div>
        <div>
          <dt>Story track</dt>
          <dd>{greyBookEntries.length} hospital chapters</dd>
        </div>
        <div>
          <dt>Practice support</dt>
          <dd>{a2Entries.length} A2 units + {resources.length} reference guides</dd>
        </div>
        <div>
          <dt>Reading flow</dt>
          <dd>Read the story, translate difficult words, then check answers only after trying</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="resume-strip" aria-label="Resume reading">
    <article class="feature-card resume-card" data-resume-card>
      <p class="eyebrow">Resume reading</p>
      <h2 data-resume-title>Start Chapter 1</h2>
      <p class="lt-text" data-resume-track>Grey's Book</p>
      <p data-resume-copy>
        Continue from the last chapter you opened, or start Chapter 1 if this is your first visit.
      </p>
      <div class="hero-actions">
        <a class="primary-button" data-resume-link href={withBase("/grey-book/chapter-01")}>Start Chapter 1</a>
        <a class="secondary-button" href={withBase("/grey-book")}>Open Grey's Book</a>
      </div>
    </article>
  </section>

  <section class="path-strip" aria-label="Recommended study path">
    <article class="path-step">
      <p class="eyebrow">Step 1</p>
      <h2>Read the chapter</h2>
      <p>Follow the story in order and stay inside the chapter flow instead of jumping across files.</p>
    </article>
    <article class="path-step">
      <p class="eyebrow">Step 2</p>
      <h2>Translate difficult words</h2>
      <p>Select an English word or phrase when you need Lithuanian support, then keep reading without leaving the chapter.</p>
    </article>
    <article class="path-step">
      <p class="eyebrow">Step 3</p>
      <h2>Practice after reading</h2>
      <p>Use the A2 course, grammar guides, and answer keys after the chapter has already given you the story context.</p>
    </article>
  </section>

  <section class="feature-grid">
    <a class="feature-card flagship-card" href={withBase("/grey-book")}>
      <p class="eyebrow">Start reading</p>
      <h2>Grey's Book</h2>
      <p class="lt-text">Medicininė drama su A2 lygio anglų kalba</p>
      <p>Story-led chapters with bilingual support, guided questions, activity blocks, and linked answer previews.</p>
      <p class="card-excerpt">Open the story first, read in order, and use long-press translation only when you need help.</p>
    </a>

    <a class="feature-card" href={withBase("/a2")}>
      <p class="eyebrow">Practice after reading</p>
      <h2>A2 Course</h2>
      <p class="lt-text">Pilnas A2 kursas lietuviškai kalbantiems</p>
      <p>Review grammar, reinforce vocabulary, and practise speaking after each reading session.</p>
    </a>

    <a class="feature-card" href={withBase("/resources/grammar-reference")}>
      <p class="eyebrow">Look up what you need</p>
      <h2>Grammar + Vocabulary</h2>
      <p class="lt-text">Gramatikos ir žodyno šaltiniai</p>
      <p>Look up a rule, check a word list, and go straight back to the chapter or unit you were studying.</p>
    </a>

    <a class="feature-card" href={withBase("/answers/a2")}>
      <p class="eyebrow">Check answers last</p>
      <h2>Answer Keys</h2>
      <p class="lt-text">Atsakymai su peržiūros valdikliais</p>
      <p>Check answers only after you try the work yourself, with sections kept collapsed until you open them.</p>
    </a>
  </section>

  <script is:inline>
    const resumeCard = document.querySelector("[data-resume-card]");
    const resumeTitle = document.querySelector("[data-resume-title]");
    const resumeTrack = document.querySelector("[data-resume-track]");
    const resumeCopy = document.querySelector("[data-resume-copy]");
    const resumeLink = document.querySelector("[data-resume-link]");
    const resumeData = JSON.parse(localStorage.getItem("english-library.resume") || "null");

    if (resumeCard && resumeData && resumeLink && resumeTitle && resumeTrack && resumeCopy) {
      const lessonTitle = resumeData.title || "your last lesson";
      resumeTitle.textContent = `Resume ${lessonTitle}`;
      resumeTrack.textContent = resumeData.track || "Recent lesson";
      resumeCopy.textContent = `You last read ${lessonTitle}. Pick up where you left off or start Chapter 1 again.`;
      resumeLink.textContent = `Resume ${lessonTitle}`;
      resumeLink.href = resumeData.href || resumeLink.href;
    }
  </script>
</BaseLayout>
