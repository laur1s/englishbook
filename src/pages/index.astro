---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getA2Entries, getGreyBookEntries, getResourceEntries } from "../lib/content";
import { withBase } from "../lib/constants";

const [greyBookEntries, a2Entries, resources] = await Promise.all([
  getGreyBookEntries(),
  getA2Entries(),
  getResourceEntries(),
]);
---

<BaseLayout title="English Library" description="GitHub-deployable bilingual English learning library.">
  <section class="landing-hero">
    <div class="hero-copy">
      <p class="eyebrow">Markdown-first publishing</p>
      <h1>Read the course like a library, not a folder dump.</h1>
      <p class="hero-intro">
        This site publishes the A2 course, Grey's Book chapters, grammar references, and answer keys
        directly from the repository source files.
      </p>
      <div class="hero-actions">
        <a class="primary-button" href={withBase("/grey-book")}>Open Grey's Book</a>
        <a class="secondary-button" href={withBase("/a2")}>Browse A2 Course</a>
      </div>
    </div>

    <div class="hero-panel">
      <dl>
        <div>
          <dt>Grey's Book</dt>
          <dd>{greyBookEntries.length} chapters</dd>
        </div>
        <div>
          <dt>A2 Course</dt>
          <dd>{a2Entries.length} units</dd>
        </div>
        <div>
          <dt>Resources</dt>
          <dd>{resources.length} reference guides</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="feature-grid">
    <a class="feature-card" href={withBase("/grey-book")}>
      <p class="eyebrow">Track 1</p>
      <h2>Grey's Book</h2>
      <p class="lt-text">Medicininė drama su A2 lygio anglų kalba</p>
      <p>Story-led chapters with word banks, questions, activities, and linked answers.</p>
    </a>

    <a class="feature-card" href={withBase("/a2")}>
      <p class="eyebrow">Track 2</p>
      <h2>A2 Course</h2>
      <p class="lt-text">Pilnas A2 kursas lietuviškai kalbantiems</p>
      <p>Structured grammar units, vocabulary practice, translation work, and speaking tasks.</p>
    </a>

    <a class="feature-card" href={withBase("/resources/grammar-reference")}>
      <p class="eyebrow">Reference</p>
      <h2>Grammar + Vocabulary</h2>
      <p class="lt-text">Gramatikos ir žodyno šaltiniai</p>
      <p>Long-form lookup pages for revision and self-study outside the unit sequence.</p>
    </a>

    <a class="feature-card" href={withBase("/answers/a2")}>
      <p class="eyebrow">Support</p>
      <h2>Answer Keys</h2>
      <p class="lt-text">Atsakymai su peržiūros valdikliais</p>
      <p>Collapsed by default, linked from lessons, and easier to navigate than raw Markdown.</p>
    </a>
  </section>
</BaseLayout>
