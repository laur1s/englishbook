---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getA2Entries, getGreyBookEntries, getResourceEntries } from "../lib/content";
import { withBase } from "../lib/constants";

const [greyBookEntries, a2Entries, resources] = await Promise.all([
  getGreyBookEntries(),
  getA2Entries(),
  getResourceEntries(),
]);
---

<BaseLayout title="English Library" description="GitHub-deployable bilingual English learning library.">
  <section class="landing-hero">
    <div class="hero-copy">
      <p class="eyebrow">Flagship reading track</p>
      <p class="hero-brand">English Library</p>
      <h1>Grey&apos;s Book should feel like a series, not a file dump.</h1>
      <p class="hero-intro">
        Read a hospital story first, keep Lithuanian help close, and move into grammar only after the chapter has
        given you context.
      </p>
      <p class="hero-subtitle lt-text">
        Pagrindinis kelias: istorija, žodžių pagalba, tik tada pratimai ir atsakymai.
      </p>
      <div class="hero-actions">
        <a class="primary-button" href={withBase("/grey-book/chapter-01")}>Start the story</a>
        <a class="secondary-button" href={withBase("/grey-book")}>Browse all chapters</a>
      </div>
      <div class="hero-stat-row" aria-label="Library overview">
        <div>
          <span>Story</span>
          <strong>{greyBookEntries.length} chapters</strong>
        </div>
        <div>
          <span>Practice</span>
          <strong>{a2Entries.length} A2 units</strong>
        </div>
        <div>
          <span>Support</span>
          <strong>{resources.length} guides</strong>
        </div>
      </div>
    </div>

    <div class="hero-poster" aria-label="Grey's Book preview">
      <div class="hero-poster-copy">
        <p class="poster-kicker">Read like a series</p>
        <h2>One chapter. One emotional arc. One clear next step.</h2>
        <p>
          Long-press difficult English, keep Lithuanian notes nearby, and reveal answers only when you are ready.
        </p>
      </div>

      <div class="chapter-glimpse" aria-hidden="true">
        <span>Emergency room</span>
        <span>Secret romance</span>
        <span>Storm shift</span>
        <span>Medical mission</span>
      </div>

      <dl class="hero-panel">
        <div>
          <dt>Start here</dt>
          <dd>Grey&apos;s Book</dd>
        </div>
        <div>
          <dt>Best on mobile</dt>
          <dd>Read, hold to translate, then continue</dd>
        </div>
        <div>
          <dt>Study order</dt>
          <dd>Story first, practice second, answer key last</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="resume-strip" aria-label="Resume reading">
    <article class="resume-card" data-resume-card>
      <div>
        <p class="eyebrow">Resume reading</p>
        <h2 data-resume-title>Start Chapter 1</h2>
        <p class="lt-text" data-resume-track>Grey's Book</p>
      </div>
      <p data-resume-copy>
        Continue from the last chapter you opened, or start Chapter 1 if this is your first visit.
      </p>
      <div class="hero-actions">
        <a class="primary-button" data-resume-link href={withBase("/grey-book/chapter-01")}>Start Chapter 1</a>
        <a class="secondary-button" href={withBase("/grey-book")}>Open Grey's Book</a>
      </div>
    </article>
  </section>

  <section class="path-strip" aria-label="Recommended study path">
    <article class="path-step">
      <p class="eyebrow">Step 1</p>
      <h2>Read the scene</h2>
      <p>Stay with one chapter until you understand the emotional turn, not just the words.</p>
    </article>
    <article class="path-step">
      <p class="eyebrow">Step 2</p>
      <h2>Hold to translate</h2>
      <p>Use Lithuanian support only when you need it, without breaking the reading rhythm.</p>
    </article>
    <article class="path-step">
      <p class="eyebrow">Step 3</p>
      <h2>Practice after</h2>
      <p>Move into grammar, vocabulary, and answer checks after the story has done its job.</p>
    </article>
  </section>

  <section class="feature-grid">
    <a class="feature-card flagship-card" href={withBase("/grey-book")}>
      <p class="eyebrow">Primary track</p>
      <h2>Grey's Book</h2>
      <p class="lt-text">Medicininė drama su A2 lygio anglų kalba</p>
      <p>Ten chapters designed to be read in order, with translation help and controlled answer reveals built into the flow.</p>
      <p class="card-excerpt">Best place to begin if you want a stronger reading habit on mobile.</p>
    </a>

    <a class="feature-card" href={withBase("/a2")}>
      <p class="eyebrow">Support track</p>
      <h2>A2 Course</h2>
      <p class="lt-text">Pilnas A2 kursas lietuviškai kalbantiems</p>
      <p>Use the A2 units when a chapter shows you where you are weak and you want focused reinforcement.</p>
    </a>

    <a class="feature-card" href={withBase("/resources/grammar-reference")}>
      <p class="eyebrow">Reference shelf</p>
      <h2>Grammar + Vocabulary</h2>
      <p class="lt-text">Gramatikos ir žodyno šaltiniai</p>
      <p>Look up one rule, check one word list, and go straight back to the lesson without getting lost.</p>
    </a>

    <a class="feature-card" href={withBase("/answers/a2")}>
      <p class="eyebrow">Review only</p>
      <h2>Answer Keys</h2>
      <p class="lt-text">Atsakymai su peržiūros valdikliais</p>
      <p>Answers stay useful when they come last, so the site keeps them collapsed until you decide to open them.</p>
    </a>
  </section>

  <script is:inline>
    const resumeCard = document.querySelector("[data-resume-card]");
    const resumeTitle = document.querySelector("[data-resume-title]");
    const resumeTrack = document.querySelector("[data-resume-track]");
    const resumeCopy = document.querySelector("[data-resume-copy]");
    const resumeLink = document.querySelector("[data-resume-link]");
    const resumeData = JSON.parse(localStorage.getItem("english-library.resume") || "null");

    if (resumeCard && resumeData && resumeLink && resumeTitle && resumeTrack && resumeCopy) {
      const lessonTitle = resumeData.title || "your last lesson";
      resumeTitle.textContent = `Resume ${lessonTitle}`;
      resumeTrack.textContent = resumeData.track || "Recent lesson";
      resumeCopy.textContent = `You last read ${lessonTitle}. Pick up where you left off or start Chapter 1 again.`;
      resumeLink.textContent = `Resume ${lessonTitle}`;
      resumeLink.href = resumeData.href || resumeLink.href;
    }
  </script>
</BaseLayout>
