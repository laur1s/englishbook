---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSpeakingMissionEntries } from "../lib/content";
import { withBase } from "../lib/constants";

const speakingEntries = await getSpeakingMissionEntries();
---

<BaseLayout title="English Library" description="A story-led A2 English course with Lithuanian support, speaking practice, and answer keys.">
  <section class="landing-hero">
    <div class="hero-copy">
      <p class="eyebrow">Continuous A2 learning</p>
      <p class="hero-brand">English Library</p>
      <h1>One clear English lesson at a time.</h1>
      <p class="hero-intro">
        Follow a 120-session path through context, grammar, interactive practice, speaking, and spaced review. Your
        next useful step is always ready.
      </p>
      <p class="hero-subtitle lt-text" lang="lt">
        Aiškus 120 užsiėmimų kelias: kontekstas, gramatika, praktika, kalbėjimas ir kartojimas.
      </p>
      <div class="hero-actions">
        <a class="primary-button" href={withBase("/learn")}>Start your learning path</a>
        <a class="secondary-button" href={withBase("/grey-book")}>Read Grey&apos;s Book</a>
      </div>
      <div class="hero-stat-row" aria-label="Library overview">
        <div>
          <span>Path</span>
          <strong>24 modules</strong>
        </div>
        <div>
          <span>Sessions</span>
          <strong>120 clear steps</strong>
        </div>
        <div>
          <span>Practice</span>
          <strong>Fresh repeat sets</strong>
        </div>
      </div>
    </div>

    <div class="hero-poster" aria-label="Continuous learning path preview">
      <div class="hero-poster-copy">
        <p class="poster-kicker">Learn like a course</p>
        <h2>Learn. Practice. Speak. Review. Then keep going.</h2>
        <p>
          Short sessions save your place, explain every answer, and bring important skills back when review is due.
        </p>
      </div>

      <div class="chapter-glimpse" aria-hidden="true">
        <span>Context</span>
        <span>Practice</span>
        <span>Speaking</span>
        <span>Recall</span>
      </div>

      <dl class="hero-panel">
        <div>
          <dt>Start here</dt>
          <dd>Your English path</dd>
        </div>
        <div>
          <dt>Built for real progress</dt>
          <dd>One focused session, with feedback</dd>
        </div>
        <div>
          <dt>Study order</dt>
          <dd>Context, learn, practice, speak, review</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="resume-strip" aria-label="Continue learning">
    <article class="resume-card">
      <div>
        <p class="eyebrow">Your next step</p>
        <h2>Continue your English path</h2>
        <p class="resume-track">Progress saves on this device</p>
      </div>
      <p>
        Return to the exact session you reached, or begin with Module 1 if this is your first visit.
      </p>
      <div class="hero-actions">
        <a class="primary-button" href={withBase("/learn")}>Open learning path</a>
        <a class="secondary-button" href={withBase("/a2")}>Browse A2 lessons</a>
      </div>
    </article>
  </section>

  <section class="path-strip" aria-label="Recommended study path">
    <article class="path-step">
      <p class="eyebrow">Step 1</p>
      <h2>Follow the next session</h2>
      <p>The course chooses one useful step from your 24-module path, so you never need to plan the order.</p>
    </article>
    <article class="path-step">
      <p class="eyebrow">Step 2</p>
      <h2>Answer and correct</h2>
      <p>Interactive practice checks each response and explains the answer in English and Lithuanian.</p>
    </article>
    <article class="path-step">
      <p class="eyebrow">Step 3</p>
      <h2>Return when it matters</h2>
      <p>Skills come back through review sessions, and a new practice set is always available.</p>
    </article>
  </section>

  <section class="feature-grid">
    <a class="feature-card flagship-card" href={withBase("/learn")}>
      <p class="eyebrow">Primary track</p>
      <h2>Your English Path</h2>
      <p class="lt-text" lang="lt">Nuoseklus A2 mokymosi kelias</p>
      <p>Move through 120 short sessions with interactive answers, speaking, review scheduling, and a clear next step.</p>
      <p class="card-excerpt">Best place to begin when you want steady progress without planning the course yourself.</p>
    </a>

    <a class="feature-card" href={withBase("/grey-book")}>
      <p class="eyebrow">Story track</p>
      <h2>Grey's Book</h2>
      <p class="lt-text" lang="lt">Medicininė drama su A2 lygio anglų kalba</p>
      <p>Twelve chapters designed to be read in order, with translation help and controlled answer reveals built into the flow.</p>
    </a>

    <a class="feature-card" href={withBase("/a2")}>
      <p class="eyebrow">Deep-study track</p>
      <h2>A2 Course</h2>
      <p class="lt-text" lang="lt">Pilnas A2 kursas lietuviškai kalbantiems</p>
      <p>Open the complete A2 units whenever you want more explanation, examples, reading, and writing practice.</p>
    </a>

    <a class="feature-card" href={withBase("/speaking")}>
      <p class="eyebrow">Rehearsal track</p>
      <h2>Speaking Lab</h2>
      <p class="lt-text" lang="lt">Trumpa kalbėjimo praktika pagal A2 temas</p>
      <p>Use {speakingEntries.length} short missions when you want to turn grammar and vocabulary into spoken English.</p>
    </a>

    <a class="feature-card" href={withBase("/resources/a2-practice-workbook")}>
      <p class="eyebrow">Practice shelf</p>
      <h2>44 A2 Practice Sets</h2>
      <p class="lt-text" lang="lt">44 A2 praktikos rinkiniai + lietuviška klaidų klinika</p>
      <p>Practise every skill with complete answers, Lithuanian explanations, mistake codes, and step-by-step repair guidance.</p>
    </a>

    <a class="feature-card" href={withBase("/answers/a2")}>
      <p class="eyebrow">Review only</p>
      <h2>Answer Keys</h2>
      <p class="lt-text" lang="lt">Atsakymai su peržiūros valdikliais</p>
      <p>Answers stay useful when they come last, so the site keeps them collapsed until you decide to open them.</p>
    </a>
  </section>

</BaseLayout>
