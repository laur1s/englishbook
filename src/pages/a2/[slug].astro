---
import ReaderLayout from "../../layouts/ReaderLayout.astro";
import {
  getA2Entries,
  getAnswerKeyEntries,
  getEntryBody,
  getPrevNextEntries,
  getSpeakingMissionEntries,
} from "../../lib/content";
import { extractA2AnswerSnippet } from "../../lib/answers";
import { parseDocument, renderMarkdown } from "../../lib/markdown";
import { withBase } from "../../lib/constants";
import { findSpeakingMissionForSource, formatDurationMinutes } from "../../lib/speaking";

export async function getStaticPaths() {
  const entries = await getA2Entries();

  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry, entries },
  }));
}

const { entry, entries } = Astro.props;
const parsed = parseDocument({
  markdown: getEntryBody(entry),
  title: entry.data.title,
  ltTitle: entry.data.ltTitle,
});
const { previous, next } = getPrevNextEntries(entries, entry.data.slug);
const answerEntry = (await getAnswerKeyEntries()).find((item) => item.data.slug === "a2");
const answerSnippet = answerEntry ? extractA2AnswerSnippet(answerEntry, entry) : "";
const relatedMission = findSpeakingMissionForSource(
  await getSpeakingMissionEntries(),
  entry.data.slug,
);
---

<ReaderLayout
  entry={entry}
  description={parsed.excerpt}
  introHtml={parsed.introHtml}
  sections={parsed.sections}
  previous={previous}
  next={next}
  answerHref={`${withBase("/answers/a2")}#${entry.data.slug}`}
  answerSnippetHtml={answerSnippet ? renderMarkdown(answerSnippet) : ""}
  practiceCallout={
    relatedMission
      ? {
          href: withBase(`/speaking/${relatedMission.data.slug}`),
          title: "Practice it aloud",
          ltTitle: relatedMission.data.ltTitle,
          description: `${relatedMission.data.title} gives you a ${formatDurationMinutes(
            relatedMission.data.durationMinutes,
          )} speaking run based on this unit.`,
          buttonLabel: "Open speaking mission",
        }
      : undefined
  }
/>
