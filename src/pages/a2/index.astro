---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CollectionFilters from "../../components/CollectionFilters.astro";
import { getA2Entries } from "../../lib/content";

const entries = await getA2Entries();
---

<BaseLayout title="A2 Course | English Library">
  <CollectionFilters
    title="A2 Course"
    ltTitle="A2 kursas"
    description="The full Lithuanian-supported A2 sequence with grammar, vocabulary, reading, writing, and speaking practice. A2.1–A2.4 are internal course stages within CEFR A2, not separate official levels."
    entries={entries}
  />
</BaseLayout>
