---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getA2Entries, getAnswerKeyEntries } from "../../lib/content";
import { extractA2AnswerSnippet } from "../../lib/answers";
import { renderMarkdown } from "../../lib/markdown";
import { withBase } from "../../lib/constants";

const [units, answerEntries] = await Promise.all([getA2Entries(), getAnswerKeyEntries()]);
const answerEntry = answerEntries.find((entry) => entry.data.slug === "a2");
---

<BaseLayout title="A2 Answer Keys | English Library">
  <section class="collection-hero">
    <p class="eyebrow">Answer key</p>
    <h1>A2 Answer Keys</h1>
    <p class="hero-subtitle lt-text">A2 kurso atsakymų raktai</p>
    <p class="collection-description">
      Answers stay visible on the site, but they are folded by default so the learning flow does not collapse.
    </p>
  </section>

  <section class="answer-stack">
    {answerEntry &&
      units.map((unit) => {
        const snippet = extractA2AnswerSnippet(answerEntry, unit);
        return (
          <details
            class="content-panel collapsible"
            id={unit.data.slug}
            data-persist-key={`answers:${unit.data.slug}`}
          >
            <summary>
              {unit.data.title}
              <span class="lt-text summary-subtitle">{unit.data.ltTitle}</span>
            </summary>
            <div class="prose" set:html={renderMarkdown(snippet)} />
            <p class="answer-link-row">
              <a class="inline-link" href={withBase(`/a2/${unit.data.slug}`)}>
                Back to lesson
                <span class="lt-text">Grįžti į skyrių</span>
              </a>
            </p>
          </details>
        );
      })}
  </section>
</BaseLayout>
