---
import type { LibraryEntry } from "../lib/content";

import { uniqueListValues, uniqueValues } from "../lib/content";
import ContentCard from "./ContentCard.astro";

type Props = {
  title: string;
  ltTitle: string;
  description: string;
  entries: LibraryEntry[];
  itemLabel?: string;
};

const { title, ltTitle, description, entries, itemLabel = "lessons" } = Astro.props;

const levels = uniqueValues(entries, "level");
const grammarFocus = uniqueListValues(entries, "grammarFocus");
const topics = uniqueListValues(entries, "topics");
---

<section class="collection-hero">
  <p class="eyebrow">Library track</p>
  <h1>{title}</h1>
  <p class="hero-subtitle lt-text" lang="lt">{ltTitle}</p>
  <p class="collection-description">{description}</p>
</section>

<section class="filter-shell" data-filter-root data-filter-item-label={itemLabel}>
  <div class="filter-bar">
    <fieldset class="filter-group">
      <legend>Level</legend>
      <div class="chip-row">
        {levels.map((level) => (
          <button type="button" class="chip" data-filter-button data-filter-group="level" data-filter-value={level} aria-pressed="false">
            {level}
          </button>
        ))}
      </div>
    </fieldset>

    <fieldset class="filter-group">
      <legend>Grammar</legend>
      <div class="chip-row">
        {grammarFocus.map((item) => (
          <button type="button" class="chip" data-filter-button data-filter-group="grammar" data-filter-value={item} aria-pressed="false">
            {item}
          </button>
        ))}
      </div>
    </fieldset>

    <fieldset class="filter-group">
      <legend>Topics</legend>
      <div class="chip-row">
        {topics.map((item) => (
          <button type="button" class="chip" data-filter-button data-filter-group="topic" data-filter-value={item} aria-pressed="false">
            {item}
          </button>
        ))}
      </div>
    </fieldset>

    <div class="filter-results-bar">
      <p data-filter-status role="status" aria-live="polite">Showing {entries.length} of {entries.length} {itemLabel}</p>
      <button type="button" class="text-button" data-filter-clear hidden>Clear filters</button>
    </div>
  </div>

  <div class="library-grid">
    {entries.map((entry) => <ContentCard entry={entry} />)}
  </div>

  <p class="empty-state" data-filter-empty role="status" hidden>
    No items match these filters. Try clearing one or more choices.
  </p>
</section>
