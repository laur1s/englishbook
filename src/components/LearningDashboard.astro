---
import LearningCycle from "./LearningCycle.astro";
import { modules, sessions } from "../lib/course-path";
import { withBase } from "../lib/constants";
import { practiceCatalog } from "../lib/practice";

const firstModule = modules[0];
const firstSession = firstModule.sessions[0];
const sessionHref = (sessionId: string) => withBase(`/learn/${sessionId}`);
const serializeForScript = (value: unknown) => JSON.stringify(value).replace(/</g, "\\u003c");
const objectives = Object.fromEntries(
  practiceCatalog.units.flatMap((unit) => unit.objectives.map((objective) => [
    objective.id,
    {
      label: objective.label.en,
      unitId: unit.unitId,
      itemCount: unit.items.filter((item) => item.objectiveId === objective.id).length,
    },
  ])),
);
const items = Object.fromEntries(
  practiceCatalog.units.flatMap((unit) => unit.items.map((item) => [
    item.id,
    { objectiveId: item.objectiveId, unitId: unit.unitId },
  ])),
);
const dashboardData = serializeForScript({
  modules: modules.map((module) => ({
    id: module.id,
    order: module.order,
    title: module.title,
    summary: module.summary,
    unitSlug: module.unitSlug,
    missionSlug: module.missionSlug,
    sessions: module.sessions.map((session) => ({
      id: session.id,
      title: session.title,
      stage: session.stage,
      minutes: session.minutes,
      revision: session.revision,
      required: session.required,
      href: sessionHref(session.id),
    })),
  })),
  sessions: sessions.map((session) => ({
    id: session.id,
    revision: session.revision,
    required: session.required,
  })),
  objectives,
  items,
});

const chevronIcon = '<svg class="chevron" viewBox="0 0 24 24" aria-hidden="true"><path d="m9 5 7 7-7 7" /></svg>';
const clockIcon = '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8.5" /><path d="M12 7.5V12l3 2" /></svg>';
const lockIcon = '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="6.5" y="10" width="11" height="9" rx="1.5" /><path d="M9 10V7.5a3 3 0 0 1 6 0V10" /></svg>';
---

<section class="learning-shell" data-learning-dashboard>
  <header class="learning-page-heading">
    <h1>Your English path</h1>
    <p>One focused session at a time.</p>
  </header>

  <section class="momentum-rail" aria-labelledby="momentum-title">
    <h2 id="momentum-title">Momentum</h2>

    <div class="momentum-stat momentum-week-stat">
      <span class="momentum-stat-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24"><rect x="4" y="5.5" width="16" height="14" rx="1.5" /><path d="M8 3v5M16 3v5M4 10h16" /></svg>
      </span>
      <span class="momentum-stat-copy">
        <span>This week</span>
        <strong data-active-days>0 active days</strong>
      </span>
      <span class="momentum-week" data-momentum-week aria-label="Activity during the last seven days">
        {Array.from({ length: 7 }, (_, index) => (
          <span class="momentum-day" data-momentum-day={String(index)}>
            <i aria-hidden="true"></i>
            <small>–</small>
          </span>
        ))}
      </span>
    </div>

    <div class="momentum-stat">
      <span class="momentum-stat-icon momentum-chart-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8.5" /><path d="M12 3.5V12h8.5" /></svg>
      </span>
      <span class="momentum-stat-copy">
        <span>Course</span>
        <strong><span data-course-percent>0</span>%</strong>
      </span>
      <span class="momentum-progress" role="progressbar" aria-label="Course completion" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" data-course-progress>
        <span data-course-progress-fill></span>
      </span>
    </div>

    <div class="momentum-stat">
      <span class="momentum-stat-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24"><path d="M4 20v-4M8 20v-8M12 20V9M16 20V5M20 20V2" /></svg>
      </span>
      <span class="momentum-stat-copy">
        <span>Skills</span>
        <strong><span data-strong-skills>0</span> strong · <span data-developing-skills>0</span> developing</strong>
      </span>
    </div>

    <div class="momentum-stat momentum-goal-stat">
      <span class="momentum-stat-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8.5" /><path d="M12 7.5V12l3 2" /></svg>
      </span>
      <span class="momentum-stat-copy">
        <span>Daily goal</span>
        <strong data-goal-progress>0 / 10 min</strong>
      </span>
      <span class="goal-options" role="group" aria-label="Choose a daily learning goal">
        {[5, 10, 15].map((minutes) => (
          <button
            type="button"
            data-daily-minutes={String(minutes)}
            aria-pressed={minutes === 10 ? "true" : "false"}
          >
            {minutes}
          </button>
        ))}
      </span>
      <span class="momentum-progress" role="progressbar" aria-label="Today’s goal" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" data-goal-meter>
        <span data-goal-progress-fill></span>
      </span>
    </div>
  </section>

  <div class="learning-dashboard-grid">
    <section class="learning-panel next-session-panel" aria-labelledby="next-session-title">
      <div class="next-session-copy">
        <p class="learning-label" data-next-label>Next session</p>
        <p class="learning-module-name" data-next-module>
          Module {firstModule.order} · {firstModule.title}
        </p>
        <h2 id="next-session-title" data-next-title>{firstSession.title}</h2>
        <p class="learning-duration">
          <Fragment set:html={clockIcon} />
          <span data-next-minutes>{firstSession.minutes} min</span>
        </p>
        <p class="next-session-description" data-next-description>{firstModule.summary}</p>
        <a class="learning-primary-button" data-next-link href={sessionHref(firstSession.id)}>
          <span data-next-action>Start session</span>
          <Fragment set:html={chevronIcon} />
        </a>
      </div>

      <div class="learning-cycle-wrap">
        <LearningCycle sessions={firstModule.sessions} activeSessionId={firstSession.id} />
        <p class="learning-step-focus">
          <strong>Step focus</strong>
          <span data-step-focus>
            Meet the language in context, notice useful details, and get ready to learn.
          </span>
        </p>
      </div>
    </section>

    <section class="learning-panel learning-side-panel today-loop-panel" aria-labelledby="today-loop-title">
      <h2 id="today-loop-title">Today’s loop</h2>
      <ol class="today-plan-list">
        <li>
          <a class="today-plan-row is-disabled" data-today-review aria-disabled="true" tabindex="-1">
            <span class="today-plan-number">1</span>
            <span class="today-plan-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M20 8V4l-2 2a8 8 0 1 0 1.1 10.1M4 16v4l2-2" /></svg>
            </span>
            <span class="today-plan-copy">
              <strong><span data-today-review-title>Adaptive review</span> <em>·</em> <span data-today-review-minutes>—</span></strong>
              <span><em data-today-review-status>Caught up</em><span data-today-review-copy>No skills are due today</span></span>
            </span>
            <Fragment set:html={chevronIcon} />
          </a>
        </li>
        <li>
          <a class="today-plan-row" data-today-core href={sessionHref(firstSession.id)}>
            <span class="today-plan-number">2</span>
            <span class="today-plan-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M3.5 5.5c3.2-1.4 6-1 8.5 1.2v13c-2.5-2.2-5.3-2.6-8.5-1.2zM20.5 5.5c-3.2-1.4-6-1-8.5 1.2v13c2.5-2.2 5.3-2.6 8.5-1.2z" /></svg>
            </span>
            <span class="today-plan-copy">
              <strong>Next path step <em>·</em> <span data-today-core-minutes>{firstSession.minutes} min</span></strong>
              <span><em data-today-core-status>Ready</em><span data-today-core-copy>{firstSession.title}</span></span>
            </span>
            <Fragment set:html={chevronIcon} />
          </a>
        </li>
        <li>
          <a class="today-plan-row is-disabled" data-today-speak aria-disabled="true" tabindex="-1">
            <span class="today-plan-number">3</span>
            <span class="today-plan-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><rect x="8" y="3" width="8" height="12" rx="4" /><path d="M5 11a7 7 0 0 0 14 0M12 18v3M9 21h6" /></svg>
            </span>
            <span class="today-plan-copy">
              <strong>Speaking transfer <em>·</em> <span data-today-speak-minutes>—</span></strong>
              <span><em data-today-speak-status>Locked</em><span data-today-speak-copy>Complete the core step first</span></span>
            </span>
            <Fragment set:html={chevronIcon} />
          </a>
        </li>
      </ol>
    </section>

    <section class="learning-panel course-map-panel" aria-labelledby="course-map-title">
      <div class="course-map-heading">
        <div>
          <h2 id="course-map-title">Course map</h2>
          <p data-course-range>Modules 1–6 of {modules.length}</p>
        </div>
        <button
          class="learning-text-action course-map-toggle"
          type="button"
          data-course-map-toggle
          aria-expanded="false"
          aria-controls="course-map-list"
        >Show all {modules.length}</button>
      </div>
      <ol class="course-map" id="course-map-list">
        {modules.map((module, index) => (
          <li
            class:list={["course-module-row", index === 0 && "current"]}
            data-course-module={module.id}
            data-course-order={String(module.order)}
          >
            <span class="course-module-number">{module.order}</span>
            <a
              class="course-module-main"
              data-module-link
              href={index === 0 ? sessionHref(module.sessions[0].id) : undefined}
              aria-disabled={index === 0 ? undefined : "true"}
              tabindex={index === 0 ? undefined : -1}
            >
              <span class="course-module-title">
                <strong>{module.title}</strong>
                <span data-module-summary hidden={index !== 0}>{module.summary}</span>
              </span>
              <span class="course-module-progress" data-module-progress hidden={index !== 0}>
                <span data-module-progress-copy>0 / {module.sessions.length} sessions</span>
                <span class="course-module-progress-track" aria-hidden="true">
                  <span class="course-module-progress-fill" data-module-progress-fill style="width: 0%"></span>
                </span>
              </span>
              <span class="course-module-state" data-module-state>
                <span data-module-lock hidden={index === 0}><Fragment set:html={lockIcon} /></span>
                <span data-module-chevron hidden={index !== 0}><Fragment set:html={chevronIcon} /></span>
              </span>
            </a>
          </li>
        ))}
      </ol>
    </section>

    <div class="learning-insight-column">
      <section class="learning-panel learning-side-panel review-queue-panel" aria-labelledby="review-queue-title">
        <h2 id="review-queue-title">Review queue</h2>
        <ul class="skill-queue-list" data-skill-list></ul>
        <div class="insight-empty-state" data-review-empty>
          <span class="insight-empty-icon" aria-hidden="true">✓</span>
          <span>
            <strong>Your recall queue is clear</strong>
            <span>Complete practice and weak skills will appear here at the right time.</span>
          </span>
        </div>
        <a class="learning-outline-button is-disabled" data-review-link aria-disabled="true" tabindex="-1">
          <span data-review-action>You’re caught up</span>
          <Fragment set:html={chevronIcon} />
        </a>
      </section>

      <section class="learning-panel learning-side-panel mistakes-panel" aria-labelledby="mistakes-title">
        <h2 id="mistakes-title">Mistakes to repair</h2>
        <div class="repair-summary">
          <span class="repair-summary-icon" aria-hidden="true">!</span>
          <span>
            <strong data-mistake-count>No answers waiting</strong>
            <span data-mistake-copy>Mistakes you repair will disappear from this list.</span>
          </span>
        </div>
        <a class="learning-outline-button is-disabled" data-mistake-link aria-disabled="true" tabindex="-1">
          <span data-mistake-action>Nothing to repair</span>
          <Fragment set:html={chevronIcon} />
        </a>
      </section>
    </div>
  </div>

  <p class="learning-footer-note">Short sessions. Steady progress. Real English.</p>

  <script is:inline type="application/json" data-dashboard-data set:html={dashboardData} />
</section>

<script>
  import {
    LEARNING_PROGRESS_KEY,
    getNextLearningSessionId,
    isLearningSessionUnlocked,
    migrateLegacyLearningProgress,
    readLearningProgress,
    setDailyMinutes,
    writeLearningProgress,
  } from "../lib/learning-progress";
  import {
    buildMistakeSummary,
    buildMomentumSummary,
    buildSkillQueue,
    type ItemInsightMeta,
    type ObjectiveInsightMeta,
    type SkillInsight,
  } from "../lib/learning-insights";
  import {
    DAILY_RECALL_SESSION_ID,
    buildDailyRecallPlan,
  } from "../lib/daily-recall";
  import { practiceCatalog } from "../lib/practice";

  type DashboardSession = {
    id: string;
    title: string;
    stage: "context" | "learn" | "practice" | "speak" | "review";
    minutes: number;
    revision: number;
    required: boolean;
    href: string;
  };

  type DashboardModule = {
    id: string;
    order: number;
    title: string;
    summary: string;
    unitSlug: string;
    missionSlug: string;
    sessions: DashboardSession[];
  };

  type DashboardData = {
    modules: DashboardModule[];
    sessions: Array<{ id: string; revision: number; required: boolean }>;
    objectives: Record<string, ObjectiveInsightMeta>;
    items: Record<string, ItemInsightMeta>;
  };

  const focusCopy: Record<DashboardSession["stage"], string> = {
    context: "Meet the language in context, notice useful details, and get ready to learn.",
    learn: "Learn new words and patterns, study examples, and check your understanding.",
    practice: "Answer one item at a time, use feedback, and correct mistakes immediately.",
    speak: "Turn the new language into a short, useful spoken response.",
    review: "Recall the key language without notes and strengthen it for later.",
  };

  const setText = (root: Element, selector: string, value: string) => {
    const element = root.querySelector(selector);
    if (element) element.textContent = value;
  };

  const setActionState = (
    element: HTMLAnchorElement | null,
    href: string | null,
    enabled: boolean,
  ) => {
    if (!element) return;
    element.classList.toggle("is-disabled", !enabled);
    if (enabled && href) {
      element.href = href;
      element.removeAttribute("aria-disabled");
      element.removeAttribute("tabindex");
    } else {
      element.removeAttribute("href");
      element.setAttribute("aria-disabled", "true");
      element.tabIndex = -1;
    }
  };

  const withPracticeMode = (
    href: string,
    mode: "adaptive" | "daily" | "repair" | "repeat",
    fresh = true,
  ) => {
    const url = new URL(href, window.location.origin);
    if (fresh) url.searchParams.set("fresh", "1");
    if (mode === "daily") {
      url.searchParams.set("daily", "1");
    } else if (mode !== "repeat") {
      url.searchParams.set(mode, "1");
    }
    return `${url.pathname}${url.search}${url.hash}`;
  };

  document.querySelectorAll("[data-learning-dashboard]").forEach((root) => {
    const dataElement = root.querySelector("[data-dashboard-data]");
    let parsedData: DashboardData | null = null;

    try {
      parsedData = JSON.parse(dataElement?.textContent || "null") as DashboardData | null;
    } catch {
      parsedData = null;
    }

    if (!parsedData?.modules.length || !parsedData.sessions.length) return;
    const data = parsedData;
    const allSessions = data.modules.flatMap((module) => module.sessions);
    const sessionById = new Map(
      data.modules.flatMap((module) =>
        module.sessions.map((session) => [session.id, { module, session }] as const),
      ),
    );
    const timeZone = Intl.DateTimeFormat().resolvedOptions().timeZone;
    let courseMapExpanded = false;

    const syncCourseMapVisibility = (activeOrder: number) => {
      const groupStart = Math.floor((activeOrder - 1) / 6) * 6 + 1;
      const groupEnd = Math.min(data.modules.length, groupStart + 5);
      root.querySelectorAll<HTMLElement>("[data-course-order]").forEach((row) => {
        const order = Number(row.dataset.courseOrder);
        row.hidden = !courseMapExpanded && (order < groupStart || order > groupEnd);
      });
      setText(
        root,
        "[data-course-range]",
        courseMapExpanded
          ? `${data.modules.length} modules · ${data.sessions.length} sessions`
          : `Modules ${groupStart}–${groupEnd} of ${data.modules.length}`,
      );
      const toggle = root.querySelector<HTMLButtonElement>("[data-course-map-toggle]");
      if (toggle) {
        toggle.hidden = data.modules.length <= 6;
        toggle.setAttribute("aria-expanded", String(courseMapExpanded));
        toggle.textContent = courseMapExpanded ? "Show current phase" : `Show all ${data.modules.length}`;
      }
    };

    migrateLegacyLearningProgress(
      window.localStorage,
      data.modules.flatMap((module) => {
        const learnSession = module.sessions.find((session) => session.stage === "learn");
        const speakSession = module.sessions.find((session) => session.stage === "speak");
        return learnSession && speakSession
          ? [{
              unitSlug: module.unitSlug,
              learnSessionId: learnSession.id,
              learnRevision: learnSession.revision,
              missionSlug: module.missionSlug,
              speakSessionId: speakSession.id,
              speakRevision: speakSession.revision,
            }]
          : [];
      }),
    );

    const syncDashboard = () => {
      const progress = readLearningProgress(window.localStorage);
      const now = new Date().toISOString();
      const nextSessionId = getNextLearningSessionId(data.sessions, progress) ?? data.sessions[0].id;
      const nextEntry = sessionById.get(nextSessionId) ?? sessionById.get(data.sessions[0].id);
      if (!nextEntry) return;

      const { module: activeModule, session: activeSession } = nextEntry;
      syncCourseMapVisibility(activeModule.order);
      const isCompleted = (session: Pick<DashboardSession, "id" | "revision">) => {
        const record = progress.sessions[session.id];
        return record?.status === "completed" && record.revision === session.revision;
      };
      const isStarted = (session: Pick<DashboardSession, "id" | "revision">) => {
        const record = progress.sessions[session.id];
        return record?.status === "started" && record.revision === session.revision;
      };
      const hasActivePracticeRun = (session: Pick<DashboardSession, "id" | "revision">) => {
        const record = progress.sessions[session.id];
        return record?.revision === session.revision && Boolean(record.practiceRun);
      };
      const activeDailyRun = progress.sessions[DAILY_RECALL_SESSION_ID]?.practiceRun?.scope === "daily"
        ? progress.sessions[DAILY_RECALL_SESSION_ID].practiceRun
        : undefined;
      const isUnlocked = (session: Pick<DashboardSession, "id">) =>
        isLearningSessionUnlocked(data.sessions, progress, session.id);
      const practiceHref = (
        target: DashboardSession,
        mode: "adaptive" | "daily" | "repair" | "repeat" = "adaptive",
      ) => mode === "daily"
        ? withPracticeMode(target.href, mode, !activeDailyRun)
        : hasActivePracticeRun(target) ? target.href : withPracticeMode(target.href, mode);
      const allComplete = data.sessions
        .filter((item) => item.required !== false)
        .every((item) => isCompleted(item));

      setText(root, "[data-next-label]", allComplete ? "Course complete" : "Next session");
      setText(root, "[data-next-module]", `Module ${activeModule.order} · ${activeModule.title}`);
      setText(root, "[data-next-title]", activeSession.title);
      setText(root, "[data-next-minutes]", `${activeSession.minutes} min`);
      setText(root, "[data-next-description]", activeModule.summary);
      setText(
        root,
        "[data-next-action]",
        allComplete
          ? hasActivePracticeRun(activeSession) ? "Continue final review" : "Review the final step"
          : isStarted(activeSession) ? "Continue session" : "Start session",
      );
      setText(root, "[data-step-focus]", focusCopy[activeSession.stage]);
      setActionState(
        root.querySelector<HTMLAnchorElement>("[data-next-link]"),
        allComplete && (activeSession.stage === "practice" || activeSession.stage === "review")
          ? practiceHref(activeSession)
          : activeSession.href,
        true,
      );

      const cycle = root.querySelector("[data-learning-cycle]");
      cycle?.querySelectorAll("[data-cycle-session]").forEach((step, index) => {
        const moduleSession = activeModule.sessions[index];
        if (moduleSession) (step as HTMLElement).dataset.cycleSession = moduleSession.id;
        const sessionId = (step as HTMLElement).dataset.cycleSession || "";
        const cycleSession = activeModule.sessions.find((item) => item.id === sessionId);
        const completed = cycleSession ? isCompleted(cycleSession) : false;
        const current = !completed && sessionId === activeSession.id;
        const status = step.querySelector("[data-cycle-status]");
        step.classList.toggle("completed", completed);
        step.classList.toggle("current", current);
        if (status) {
          status.textContent = completed
            ? "Done"
            : current ? "In progress" : cycleSession?.required === false ? "Optional" : "Upcoming";
        }
      });

      const momentum = buildMomentumSummary(progress, data.sessions, now, timeZone);
      setText(root, "[data-active-days]", `${momentum.activeDayCount} active ${momentum.activeDayCount === 1 ? "day" : "days"}`);
      setText(root, "[data-course-percent]", String(momentum.coursePercent));
      setText(root, "[data-strong-skills]", String(momentum.strongSkills));
      setText(root, "[data-developing-skills]", String(momentum.developingSkills));
      setText(root, "[data-goal-progress]", `${momentum.todayMinutes} / ${momentum.dailyMinutes} min`);
      const courseProgress = root.querySelector<HTMLElement>("[data-course-progress]");
      const courseProgressFill = root.querySelector<HTMLElement>("[data-course-progress-fill]");
      const goalMeter = root.querySelector<HTMLElement>("[data-goal-meter]");
      const goalProgressFill = root.querySelector<HTMLElement>("[data-goal-progress-fill]");
      if (courseProgress) courseProgress.setAttribute("aria-valuenow", String(momentum.coursePercent));
      if (courseProgressFill) courseProgressFill.style.width = `${momentum.coursePercent}%`;
      const goalPercent = Math.round(momentum.dailyProgress * 100);
      if (goalMeter) goalMeter.setAttribute("aria-valuenow", String(goalPercent));
      if (goalProgressFill) goalProgressFill.style.width = `${goalPercent}%`;
      root.querySelectorAll<HTMLElement>("[data-momentum-day]").forEach((element, index) => {
        const day = momentum.days[index];
        if (!day) return;
        element.classList.toggle("is-active", day.active);
        element.classList.toggle("is-today", day.isToday);
        element.title = `${day.key}: ${day.minutes} learning minutes`;
        element.setAttribute("role", "img");
        element.setAttribute(
          "aria-label",
          `${day.key}: ${day.minutes} learning ${day.minutes === 1 ? "minute" : "minutes"}${day.isToday ? ", today" : ""}`,
        );
        const bar = element.querySelector<HTMLElement>("i");
        const label = element.querySelector("small");
        if (bar) bar.style.height = `${Math.max(day.active ? 28 : 12, Math.min(100, day.minutes * 7))}%`;
        if (label) label.textContent = day.label;
      });
      root.querySelectorAll<HTMLButtonElement>("[data-daily-minutes]").forEach((button) => {
        button.setAttribute("aria-pressed", String(Number(button.dataset.dailyMinutes) === momentum.dailyMinutes));
      });

      const skillQueue = buildSkillQueue(progress, data.objectives, now, timeZone, 2);
      const mistakes = buildMistakeSummary(progress, data.items, data.objectives);
      const dailyRecallPlan = buildDailyRecallPlan(practiceCatalog, progress, now);
      const findPracticeTarget = (
        unitId: string | undefined,
        sourceSessionId: string | undefined,
        purpose: "adaptive" | "daily" | "repair",
      ) => {
        const sourceEntry = sourceSessionId ? sessionById.get(sourceSessionId) : undefined;
        const module = (unitId ? data.modules.find((candidate) => candidate.unitSlug === unitId) : undefined)
          ?? sourceEntry?.module;
        if (!module) return undefined;
        const review = module.sessions.find((session) => session.stage === "review");
        const practice = module.sessions.find((session) => session.stage === "practice");
        const candidates = purpose === "repair" ? [practice, review] : [review, practice];
        return candidates.find((candidate) =>
          candidate && (purpose === "daily" || isUnlocked(candidate))
        );
      };
      const activeRepairEntry = Object.entries(progress.sessions)
        .find(([sessionId, record]) =>
          sessionId !== DAILY_RECALL_SESSION_ID && record.practiceRun?.phase === "repair"
        );
      const activeRepairSession = activeRepairEntry
        ? sessionById.get(activeRepairEntry[0])?.session
        : undefined;
      const firstMistake = mistakes.groups[0];
      const firstSkill = skillQueue[0];
      const activeDailyTarget = activeDailyRun?.hostSessionId
        ? sessionById.get(activeDailyRun.hostSessionId)?.session
        : undefined;
      const plannedDailyTarget = dailyRecallPlan.emptyReason === null
        ? dailyRecallPlan.unitIds
            .map((unitId) => findPracticeTarget(unitId, undefined, "daily"))
            .find(Boolean)
        : undefined;
      const dailyReviewTarget = activeDailyTarget ?? plannedDailyTarget;
      const reviewTarget = activeRepairSession
        ?? dailyReviewTarget;
      const reviewMode: "daily" | "repair" = activeRepairSession ? "repair" : "daily";
      const reviewIsCore = reviewMode !== "daily" && reviewTarget?.id === activeSession.id;
      const reviewEnabled = Boolean(
        reviewTarget && (reviewMode === "daily" || isUnlocked(reviewTarget)),
      );
      const dailyItemCount = activeDailyRun?.itemRefs.length ||
        (dailyRecallPlan.emptyReason === null ? dailyRecallPlan.count : 0);
      const dailyMinutes = activeDailyRun
        ? Math.min(progress.preferences.dailyMinutes, Math.max(1, Math.ceil(dailyItemCount * 1.25)))
        : dailyRecallPlan.emptyReason === null ? dailyRecallPlan.minutes : 0;
      const reviewLink = root.querySelector<HTMLAnchorElement>("[data-today-review]");
      setActionState(
        reviewLink,
        reviewTarget ? practiceHref(reviewTarget, reviewMode) : null,
        reviewEnabled,
      );
      reviewLink?.classList.toggle("is-ready", reviewEnabled);
      setText(
        root,
        "[data-today-review-title]",
        activeRepairSession
          ? "Mistake repair"
          : activeDailyRun?.phase === "repair" ? "Finish daily repair" : "Daily recall",
      );
      setText(
        root,
        "[data-today-review-minutes]",
        reviewTarget ? `${reviewMode === "daily" ? dailyMinutes : reviewTarget.minutes} min` : "—",
      );
      setText(root, "[data-today-review-status]", reviewEnabled ? "Ready" : skillQueue.length || mistakes.count ? "Locked" : "Caught up");
      setText(
        root,
        "[data-today-review-copy]",
        activeRepairSession
          ? "Resume the correction loop you started"
          : activeDailyRun
            ? `Continue your ${dailyItemCount}-item cross-unit review`
            : firstMistake
              ? `${mistakes.count} ${mistakes.count === 1 ? "answer" : "answers"} first, then due skills`
              : firstSkill
                ? `${dailyItemCount} items from ${dailyRecallPlan.unitIds.length} ${dailyRecallPlan.unitIds.length === 1 ? "unit" : "units"}`
                : "No skills are due today",
      );

      const coreLink = root.querySelector<HTMLAnchorElement>("[data-today-core]");
      setActionState(coreLink, activeSession.href, !reviewIsCore);
      setText(root, "[data-today-core-minutes]", reviewIsCore ? "—" : `${activeSession.minutes} min`);
      setText(root, "[data-today-core-status]", reviewIsCore ? "Next" : "Ready");
      setText(
        root,
        "[data-today-core-copy]",
        reviewIsCore ? "Finish the review above to continue" : activeSession.title,
      );

      const previousSpeaking = [...allSessions]
        .reverse()
        .find((session) =>
          session.stage === "speak" &&
          session.id !== activeSession.id &&
          session.id !== reviewTarget?.id &&
          isCompleted(session) &&
          isUnlocked(session)
        );
      const moduleSpeaking = activeModule.sessions.find((session) =>
        session.stage === "speak" &&
        session.id !== activeSession.id &&
        session.id !== reviewTarget?.id &&
        isUnlocked(session)
      );
      const speakingTarget = previousSpeaking ?? moduleSpeaking;
      const speakLink = root.querySelector<HTMLAnchorElement>("[data-today-speak]");
      setActionState(
        speakLink,
        speakingTarget
          ? isCompleted(speakingTarget) ? withPracticeMode(speakingTarget.href, "repeat") : speakingTarget.href
          : null,
        Boolean(speakingTarget),
      );
      speakLink?.classList.toggle("is-ready", Boolean(speakingTarget));
      setText(root, "[data-today-speak-minutes]", speakingTarget ? `${speakingTarget.minutes} min` : "—");
      setText(root, "[data-today-speak-status]", speakingTarget ? "Ready" : "Locked");
      setText(
        root,
        "[data-today-speak-copy]",
        speakingTarget?.title ?? (activeSession.stage === "speak"
          ? "Speaking is today’s core step"
          : "Complete the core steps to unlock speaking"),
      );

      data.modules.forEach((module) => {
        const row = root.querySelector(`[data-course-module="${module.id}"]`);
        if (!(row instanceof HTMLElement)) return;
        const requiredSessions = module.sessions.filter((session) => session.required !== false);
        const completedCount = requiredSessions.filter((session) => isCompleted(session)).length;
        const moduleCompleted = requiredSessions.every((session) => isCompleted(session));
        const current = module.id === activeModule.id;
        const firstIncomplete = requiredSessions.find((session) => !isCompleted(session))
          ?? requiredSessions.at(-1)
          ?? module.sessions.at(-1);
        const moduleUnlocked = firstIncomplete ? isUnlocked(firstIncomplete) : moduleCompleted;
        const summary = row.querySelector<HTMLElement>("[data-module-summary]");
        const progressElement = row.querySelector<HTMLElement>("[data-module-progress]");
        const lockElement = row.querySelector<HTMLElement>("[data-module-lock]");
        const chevronElement = row.querySelector<HTMLElement>("[data-module-chevron]");
        const moduleLink = row.querySelector<HTMLAnchorElement>("[data-module-link]");
        const progressFill = row.querySelector<HTMLElement>("[data-module-progress-fill]");
        const locked = !moduleCompleted && !moduleUnlocked;
        row.classList.toggle("current", current);
        row.classList.toggle("completed", moduleCompleted);
        if (summary) summary.hidden = !current;
        if (progressElement) progressElement.hidden = !current;
        if (lockElement) lockElement.hidden = !locked;
        if (chevronElement) chevronElement.hidden = locked;
        setText(row, "[data-module-progress-copy]", `${completedCount} / ${requiredSessions.length} sessions`);
        if (progressFill) {
          progressFill.style.width = `${requiredSessions.length ? (completedCount / requiredSessions.length) * 100 : 100}%`;
        }
        setActionState(moduleLink, firstIncomplete?.href ?? null, !locked && Boolean(firstIncomplete));
      });

      const skillList = root.querySelector<HTMLElement>("[data-skill-list]");
      const reviewEmpty = root.querySelector<HTMLElement>("[data-review-empty]");
      if (skillList) skillList.replaceChildren();
      if (reviewEmpty) reviewEmpty.hidden = skillQueue.length > 0;

      const makeSkillRow = (skill: SkillInsight) => {
        const item = document.createElement("li");
        const link = document.createElement("a");
        const icon = document.createElement("span");
        const copy = document.createElement("span");
        const title = document.createElement("strong");
        const status = document.createElement("em");
        const detail = document.createElement("span");
        const arrow = document.createElement("span");
        const target = dailyReviewTarget
          ?? findPracticeTarget(skill.unitId, skill.sourceSessionId, "daily");
        item.className = "skill-queue-item";
        link.className = "skill-queue-row";
        icon.className = `skill-queue-icon ${skill.due ? "is-due" : "is-weak"}`;
        icon.textContent = skill.due ? "?" : "↗";
        copy.className = "skill-queue-copy";
        title.textContent = skill.label;
        status.textContent = skill.status;
        detail.textContent = `${skill.lastSeenLabel}${skill.itemCount ? ` · ${skill.itemCount} items` : ""}`;
        arrow.className = "skill-queue-arrow";
        arrow.textContent = "›";
        title.append(" · ", status);
        copy.append(title, detail);
        link.append(icon, copy, arrow);
        setActionState(link, target ? practiceHref(target, "daily") : null, Boolean(target));
        item.append(link);
        return item;
      };
      skillQueue.forEach((skill) => skillList?.append(makeSkillRow(skill)));

      const reviewActionTarget = dailyReviewTarget;
      const reviewAction = root.querySelector<HTMLAnchorElement>("[data-review-link]");
      setActionState(
        reviewAction,
        reviewActionTarget ? practiceHref(reviewActionTarget, "daily") : null,
        Boolean(reviewActionTarget),
      );
      setText(
        root,
        "[data-review-action]",
        reviewActionTarget
          ? activeDailyRun ? "Resume daily recall" : "Start daily recall"
          : skillQueue.length ? "Continue the path first" : "You’re caught up",
      );

      const mistakeTarget = activeRepairSession
        ?? dailyReviewTarget;
      setText(
        root,
        "[data-mistake-count]",
        mistakes.count
          ? `${mistakes.count} ${mistakes.count === 1 ? "answer needs" : "answers need"} another try`
          : "No answers waiting",
      );
      setText(
        root,
        "[data-mistake-copy]",
        firstMistake
          ? `${firstMistake.label}${mistakes.groups.length > 1 ? ` + ${mistakes.groups.length - 1} more` : ""}`
          : "Mistakes you repair will disappear from this list.",
      );
      const mistakeLink = root.querySelector<HTMLAnchorElement>("[data-mistake-link]");
      setActionState(
        mistakeLink,
        mistakeTarget ? practiceHref(mistakeTarget, "repair") : null,
        Boolean(mistakeTarget && mistakes.count),
      );
      setText(
        root,
        "[data-mistake-action]",
        mistakes.count
          ? mistakeTarget ? activeRepairSession ? "Resume repair" : "Repair mistakes" : "Complete the path first"
          : "Nothing to repair",
      );
    };

    root.querySelectorAll<HTMLButtonElement>("[data-daily-minutes]").forEach((button) => {
      button.addEventListener("click", () => {
        const minutes = Number(button.dataset.dailyMinutes);
        if (minutes !== 5 && minutes !== 10 && minutes !== 15) return;
        const next = setDailyMinutes(readLearningProgress(window.localStorage), minutes);
        writeLearningProgress(window.localStorage, next);
        window.dispatchEvent(new CustomEvent("english-library:progress"));
        syncDashboard();
      });
    });

    root.querySelector<HTMLButtonElement>("[data-course-map-toggle]")?.addEventListener("click", () => {
      courseMapExpanded = !courseMapExpanded;
      syncDashboard();
    });

    syncDashboard();
    window.addEventListener("storage", (event) => {
      if (event.key === LEARNING_PROGRESS_KEY) syncDashboard();
    });
    window.addEventListener("english-library:progress", syncDashboard);
    window.addEventListener("pageshow", syncDashboard);
    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "visible") syncDashboard();
    });
  });
</script>
