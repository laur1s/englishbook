---
import type { SpeakingMissionEntry } from "../lib/content";
import { getContentSessionByHref } from "../lib/course-path";

import {
  MISSION_TYPE_LABELS,
  SPEAKING_COMPLETED_RUN_LIMIT,
  SPEAKING_PROGRESS_KEY,
  STEP_KIND_LABELS,
  formatDurationMinutes,
} from "../lib/speaking";

type Props = {
  entry: SpeakingMissionEntry;
  relatedHref?: string;
  relatedTitle?: string;
  resetOnFreshRequest?: boolean;
};

const { entry, relatedHref, relatedTitle, resetOnFreshRequest = false } = Astro.props;

type ListeningCheck = {
  id: string;
  kind: string;
  prompt: string;
  ltPrompt: string;
  hint: string;
  ltHint: string;
  options: Array<{ id: string; text: string }>;
  answerId: string;
  feedback: string;
  ltFeedback: string;
};

type ActiveListening = {
  modelText: string;
  speechText: string;
  checks: ListeningCheck[];
  shadowLine: string;
  shadowLineLt: string;
};

const activeListening = (entry.data as typeof entry.data & { listening?: ActiveListening }).listening;
const missionRevision = getContentSessionByHref(`/speaking/${entry.data.slug}`)?.revision ?? 1;

const modelPrefix = /^(?:check your version against this model|compare with this model exchange|compare with this model|check this model exchange|check this model|check the explanation|check the rule)\s*:\s*/i;
const getModelText = (prompt: string) => prompt.replace(modelPrefix, "").trim();
---

<section
  class="mission-player"
  id="mission-player"
  data-mission-player
  data-mission-slug={entry.data.slug}
  data-mission-revision={String(missionRevision)}
  data-reset-on-fresh-request={String(resetOnFreshRequest)}
  data-supports-recording={String(entry.data.supportsRecording)}
>
  <div class="mission-player-head">
    <div>
      <p class="eyebrow">Run The Rehearsal</p>
      <h2>Move once through the full speaking loop</h2>
      <p class="mission-player-copy">
        Keep the pace short, speak aloud, and resist writing a full script before you start.
      </p>
    </div>

    <div class="badge-row">
      <span class="badge soft">{MISSION_TYPE_LABELS[entry.data.missionType]}</span>
      <span class="badge">{formatDurationMinutes(entry.data.durationMinutes)}</span>
      <span class="badge" data-recording-badge>
        {entry.data.supportsRecording ? "Recording ready" : "Speak aloud only"}
      </span>
    </div>
  </div>

  <div class="mission-progress-strip">
    <div>
      <span>Status</span>
      <strong data-progress-status>Not completed yet</strong>
    </div>
    <div>
      <span>Last confidence</span>
      <strong data-progress-confidence>Not rated</strong>
    </div>
    <div>
      <span>Last practised</span>
      <strong data-progress-played>Never</strong>
    </div>
  </div>

  <p class="mission-live-status" data-mission-status role="status" aria-live="polite" aria-atomic="true">
    Mission ready.
  </p>

  <ol class="mission-step-list">
    {entry.data.steps.map((step, index) => (
      <li
        class="mission-step"
        data-mission-step
        data-step-kind={step.kind}
        data-step-seconds={step.seconds ? String(step.seconds) : ""}
      >
        <div class="mission-step-top">
          <div>
            <p class="eyebrow">Step {index + 1}</p>
            <h3 data-step-heading tabindex="-1">{STEP_KIND_LABELS[step.kind]}</h3>
          </div>

          {step.seconds ? (
            <div class="mission-timer-shell">
              <span class="mission-timer-label">Countdown</span>
              <strong data-timer-countdown>{Math.floor(step.seconds / 60)}:{String(step.seconds % 60).padStart(2, "0")}</strong>
            </div>
          ) : null}
        </div>

        <p class="mission-step-prompt">
          {step.kind === "compare" && activeListening
            ? "Listen for the main idea and one important detail. Keep the transcript hidden for your first try."
            : step.prompt}
        </p>
        {step.kind === "compare" && activeListening ? (
          <p class="mission-step-translation lt-text" lang="lt">
            Klausykitės pagrindinės minties ir vienos svarbios detalės. Pirmą kartą stenkitės neskaityti teksto.
          </p>
        ) : step.ltPrompt ? (
          <p class="mission-step-translation lt-text" lang="lt">{step.ltPrompt}</p>
        ) : null}

        {step.support?.length ? (
          <ul class="mission-support-list">
            {step.support.map((item) => <li>{item}</li>)}
          </ul>
        ) : null}

        {step.kind === "prep" ? (
          <label class="mission-prep-notes">
            <span>Your three keywords</span>
            <textarea
              data-prep-notes
              rows="2"
              maxlength="180"
              placeholder="Write keywords only — not a full script"
            ></textarea>
            <small>Saved on this device. Audio is never stored here.</small>
          </label>
        ) : null}

        {step.kind === "speak" ? (
          <section class="mission-tool-panel mission-recording-panel" data-recording-panel aria-label="Speaking recorder">
            <div>
              <p class="mission-tool-label">Your take</p>
              <h4>Record, replay, and try again</h4>
            </div>
            <p class="mission-privacy-note">Audio stays in this tab and is never uploaded.</p>
            <div class="mission-recording-controls">
              <button type="button" class="primary-button" data-record hidden>Record</button>
              <button type="button" class="primary-button" data-stop-recording hidden disabled>Stop</button>
              <button type="button" class="secondary-button" data-replace-recording hidden>Replace</button>
            </div>
            <audio data-recording-playback controls preload="metadata" aria-label="Your recorded speaking take" hidden></audio>
            <p class="mission-recording-fallback" data-recording-fallback hidden>
              Recording is not available here. Use the timer and speak aloud instead.
            </p>
            <label class="mission-no-recording-option">
              <input type="checkbox" data-no-recording />
              <span>Practise without recording</span>
            </label>
          </section>
        ) : null}

        {step.kind === "compare" && activeListening ? (
          <section
            class="mission-tool-panel mission-active-listening"
            data-active-listening
            data-model-text={activeListening.modelText}
            data-speech-text={activeListening.speechText}
            data-shadow-text={activeListening.shadowLine}
            aria-labelledby={`listening-title-${entry.data.slug}`}
          >
            <div class="mission-listening-heading">
              <div>
                <p class="mission-tool-label">Active listening</p>
                <h4 id={`listening-title-${entry.data.slug}`}>Listen. Then check what you understood.</h4>
                <p class="lt-text" lang="lt">Klausykitės. Tada patikrinkite, ką supratote.</p>
              </div>
              <span class="mission-listening-stage" data-active-listening-stage>Ready to listen</span>
            </div>

            <p class="mission-listening-instruction">
              Listen at normal or slow speed. The two questions open when the model ends.
              <span class="lt-text" lang="lt"> Klausykitės įprastu arba lėtesniu greičiu. Du klausimai atsivers įrašui pasibaigus.</span>
            </p>

            <div class="mission-listening-controls">
              <button type="button" class="primary-button" data-active-listen hidden>Listen · Klausyti</button>
              <button type="button" class="secondary-button" data-active-listen-slow hidden>Slow · Lėčiau</button>
              <button type="button" class="secondary-button" data-use-listening-transcript>
                Read transcript · Skaityti tekstą
              </button>
            </div>

            <p class="mission-recording-fallback" data-active-listening-fallback hidden>
              Voice is not available here. Read the transcript to continue.
              <span class="lt-text" lang="lt"> Čia balso įrašas nepasiekiamas. Tęskite skaitydami tekstą.</span>
            </p>

            <div class="mission-model-transcript mission-assist-transcript" data-listening-assist-transcript tabindex="-1" hidden>
              <p class="mission-tool-label">Transcript option · Teksto variantas</p>
              <p>{activeListening.modelText}</p>
            </div>

            <div class="mission-listening-checks" data-active-listening-checks hidden>
              <div class="mission-listening-checks-head">
                <div>
                  <p class="mission-tool-label">Comprehension check</p>
                  <h5>Answer both before you reveal the transcript</h5>
                </div>
                <span data-listening-score>0/{activeListening.checks.length} correct</span>
              </div>

              {activeListening.checks.map((check, checkIndex) => (
                <fieldset
                  class="mission-listening-check"
                  data-listening-check
                  data-check-id={check.id}
                  data-answer-id={check.answerId}
                  data-hint={check.hint}
                  data-hint-lt={check.ltHint}
                  data-feedback={check.feedback}
                  data-feedback-lt={check.ltFeedback}
                >
                  <legend>
                    <span class="mission-check-kind">
                      {check.kind === "gist" ? "Main idea" : check.kind === "detail" ? "Detail" : check.kind}
                    </span>
                    <span>{checkIndex + 1}. {check.prompt}</span>
                    <span class="lt-text" lang="lt">{check.ltPrompt}</span>
                  </legend>
                  <div class="mission-listening-options">
                    {check.options.map((option) => (
                      <label>
                        <input
                          type="radio"
                          name={`${entry.data.slug}-${check.id}`}
                          value={option.id}
                        />
                        <span>{option.text}</span>
                      </label>
                    ))}
                  </div>
                  <p
                    class="mission-listening-feedback"
                    data-listening-feedback
                    role="status"
                    aria-live="polite"
                    aria-atomic="true"
                    hidden
                  >
                    <span data-listening-feedback-en></span>
                    <span class="lt-text" data-listening-feedback-lt lang="lt"></span>
                  </p>
                </fieldset>
              ))}
            </div>

            <div class="mission-listening-reveal">
              <button type="button" class="secondary-button" data-reveal-listening-transcript hidden disabled>
                Show transcript · Rodyti tekstą
              </button>
              <p class="mission-time-note" data-listening-reveal-note>
                Listen and try both questions. Then you can show the transcript.
                <span class="lt-text" lang="lt"> Išklausykite ir atsakykite į abu klausimus. Tada galėsite parodyti tekstą.</span>
              </p>
            </div>

            <div class="mission-model-transcript mission-active-transcript" data-active-transcript tabindex="-1" hidden>
              <p class="mission-tool-label">Model transcript</p>
              <p>{activeListening.modelText}</p>
            </div>

            <div class="mission-shadow-check" data-listening-shadow-panel hidden>
              <p class="mission-tool-label">Read or listen, then repeat · Perskaitykite arba klausykitės, tada pakartokite</p>
              <p>
                Listen to or read the line, then repeat it aloud and copy the rhythm.
                <span class="lt-text" lang="lt"> Išklausykite arba perskaitykite sakinį, tada garsiai jį pakartokite ir pamėgdžiokite ritmą.</span>
              </p>
              <blockquote>{activeListening.shadowLine}</blockquote>
              <p class="lt-text" lang="lt">{activeListening.shadowLineLt}</p>
              <button type="button" class="secondary-button" data-play-shadow-line hidden>
                Play line · Klausyti sakinio
              </button>
              <label>
                <input type="checkbox" data-listening-shadowed />
                <span>
                  I read or listened to this line, then repeated it aloud and copied the rhythm.
                  <small class="lt-text" lang="lt">Perskaičiau arba išklausiau šį sakinį, tada garsiai jį pakartojau ir pamėgdžiojau ritmą.</small>
                </span>
              </label>
            </div>
          </section>
        ) : step.kind === "compare" ? (
          <section
            class="mission-tool-panel mission-listening-panel"
            data-listening-panel
            data-model-text={getModelText(step.prompt)}
            aria-label="Listen to the model"
          >
            <div>
              <p class="mission-tool-label">Model listening</p>
              <h4>Listen, then compare with your take</h4>
            </div>
            <div class="mission-listening-controls">
              <button type="button" class="primary-button" data-listen-model hidden>Listen</button>
              <button type="button" class="secondary-button" data-listen-slow hidden>Slow</button>
              <span class="mission-listened-state" data-listened-state>Not listened yet</span>
            </div>
            <p class="mission-recording-fallback" data-listening-fallback hidden>
              Voice playback is not available here. Read the transcript aloud instead.
            </p>
            <div class="mission-model-transcript">
              <p class="mission-tool-label">Visible transcript</p>
              <p data-model-transcript>{getModelText(step.prompt)}</p>
            </div>
          </section>
        ) : null}

        {step.seconds ? (
          <div class="mission-timer-tools">
            <p class="mission-time-note">Suggested time: {step.seconds} seconds.</p>
            <button type="button" class="secondary-button" data-start-timer hidden>
              Start timer
            </button>
            <p class="mission-timer-status" data-timer-status hidden>Timer ready.</p>
          </div>
        ) : null}

        {step.kind === "reflect" ? (
          <div class="mission-reflect">
            <fieldset class="mission-self-check">
              <legend>Quick accuracy and fluency check</legend>
              <label><input type="checkbox" data-self-check value="target-grammar" /> I used the target grammar at least twice.</label>
              <label><input type="checkbox" data-self-check value="full-phrases" /> I spoke in full phrases without reading every word.</label>
              <label><input type="checkbox" data-self-check value="self-correction" /> I noticed and corrected at least one mistake.</label>
            </fieldset>
            <p class="mission-time-note">
              Second-attempt goal: repeat the hardest step once, with one clearer sentence and fewer pauses.
            </p>
            <p class="mission-time-note">Rate the run: 1 = very hard, 5 = smooth and natural.</p>
            <div class="confidence-row" data-confidence-row hidden>
              {[1, 2, 3, 4, 5].map((score) => (
                <button type="button" class="confidence-button" data-confidence={String(score)} aria-label={`Confidence ${score} out of 5`} aria-pressed="false">
                  {score}
                </button>
              ))}
            </div>
            <p class="mission-reflect-note" data-confidence-note>
              Choose a confidence score or save one self-check, then use Finish mission.
            </p>
            {relatedHref && relatedTitle ? (
              <a class="inline-link" href={relatedHref}>Return to {relatedTitle}</a>
            ) : null}
          </div>
        ) : null}
      </li>
    ))}
  </ol>

  <div class="mission-controls" data-player-controls hidden>
    <button type="button" class="secondary-button" data-prev-step>Previous step</button>
    <button type="button" class="primary-button" data-next-step>Next step</button>
  </div>

  <noscript>
    <p class="mission-noscript">
      JavaScript is off, so every step stays open. Use the suggested timings, read the model transcript,
      and practise aloud without recording.
    </p>
  </noscript>
</section>

<script is:inline define:vars={{
  progressKey: SPEAKING_PROGRESS_KEY,
  completedRunLimit: SPEAKING_COMPLETED_RUN_LIMIT,
}}>
  const readSpeakingProgress = () => {
    try {
      const raw = localStorage.getItem(progressKey);

      if (!raw) {
        return {};
      }

      const parsed = JSON.parse(raw);
      return parsed && typeof parsed === "object" && !Array.isArray(parsed) ? parsed : {};
    } catch {
      return {};
    }
  };

  const writeSpeakingProgress = (value) => {
    try {
      localStorage.setItem(progressKey, JSON.stringify(value));
      window.dispatchEvent(new CustomEvent("english-library:speaking-progress"));
      return true;
    } catch {
      return false;
    }
  };

  const isSpeakingRecord = (value) =>
    Boolean(value) && typeof value === "object" && !Array.isArray(value);

  const normalizeStoredDate = (value) => {
    if (typeof value !== "string" || !Number.isFinite(Date.parse(value))) return null;
    return new Date(value).toISOString();
  };

  const sanitizeStringIds = (value) => Array.isArray(value)
    ? [...new Set(value.flatMap((item) => {
        if (typeof item !== "string") return [];
        const normalized = item.trim().slice(0, 120);
        return normalized ? [normalized] : [];
      }))].slice(0, 12)
    : [];

  const sanitizeCompletedRun = (value) => {
    if (!isSpeakingRecord(value) || value.completed !== true) return null;
    const completedAt = normalizeStoredDate(value.completedAt);
    if (!completedAt) return null;

    const storedRevision = Number(value.revision ?? 1);
    const run = {
      revision: Number.isInteger(storedRevision) && storedRevision > 0 ? storedRevision : 1,
      completed: true,
      completedAt,
    };
    const startedAt = normalizeStoredDate(value.startedAt);
    const lastPlayedAt = normalizeStoredDate(value.lastPlayedAt);
    const ratedAt = normalizeStoredDate(value.ratedAt);
    const activeStep = Number(value.activeStep);
    const confidence = Number(value.lastConfidence);
    const selfChecks = sanitizeStringIds(value.selfChecks);

    if (startedAt) run.startedAt = startedAt;
    if (lastPlayedAt) run.lastPlayedAt = lastPlayedAt;
    if (ratedAt) run.ratedAt = ratedAt;
    if (Number.isInteger(activeStep) && activeStep >= 0) run.activeStep = activeStep;
    if (Number.isInteger(confidence) && confidence >= 1 && confidence <= 5) {
      run.lastConfidence = confidence;
    }
    if (selfChecks.length) run.selfChecks = selfChecks;
    if (value.noRecording === true) run.noRecording = true;
    if (value.listened === true) run.listened = true;

    if (isSpeakingRecord(value.listening)) {
      run.listening = {
        assisted: value.listening.assisted === true,
        played: value.listening.played === true,
        revealed: value.listening.revealed === true,
        shadowed: value.listening.shadowed === true,
        correctIds: sanitizeStringIds(value.listening.correctIds),
        firstAttemptCorrectIds: sanitizeStringIds(value.listening.firstAttemptCorrectIds),
        attemptedIds: sanitizeStringIds(value.listening.attemptedIds),
      };
    }

    return run;
  };

  // Keep only compact, valid evidence for the five most recent completed runs.
  const sanitizeCompletedRuns = (value) => {
    if (!Array.isArray(value)) return [];
    const uniqueRuns = new Map();

    value.forEach((run) => {
      const sanitized = sanitizeCompletedRun(run);
      if (!sanitized) return;
      uniqueRuns.set(`${sanitized.revision}:${sanitized.completedAt}`, sanitized);
    });

    return [...uniqueRuns.values()]
      .sort((left, right) => Date.parse(left.completedAt) - Date.parse(right.completedAt))
      .slice(-completedRunLimit);
  };

  const archiveCompletedRun = (runs, value) => {
    const completedRun = sanitizeCompletedRun(value);
    return sanitizeCompletedRuns([
      ...sanitizeCompletedRuns(runs),
      ...(completedRun ? [completedRun] : []),
    ]);
  };

  const sanitizeRecordHistory = (value) => {
    if (!isSpeakingRecord(value)) return {};
    const { completedRuns: storedRuns, ...record } = value;
    const completedRuns = sanitizeCompletedRuns(storedRuns);
    return {
      ...record,
      ...(completedRuns.length ? { completedRuns } : {}),
    };
  };

  const formatCountdown = (seconds) => {
    const minutes = Math.floor(seconds / 60);
    return `${minutes}:${String(seconds % 60).padStart(2, "0")}`;
  };

  const formatLastPlayed = (value) => {
    if (!value) {
      return "Never";
    }

    const parsed = new Date(value);

    if (Number.isNaN(parsed.getTime())) {
      return "Recently";
    }

    return parsed.toLocaleDateString("en-GB", {
      year: "numeric",
      month: "short",
      day: "numeric",
    });
  };

  document.querySelectorAll("[data-mission-player]").forEach((root) => {
    const slug = root.dataset.missionSlug;
    const revision = Number(root.dataset.missionRevision || 1);
    const steps = [...root.querySelectorAll("[data-mission-step]")];
    const controls = root.querySelector("[data-player-controls]");
    const prevButton = root.querySelector("[data-prev-step]");
    const nextButton = root.querySelector("[data-next-step]");
    const statusValue = root.querySelector("[data-progress-status]");
    const confidenceValue = root.querySelector("[data-progress-confidence]");
    const playedValue = root.querySelector("[data-progress-played]");
    const liveStatus = root.querySelector("[data-mission-status]");
    const confidenceButtons = [...root.querySelectorAll("[data-confidence]")];
    const confidenceRow = root.querySelector("[data-confidence-row]");
    const confidenceNote = root.querySelector("[data-confidence-note]");
    const prepNotes = root.querySelector("[data-prep-notes]");
    const selfChecks = [...root.querySelectorAll("[data-self-check]")];
    const recordingPanel = root.querySelector("[data-recording-panel]");
    const recordingBadge = root.querySelector("[data-recording-badge]");

    if (!slug || !steps.length || !controls || !prevButton || !nextButton) {
      return;
    }

    const selectCurrentRecord = (value) => {
      const record = value && typeof value === "object" && !Array.isArray(value) ? value : {};
      const savedRevision = Number(record.revision ?? 1);
      return savedRevision === revision ? record : {};
    };

    let progress = readSpeakingProgress();
    const recordWithHistory = isSpeakingRecord(progress[slug]) ? progress[slug] : null;

    if (recordWithHistory && Object.prototype.hasOwnProperty.call(recordWithHistory, "completedRuns")) {
      progress = {
        ...progress,
        [slug]: sanitizeRecordHistory(recordWithHistory),
      };
      writeSpeakingProgress(progress);
    }

    const shouldStartFreshRun = root.dataset.resetOnFreshRequest === "true" &&
      new URL(window.location.href).searchParams.get("fresh") === "1";

    if (shouldStartFreshRun) {
      const storedRecord = sanitizeRecordHistory(progress[slug]);
      const nextCompletedRuns = archiveCompletedRun(storedRecord.completedRuns, storedRecord);

      const freshRecord = {
        revision,
        activeStep: 0,
        startedAt: new Date().toISOString(),
        ...(nextCompletedRuns.length ? { completedRuns: nextCompletedRuns } : {}),
      };
      progress = { ...progress, [slug]: freshRecord };
      writeSpeakingProgress(progress);
      root.dataset.freshRunActive = "true";
      root.__freshSpeakingRecord = freshRecord;
    }

    const initialRecord = selectCurrentRecord(progress[slug]);
    let currentRunRecord = initialRecord;
    const savedStep = Number(initialRecord.activeStep);
    let activeIndex = Number.isInteger(savedStep) && savedStep >= 0 && savedStep < steps.length
      ? savedStep
      : 0;
    let timerId = null;
    let timerDeadline = 0;
    let timerStep = null;
    let mediaRecorder = null;
    let mediaStream = null;
    let audioUrl = null;
    let recordedChunks = [];
    let currentUtterance = null;
    let disposing = false;
    let shouldRestoreRecordingFocus = false;

    const getRecord = () => {
      return shouldStartFreshRun ? currentRunRecord : selectCurrentRecord(progress[slug]);
    };

    const announce = (message) => {
      if (liveStatus) {
        liveStatus.textContent = message;
      }
    };

    const updateProgress = (updates) => {
      progress = readSpeakingProgress();
      const storedValue = sanitizeRecordHistory(progress[slug]);
      const storedRecord = sanitizeRecordHistory(selectCurrentRecord(progress[slug]));
      const storedRevision = Number(storedValue.revision ?? 1);
      const carriedRuns = storedRevision === revision
        ? sanitizeCompletedRuns(storedRecord.completedRuns)
        : archiveCompletedRun(storedValue.completedRuns, storedValue);
      const revisionRecord = storedRevision === revision
        ? storedRecord
        : carriedRuns.length ? { completedRuns: carriedRuns } : {};
      const previousRecord = shouldStartFreshRun && revisionRecord.startedAt !== currentRunRecord.startedAt
        ? sanitizeRecordHistory(currentRunRecord)
        : revisionRecord;
      const nextRecord = sanitizeRecordHistory({
        ...previousRecord,
        ...updates,
        revision,
      });
      currentRunRecord = nextRecord;

      progress = {
        ...progress,
        [slug]: nextRecord,
      };

      const saved = writeSpeakingProgress(progress);
      syncProgressUi();
      return saved;
    };

    const markStarted = (updates = {}) => {
      const record = getRecord();
      const now = new Date().toISOString();
      return updateProgress({
        ...updates,
        startedAt: record.startedAt || now,
        lastPlayedAt: now,
      });
    };

    const clearTimer = () => {
      if (timerId !== null) {
        window.clearInterval(timerId);
        timerId = null;
      }
      timerDeadline = 0;
      timerStep = null;
    };

    const resetTimers = () => {
      steps.forEach((step) => {
        const seconds = Number(step.dataset.stepSeconds || 0);
        const countdown = step.querySelector("[data-timer-countdown]");
        const timerButton = step.querySelector("[data-start-timer]");
        const timerStatus = step.querySelector("[data-timer-status]");

        if (!seconds || !countdown) {
          return;
        }

        countdown.textContent = formatCountdown(seconds);

        if (timerButton) {
          timerButton.hidden = false;
        }

        if (timerStatus) {
          timerStatus.hidden = false;
          timerStatus.textContent = "Timer ready.";
        }
      });
    };

    const startTimer = (step) => {
      const seconds = Number(step?.dataset.stepSeconds || 0);
      const countdown = step?.querySelector("[data-timer-countdown]");
      const timerStatus = step?.querySelector("[data-timer-status]");

      if (!seconds || !countdown) {
        return;
      }

      clearTimer();
      timerStep = step;
      timerDeadline = Date.now() + seconds * 1000;
      countdown.textContent = formatCountdown(seconds);

      if (timerStatus) {
        timerStatus.hidden = false;
        timerStatus.textContent = "Timer running.";
      }

      announce(`Timer started for ${seconds} seconds.`);

      const tick = () => {
        if (!timerStep || !timerDeadline) {
          return;
        }

        const remaining = Math.max(0, Math.ceil((timerDeadline - Date.now()) / 1000));
        countdown.textContent = formatCountdown(remaining);

        if (remaining <= 0) {
          clearTimer();
          if (timerStatus) {
            timerStatus.textContent = "Time is up. Finish the sentence and move on.";
          }
          announce("Time is up. Finish your sentence, then move on.");
        }
      };

      tick();
      timerId = window.setInterval(tick, 250);
    };

    const hasSpeechPlayback =
      "speechSynthesis" in window && "SpeechSynthesisUtterance" in window;
    const hasRecording = Boolean(
      root.dataset.supportsRecording === "true" &&
      navigator.mediaDevices?.getUserMedia &&
      "MediaRecorder" in window,
    );

    const stopStream = () => {
      if (mediaStream) {
        mediaStream.getTracks().forEach((track) => track.stop());
        mediaStream = null;
      }
    };

    const revokeAudio = () => {
      if (audioUrl) {
        URL.revokeObjectURL(audioUrl);
        audioUrl = null;
      }
    };

    const cancelSpeech = () => {
      if (hasSpeechPlayback) {
        window.speechSynthesis.cancel();
      }
      currentUtterance = null;
    };

    const syncRecordingUi = (state = "idle") => {
      if (!recordingPanel) {
        return;
      }

      const recordButton = recordingPanel.querySelector("[data-record]");
      const stopButton = recordingPanel.querySelector("[data-stop-recording]");
      const replaceButton = recordingPanel.querySelector("[data-replace-recording]");
      const playback = recordingPanel.querySelector("[data-recording-playback]");
      const fallback = recordingPanel.querySelector("[data-recording-fallback]");
      const hasAudio = Boolean(audioUrl && playback?.getAttribute("src"));
      const isRecording = state === "recording";

      if (recordButton) {
        recordButton.hidden = !hasRecording || hasAudio || isRecording;
        recordButton.disabled = isRecording;
      }
      if (stopButton) {
        stopButton.hidden = !isRecording;
        stopButton.disabled = !isRecording;
      }
      if (replaceButton) {
        replaceButton.hidden = !hasRecording || !hasAudio || isRecording;
        replaceButton.disabled = isRecording;
      }
      if (fallback) {
        fallback.hidden = hasRecording;
      }
    };

    const pickRecordingMimeType = () => {
      if (!("MediaRecorder" in window) || typeof window.MediaRecorder.isTypeSupported !== "function") {
        return "";
      }

      return [
        "audio/webm;codecs=opus",
        "audio/webm",
        "audio/mp4",
        "audio/ogg;codecs=opus",
      ].find((type) => {
        try {
          return window.MediaRecorder.isTypeSupported(type);
        } catch {
          return false;
        }
      }) || "";
    };

    const stopRecording = (restoreFocus = false) => {
      shouldRestoreRecordingFocus = restoreFocus;
      if (mediaRecorder && mediaRecorder.state !== "inactive") {
        mediaRecorder.stop();
        announce("Recording stopped. Your take is ready to replay.");
      } else {
        stopStream();
      }
    };

    const startRecording = async () => {
      if (!recordingPanel || !hasRecording) {
        markStarted({ noRecording: true });
        const noRecording = recordingPanel?.querySelector("[data-no-recording]");
        if (noRecording) noRecording.checked = true;
        announce("Recording is unavailable. Practise aloud with the timer instead.");
        return;
      }

      const recordButton = recordingPanel.querySelector("[data-record]");
      const replaceButton = recordingPanel.querySelector("[data-replace-recording]");
      if (recordButton) recordButton.disabled = true;
      if (replaceButton) replaceButton.disabled = true;

      try {
        mediaStream = await navigator.mediaDevices.getUserMedia({ audio: true });

        if (disposing) {
          stopStream();
          return;
        }

        const mimeType = pickRecordingMimeType();
        mediaRecorder = mimeType
          ? new window.MediaRecorder(mediaStream, { mimeType })
          : new window.MediaRecorder(mediaStream);
        recordedChunks = [];

        mediaRecorder.addEventListener("dataavailable", (event) => {
          if (event.data?.size) {
            recordedChunks.push(event.data);
          }
        });

        mediaRecorder.addEventListener("stop", () => {
          const recorderType = mediaRecorder?.mimeType || mimeType || recordedChunks[0]?.type || "audio/webm";
          const playback = recordingPanel.querySelector("[data-recording-playback]");

          stopStream();
          mediaRecorder = null;

          if (!disposing && recordedChunks.length && playback) {
            revokeAudio();
            const recording = new Blob(recordedChunks, { type: recorderType });
            audioUrl = URL.createObjectURL(recording);
            playback.src = audioUrl;
            playback.hidden = false;
          }

          recordedChunks = [];
          syncRecordingUi();
          if (shouldRestoreRecordingFocus && !disposing) {
            const recordButton = recordingPanel.querySelector("[data-record]");
            const replaceButton = recordingPanel.querySelector("[data-replace-recording]");
            const focusTarget = audioUrl && playback && !playback.hidden
              ? playback
              : recordButton && !recordButton.hidden
                ? recordButton
                : replaceButton;
            window.requestAnimationFrame(() => focusTarget?.focus());
          }
          shouldRestoreRecordingFocus = false;
        }, { once: true });

        revokeAudio();
        const playback = recordingPanel.querySelector("[data-recording-playback]");
        if (playback) {
          playback.pause();
          playback.removeAttribute("src");
          playback.load();
          playback.hidden = true;
        }

        mediaRecorder.start();
        const noRecording = recordingPanel.querySelector("[data-no-recording]");
        if (noRecording) noRecording.checked = false;
        markStarted({ noRecording: false });
        syncRecordingUi("recording");
        const stopButton = recordingPanel.querySelector("[data-stop-recording]");
        window.requestAnimationFrame(() => stopButton?.focus());
        const speakingStep = recordingPanel.closest("[data-mission-step]");
        startTimer(speakingStep);
        announce("Recording started. Speak naturally; press Stop when you finish.");
      } catch (error) {
        stopStream();
        mediaRecorder = null;
        const noRecording = recordingPanel.querySelector("[data-no-recording]");
        if (noRecording) noRecording.checked = true;
        markStarted({ noRecording: true });
        syncRecordingUi();
        const fallback = recordingPanel.querySelector("[data-recording-fallback]");
        if (fallback) {
          fallback.hidden = false;
          fallback.textContent = error?.name === "NotAllowedError"
            ? "Microphone permission was not granted. Use the timer and speak aloud instead."
            : "The microphone could not start. Use the timer and speak aloud instead.";
        }
        announce("Microphone unavailable. Practise aloud with the timer instead.");
      }
    };

    const syncProgressUi = () => {
      const record = getRecord();
      const lastConfidence = Number(record.lastConfidence);
      const hasConfidence = Number.isInteger(lastConfidence) && lastConfidence >= 1 && lastConfidence <= 5;
      const savedChecks = Array.isArray(record.selfChecks)
        ? record.selfChecks.filter((value) => typeof value === "string")
        : [];

      if (statusValue) {
        statusValue.textContent = record.completed ? "Completed" : "Not completed yet";
      }

      if (confidenceValue) {
        confidenceValue.textContent = hasConfidence ? `${lastConfidence}/5` : "Not rated";
      }

      if (playedValue) {
        playedValue.textContent = formatLastPlayed(record.lastPlayedAt);
      }

      if (confidenceNote) {
        confidenceNote.textContent = hasConfidence
          ? `Saved confidence: ${lastConfidence}/5. Use Finish mission when you are ready.`
          : savedChecks.length
            ? "Self-check saved. Add a confidence score if useful, then finish the mission."
            : "Choose a confidence score or save one self-check, then use Finish mission.";
      }

      confidenceButtons.forEach((button) => {
        const isSelected = Number(button.dataset.confidence) === lastConfidence;
        button.classList.toggle("selected", isSelected);
        button.setAttribute("aria-pressed", String(isSelected));
      });

      selfChecks.forEach((input) => {
        input.checked = savedChecks.includes(input.value);
      });

      if (prepNotes && document.activeElement !== prepNotes) {
        prepNotes.value = typeof record.prepNotes === "string" ? record.prepNotes.slice(0, 180) : "";
      }

      const noRecording = recordingPanel?.querySelector("[data-no-recording]");
      if (noRecording) {
        noRecording.checked = record.noRecording === true;
      }

      root.querySelectorAll("[data-listened-state]").forEach((value) => {
        value.textContent = record.listened === true ? "Listened" : "Not listened yet";
      });
    };

    const syncNextControl = () => {
      const activeStep = steps[activeIndex];
      const needsListeningEvidence = Boolean(activeStep?.querySelector("[data-active-listening]"));
      const listeningReady = root.dataset.listeningReady === "true";

      prevButton.disabled = activeIndex === 0;
      nextButton.disabled = needsListeningEvidence && !listeningReady;
      nextButton.textContent = activeIndex === steps.length - 1
        ? "Finish mission"
        : needsListeningEvidence && !listeningReady
          ? "Finish listening to continue"
          : "Next step";
    };

    const showStep = (index, shouldFocus = true, shouldPersist = true) => {
      const nextIndex = Math.max(0, Math.min(index, steps.length - 1));
      if (mediaRecorder?.state === "recording" && nextIndex !== activeIndex) {
        stopRecording();
      }
      clearTimer();
      resetTimers();
      cancelSpeech();
      root.querySelectorAll("audio").forEach((audio) => audio.pause());
      activeIndex = nextIndex;

      steps.forEach((step, stepIndex) => {
        step.hidden = stepIndex !== activeIndex;
      });

      syncNextControl();

      if (shouldPersist) {
        markStarted({ activeStep: activeIndex });
      }

      const heading = steps[activeIndex]?.querySelector("[data-step-heading]");
      const headingText = heading?.textContent?.trim() || `Step ${activeIndex + 1}`;
      announce(`Step ${activeIndex + 1} of ${steps.length}: ${headingText}.`);

      if (shouldFocus && heading) {
        window.requestAnimationFrame(() => heading.focus({ preventScroll: true }));
      }
    };

    controls.hidden = false;

    if (confidenceRow) {
      confidenceRow.hidden = false;
    }

    if (recordingBadge && !hasRecording) {
      recordingBadge.textContent = "Timer-only fallback";
    }

    syncRecordingUi();

    root.querySelectorAll("[data-listening-panel]").forEach((panel) => {
      const listenButton = panel.querySelector("[data-listen-model]");
      const slowButton = panel.querySelector("[data-listen-slow]");
      const fallback = panel.querySelector("[data-listening-fallback]");

      if (listenButton) listenButton.hidden = !hasSpeechPlayback;
      if (slowButton) slowButton.hidden = !hasSpeechPlayback;
      if (fallback) fallback.hidden = hasSpeechPlayback;

      const playModel = (rate) => {
        const text = panel.dataset.modelText?.trim();

        if (!hasSpeechPlayback || !text) {
          if (fallback) fallback.hidden = false;
          announce("Voice playback is unavailable. Use the visible transcript instead.");
          return;
        }

        cancelSpeech();
        const utterance = new window.SpeechSynthesisUtterance(text);
        utterance.lang = "en-GB";
        utterance.rate = rate;
        utterance.onstart = () => {
          currentUtterance = utterance;
          markStarted({ listened: true });
          announce(rate < 1 ? "Playing the model slowly." : "Playing the model.");
        };
        utterance.onend = () => {
          if (currentUtterance === utterance) {
            currentUtterance = null;
            announce("Model finished. Compare it with your own take.");
          }
        };
        utterance.onerror = (event) => {
          if (event.error !== "canceled" && event.error !== "interrupted") {
            if (fallback) fallback.hidden = false;
            announce("Voice playback failed. Use the visible transcript instead.");
          }
        };
        window.speechSynthesis.speak(utterance);
      };

      listenButton?.addEventListener("click", () => playModel(1));
      slowButton?.addEventListener("click", () => playModel(0.78));
    });

    prevButton.addEventListener("click", () => {
      showStep(activeIndex - 1);
    });

    nextButton.addEventListener("click", () => {
      if (activeIndex === steps.length - 1) {
        const record = getRecord();
        const confidence = Number(record.lastConfidence);
        const hasConfidence = Number.isInteger(confidence) && confidence >= 1 && confidence <= 5;
        const savedChecks = Array.isArray(record.selfChecks)
          ? record.selfChecks.filter((value) => typeof value === "string")
          : [];

        if (!hasConfidence && !savedChecks.length) {
          announce("Before finishing, choose a confidence score or save at least one self-check.");
          const focusTarget = confidenceButtons[0] || selfChecks[0];
          focusTarget?.focus();
          return;
        }

        const now = new Date().toISOString();
        const saved = markStarted({
          activeStep: activeIndex,
          completed: true,
          completedAt: record.completedAt || now,
        });
        if (!saved) {
          const inMemoryRecord = getRecord();
          const unfinishedRecord = {
            ...inMemoryRecord,
            completed: false,
            completedAt: undefined,
          };
          currentRunRecord = unfinishedRecord;
          progress = {
            ...progress,
            [slug]: unfinishedRecord,
          };
          syncProgressUi();
          announce("Mission finished in this tab, but the browser could not save it. Enable site storage, then finish again.");
          return;
        }
        const detail = {
          slug,
          confidence: hasConfidence ? confidence : null,
        };
        const listeningTotal = Number(root.dataset.listeningTotal || 0);

        if (Number.isInteger(listeningTotal) && listeningTotal > 0) {
          detail.listening = {
            score: Number(root.dataset.listeningFirstAttemptScore || 0),
            finalScore: Number(root.dataset.listeningScore || 0),
            total: listeningTotal,
            assisted: root.dataset.listeningAssisted === "true",
          };
        }

        const completionAccepted = root.dispatchEvent(new CustomEvent("english-library:speaking-complete", {
          bubbles: true,
          cancelable: true,
          detail,
        }));
        if (!completionAccepted) {
          nextButton.textContent = "Retry saving course step";
          nextButton.disabled = false;
          announce("Mission saved, but course progress could not be saved. Try Finish mission again.");
          return;
        }
        nextButton.textContent = "Mission completed";
        nextButton.disabled = true;
        announce("Mission completed. Your progress is saved on this device.");
        return;
      }

      showStep(activeIndex + 1);
    });

    steps.forEach((step) => {
      const seconds = Number(step.dataset.stepSeconds || 0);
      const timerButton = step.querySelector("[data-start-timer]");

      if (!seconds || !timerButton) {
        return;
      }

      timerButton.addEventListener("click", () => {
        markStarted();
        startTimer(step);
      });
    });

    recordingPanel?.querySelector("[data-record]")?.addEventListener("click", startRecording);
    recordingPanel?.querySelector("[data-stop-recording]")?.addEventListener("click", () => stopRecording(true));
    recordingPanel?.querySelector("[data-replace-recording]")?.addEventListener("click", startRecording);
    recordingPanel?.querySelector("[data-no-recording]")?.addEventListener("change", (event) => {
      const selected = event.currentTarget.checked;
      if (selected && mediaRecorder?.state === "recording") {
        stopRecording();
      }
      markStarted({ noRecording: selected });
      announce(selected
        ? "Timer-only practice selected. Speak aloud when you are ready."
        : "Recording practice selected.");
    });

    prepNotes?.addEventListener("input", (event) => {
      markStarted({ prepNotes: event.currentTarget.value.slice(0, 180) });
    });

    selfChecks.forEach((input) => {
      input.addEventListener("change", () => {
        const checked = selfChecks.filter((item) => item.checked).map((item) => item.value);
        markStarted({ selfChecks: checked });
        announce(checked.length ? "Self-check saved." : "Self-check cleared.");
      });
    });

    confidenceButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const confidence = Number(button.dataset.confidence);

        if (!Number.isInteger(confidence) || confidence < 1 || confidence > 5) {
          return;
        }

        const now = new Date().toISOString();
        markStarted({
          lastConfidence: confidence,
          ratedAt: now,
        });
        announce(`Confidence ${confidence} out of 5 saved. Use Finish mission when you are ready.`);
      });
    });

    root.addEventListener("english-library:listening-updated", () => {
      progress = readSpeakingProgress();
      const storedRecord = selectCurrentRecord(progress[slug]);
      if (!shouldStartFreshRun || storedRecord.startedAt === currentRunRecord.startedAt) {
        currentRunRecord = storedRecord;
      }
      syncProgressUi();
      const listeningStepIndex = steps.findIndex((step) => step.querySelector("[data-active-listening]"));

      if (
        listeningStepIndex >= 0 &&
        activeIndex > listeningStepIndex &&
        root.dataset.listeningReady !== "true"
      ) {
        showStep(listeningStepIndex, false, true);
      }
      syncNextControl();
    });

    window.addEventListener("pagehide", () => {
      disposing = true;
      clearTimer();
      cancelSpeech();
      root.querySelectorAll("audio").forEach((audio) => audio.pause());
      if (mediaRecorder && mediaRecorder.state !== "inactive") {
        mediaRecorder.onstop = null;
        mediaRecorder.stop();
      }
      stopStream();
      revokeAudio();
    }, { once: true });

    resetTimers();
    syncProgressUi();
    showStep(activeIndex, false, false);
  });
</script>

<script>
  import {
    answerListeningCheck,
    canUnlockListeningReflect,
    chooseListeningTranscriptAlternative,
    getListeningState,
    hasAttemptedAllListeningChecks,
    revealListeningTranscript,
    setListeningShadowed,
    startListeningPlayback,
  } from "../lib/listening-progress";
  import { SPEAKING_PROGRESS_KEY } from "../lib/speaking";

  type SpeakingRecord = Record<string, unknown>;
  type SpeakingProgress = Record<string, SpeakingRecord>;

  const isRecord = (value: unknown): value is SpeakingRecord =>
    Boolean(value) && typeof value === "object" && !Array.isArray(value);

  const readProgress = (): SpeakingProgress => {
    try {
      const raw = localStorage.getItem(SPEAKING_PROGRESS_KEY);
      const parsed = raw ? JSON.parse(raw) : {};
      return isRecord(parsed) ? parsed as SpeakingProgress : {};
    } catch {
      return {};
    }
  };

  const writeProgress = (progress: SpeakingProgress): boolean => {
    try {
      localStorage.setItem(SPEAKING_PROGRESS_KEY, JSON.stringify(progress));
      window.dispatchEvent(new CustomEvent("english-library:speaking-progress"));
      return true;
    } catch {
      return false;
    }
  };

  document.querySelectorAll<HTMLElement>("[data-mission-player]").forEach((root) => {
    const panel = root.querySelector<HTMLElement>("[data-active-listening]");
    const slug = root.dataset.missionSlug;
    const revision = Number(root.dataset.missionRevision ?? 1);

    if (!panel || !slug) return;

    const checks = [...panel.querySelectorAll<HTMLElement>("[data-listening-check]")];
    const requiredCheckIds = checks
      .map((check) => check.dataset.checkId?.trim() ?? "")
      .filter(Boolean);
    const listenButton = panel.querySelector<HTMLButtonElement>("[data-active-listen]");
    const slowButton = panel.querySelector<HTMLButtonElement>("[data-active-listen-slow]");
    const transcriptButton = panel.querySelector<HTMLButtonElement>("[data-use-listening-transcript]");
    const revealButton = panel.querySelector<HTMLButtonElement>("[data-reveal-listening-transcript]");
    const fallback = panel.querySelector<HTMLElement>("[data-active-listening-fallback]");
    const checksPanel = panel.querySelector<HTMLElement>("[data-active-listening-checks]");
    const assistTranscript = panel.querySelector<HTMLElement>("[data-listening-assist-transcript]");
    const transcript = panel.querySelector<HTMLElement>("[data-active-transcript]");
    const shadowPanel = panel.querySelector<HTMLElement>("[data-listening-shadow-panel]");
    const shadowCheckbox = panel.querySelector<HTMLInputElement>("[data-listening-shadowed]");
    const playShadowButton = panel.querySelector<HTMLButtonElement>("[data-play-shadow-line]");
    const revealNote = panel.querySelector<HTMLElement>("[data-listening-reveal-note]");
    const stageValue = panel.querySelector<HTMLElement>("[data-active-listening-stage]");
    const scoreValue = panel.querySelector<HTMLElement>("[data-listening-score]");
    const liveStatus = root.querySelector<HTMLElement>("[data-mission-status]");
    const hasSpeechPlayback =
      "speechSynthesis" in window && "SpeechSynthesisUtterance" in window;
    const selectCurrentRecord = (value: unknown): SpeakingRecord => {
      const record = isRecord(value) ? value : {};
      const savedRevision = Number(record.revision ?? 1);
      return savedRevision === revision ? record : {};
    };
    const freshRunActive = root.dataset.freshRunActive === "true";
    const freshRecord = (root as HTMLElement & { __freshSpeakingRecord?: unknown }).__freshSpeakingRecord;
    let localRecord: SpeakingRecord = selectCurrentRecord(
      freshRunActive && isRecord(freshRecord) ? freshRecord : readProgress()[slug],
    );
    let currentUtterance: SpeechSynthesisUtterance | null = null;

    const announce = (message: string) => {
      if (liveStatus) liveStatus.textContent = message;
    };

    const getStoredRecord = (): SpeakingRecord => {
      const record = selectCurrentRecord(readProgress()[slug]);
      return Object.keys(record).length ? record : localRecord;
    };

    const persist = (
      transition: (record: SpeakingRecord) => SpeakingRecord,
      message?: string,
    ) => {
      const progress = readProgress();
      const stored = selectCurrentRecord(progress[slug]);
      const storedMatchesFreshRun = stored.startedAt === localRecord.startedAt;
      const previous = freshRunActive && !storedMatchesFreshRun
        ? localRecord
        : Object.keys(stored).length ? stored : localRecord;
      const now = new Date().toISOString();
      const transitioned = transition(previous);
      localRecord = {
        ...transitioned,
        revision,
        startedAt: typeof previous.startedAt === "string" ? previous.startedAt : now,
        lastPlayedAt: now,
      };
      const saved = writeProgress({ ...progress, [slug]: localRecord });

      sync(localRecord);
      announce(saved ? (message ?? "Listening progress saved.") : "Progress changed, but this browser could not save it.");
    };

    const sync = (record: SpeakingRecord = getStoredRecord()) => {
      localRecord = record;
      const state = getListeningState(record);
      const canStartChecks = state.played || state.assisted;
      const attemptedAll = hasAttemptedAllListeningChecks(record, requiredCheckIds);
      const ready = canUnlockListeningReflect(record, requiredCheckIds);
      const score = requiredCheckIds.filter((checkId) => state.correctIds.includes(checkId)).length;
      const firstAttemptScore = requiredCheckIds.filter((checkId) =>
        state.firstAttemptCorrectIds.includes(checkId)
      ).length;

      if (checksPanel) checksPanel.hidden = !canStartChecks;
      if (assistTranscript) assistTranscript.hidden = !state.assisted || state.revealed;
      if (transcript) transcript.hidden = !state.revealed;
      if (shadowPanel) shadowPanel.hidden = !state.revealed;
      if (shadowCheckbox) shadowCheckbox.checked = state.shadowed;

      if (transcriptButton) {
        transcriptButton.disabled = state.assisted;
        transcriptButton.textContent = state.assisted
          ? "Transcript open · Tekstas atvertas"
          : "Read transcript · Skaityti tekstą";
      }

      if (revealButton) {
        revealButton.hidden = state.revealed || !attemptedAll;
        revealButton.disabled = !attemptedAll;
      }

      if (scoreValue) scoreValue.textContent = `${score}/${requiredCheckIds.length} correct`;

      checks.forEach((check) => {
        const checkId = check.dataset.checkId ?? "";
        const responseId = state.responses[checkId];
        const attempted = state.attemptedIds.includes(checkId);
        const correct = state.correctIds.includes(checkId);
        const feedback = check.querySelector<HTMLElement>("[data-listening-feedback]");
        const feedbackEn = check.querySelector<HTMLElement>("[data-listening-feedback-en]");
        const feedbackLt = check.querySelector<HTMLElement>("[data-listening-feedback-lt]");

        check.querySelectorAll<HTMLInputElement>('input[type="radio"]').forEach((input) => {
          input.checked = input.value === responseId;
        });

        check.classList.toggle("is-correct", attempted && correct);
        check.classList.toggle("is-incorrect", attempted && !correct);

        if (feedback) {
          feedback.hidden = !attempted;
          feedback.classList.toggle("is-correct", correct);
        }
        if (feedbackEn) {
          const explanation = correct || state.revealed
            ? check.dataset.feedback
            : check.dataset.hint;
          feedbackEn.textContent = attempted
            ? `${correct ? "Correct." : "Try again."} ${explanation ?? ""}`
            : "";
        }
        if (feedbackLt) {
          const explanation = correct || state.revealed
            ? check.dataset.feedbackLt
            : check.dataset.hintLt;
          feedbackLt.textContent = attempted
            ? `${correct ? "Teisingai." : "Bandykite dar kartą."} ${explanation ?? ""}`
            : "";
        }
      });

      if (revealNote) {
        revealNote.textContent = ready
          ? "Listening step complete. Continue to Reflect. / Klausymo žingsnis baigtas. Tęskite apmąstymo žingsnį."
          : state.revealed && score < requiredCheckIds.length
            ? "Use the hints and transcript to correct both answers. / Pasinaudokite užuominomis ir tekstu, tada pataisykite abu atsakymus."
            : state.revealed && !state.shadowed
              ? "Read or listen to the highlighted line, then repeat it aloud. / Perskaitykite arba išklausykite pažymėtą sakinį, tada garsiai jį pakartokite."
              : attemptedAll
                ? "Both answers tried. Show the transcript. / Abu atsakymai pažymėti. Parodykite tekstą."
                : canStartChecks
                  ? `Try both questions: ${state.attemptedIds.length}/${requiredCheckIds.length}. / Atsakykite į abu klausimus.`
                  : "Listen or read the transcript to open the questions. / Klausykitės arba skaitykite tekstą.";
      }

      if (stageValue) {
        stageValue.textContent = ready
          ? "Complete · Baigta"
          : state.revealed
            ? `${score}/${requiredCheckIds.length} correct · read or listen, then repeat`
            : attemptedAll
              ? "Text ready · Tekstas paruoštas"
              : canStartChecks
                ? "Questions open · Klausimai atverti"
                : "Ready · Pasiruošta";
      }

      root.dataset.listeningReady = String(ready);
      root.dataset.listeningScore = String(score);
      root.dataset.listeningFirstAttemptScore = String(firstAttemptScore);
      root.dataset.listeningTotal = String(requiredCheckIds.length);
      root.dataset.listeningAssisted = String(state.assisted);
      root.dispatchEvent(new CustomEvent("english-library:listening-updated"));
    };

    if (listenButton) listenButton.hidden = !hasSpeechPlayback;
    if (slowButton) slowButton.hidden = !hasSpeechPlayback;
    if (playShadowButton) playShadowButton.hidden = !hasSpeechPlayback;
    if (fallback) fallback.hidden = hasSpeechPlayback;

    const playModel = (rate: number) => {
      const modelText = panel.dataset.speechText?.trim();

      if (!hasSpeechPlayback || !modelText) {
        if (fallback) fallback.hidden = false;
        announce("Voice is unavailable. Read the transcript to continue.");
        transcriptButton?.focus();
        return;
      }

      window.speechSynthesis.cancel();
      const utterance = new SpeechSynthesisUtterance(modelText);
      utterance.lang = "en-GB";
      utterance.rate = rate;
      utterance.onstart = () => {
        currentUtterance = utterance;
        announce(rate < 1 ? "Playing slowly. Listen to the end." : "Playing the model. Listen to the end.");
      };
      utterance.onend = () => {
        if (currentUtterance === utterance) {
          currentUtterance = null;
          persist(
            (record) => startListeningPlayback(record),
            "Model finished. Answer the two questions. / Įrašas baigtas. Atsakykite į du klausimus.",
          );
        }
      };
      utterance.onerror = (event) => {
        if (event.error !== "canceled" && event.error !== "interrupted") {
          if (fallback) fallback.hidden = false;
          announce("Voice failed. Read the transcript to continue.");
        }
      };
      window.speechSynthesis.speak(utterance);
    };

    listenButton?.addEventListener("click", () => playModel(1));
    slowButton?.addEventListener("click", () => playModel(0.78));

    transcriptButton?.addEventListener("click", () => {
      if (hasSpeechPlayback) window.speechSynthesis.cancel();
      currentUtterance = null;
      persist(
        (record) => chooseListeningTranscriptAlternative(record),
        "Transcript opened. Answer the two questions. / Tekstas atvertas. Atsakykite į du klausimus.",
      );
      window.requestAnimationFrame(() => assistTranscript?.focus?.());
    });

    checks.forEach((check) => {
      check.querySelectorAll<HTMLInputElement>('input[type="radio"]').forEach((input) => {
        input.addEventListener("change", () => {
          if (!input.checked) return;
          const checkId = check.dataset.checkId ?? "";
          const answerId = check.dataset.answerId ?? "";
          const isCorrect = input.value === answerId;
          persist(
            (record) => answerListeningCheck(record, checkId, input.value, answerId),
            isCorrect
              ? "Correct. Read the feedback, then continue."
              : "Not yet. Read the feedback and try another answer.",
          );
        });
      });
    });

    revealButton?.addEventListener("click", () => {
      persist(
        (record) => revealListeningTranscript(record, requiredCheckIds),
        "Transcript shown. Correct the answers, then read or listen to the highlighted line and repeat it aloud.",
      );
      window.requestAnimationFrame(() => transcript?.focus?.());
    });

    shadowCheckbox?.addEventListener("change", () => {
      persist(
        (record) => setListeningShadowed(record, shadowCheckbox.checked),
        shadowCheckbox.checked
          ? "Repeat practice saved. Finish any corrections, then continue to Reflect."
          : "Repeat practice cleared. Finish it again before you continue.",
      );
    });

    playShadowButton?.addEventListener("click", () => {
      const shadowText = panel.dataset.shadowText?.trim();
      if (!hasSpeechPlayback || !shadowText) return;

      window.speechSynthesis.cancel();
      const utterance = new SpeechSynthesisUtterance(shadowText);
      utterance.lang = "en-GB";
      utterance.rate = 0.86;
      utterance.onstart = () => {
        currentUtterance = utterance;
        announce("Listen to the line, then repeat it immediately.");
      };
      utterance.onend = () => {
        if (currentUtterance === utterance) {
          currentUtterance = null;
          announce("Now repeat the line aloud and copy the rhythm.");
        }
      };
      window.speechSynthesis.speak(utterance);
    });

    window.addEventListener("storage", (event) => {
      if (event.key !== SPEAKING_PROGRESS_KEY) return;
      const stored = selectCurrentRecord(readProgress()[slug]);
      if (freshRunActive && stored.startedAt !== localRecord.startedAt) return;
      localRecord = stored;
      sync(stored);
    });

    window.addEventListener("pagehide", () => {
      if (currentUtterance) window.speechSynthesis.cancel();
      currentUtterance = null;
    }, { once: true });

    sync(localRecord);
  });
</script>
