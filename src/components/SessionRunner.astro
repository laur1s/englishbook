---
import LearningCycle from "./LearningCycle.astro";
import MissionPlayer from "./MissionPlayer.astro";
import type { CourseModule, CourseSession } from "../lib/course-path";
import type { SpeakingMissionEntry } from "../lib/content";
import { coursePath } from "../lib/course-path";
import { withBase } from "../lib/constants";

type Props = {
  module: CourseModule;
  session: CourseSession;
  nextSessionId?: string;
  speakingEntry?: SpeakingMissionEntry;
};

const { module, session, nextSessionId, speakingEntry } = Astro.props;
const nextHref = nextSessionId ? withBase(`/learn/${nextSessionId}`) : withBase("/learn");
const contentHref = session.kind === "content" ? withBase(session.href) : undefined;
const stageDescriptions = {
  context: "Read or explore the source first. Notice meaning and useful language before you study the rules.",
  learn: "Work through the focused lesson. Say examples aloud and try the exercises before checking answers.",
  practice: "Answer one item at a time. Use the feedback to correct mistakes while the language is still active.",
  speak: "Complete the speaking mission aloud. Aim for clear meaning first, then a smoother second attempt.",
  review: "Recall the language without notes. The result schedules the skills that need another review.",
} as const;
const contentActionLabels = {
  context: "Open reading",
  learn: "Open lesson",
  practice: "Open practice",
  speak: "Open speaking mission",
  review: "Open review",
} as const;
const completeActionLabels = {
  context: "I finished the reading",
  learn: "I finished the lesson",
  practice: "I finished the practice",
  speak: "I finished the mission",
  review: "I finished the review",
} as const;
const serializeForScript = (value: unknown) => JSON.stringify(value).replace(/</g, "\\u003c");
const runnerData = serializeForScript({
  revision: session.revision,
  module: { id: module.id, order: module.order, title: module.title },
  moduleSessions: module.sessions.map((item) => ({
    id: item.id,
    stage: item.stage,
    revision: item.revision,
    required: item.required,
  })),
  pathSessions: coursePath.modules.flatMap((courseModule) =>
    courseModule.sessions.map((item) => ({
      id: item.id,
      revision: item.revision,
      required: item.required,
    })),
  ),
  session: {
    id: session.id,
    kind: session.kind,
    stage: session.stage,
    title: session.title,
    minutes: session.minutes,
    skillRefs: session.skillRefs,
    ...(session.kind === "practice"
      ? {
          ...(session.unitIds ? { unitIds: session.unitIds } : { unitId: session.unitId }),
          mode: session.mode,
          count: session.count,
        }
      : {}),
  },
  nextSessionId: nextSessionId ?? null,
  nextHref,
  dashboardHref: withBase("/learn"),
});
const chevronIcon = '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 5 7 7-7 7" /></svg>';
const clockIcon = '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8.5" /><path d="M12 7.5V12l3 2" /></svg>';
---

<section class="learning-shell session-runner-shell" data-session-runner>
  <header class="session-runner-header">
    <div>
      <p class="learning-module-name">Module {module.order} · {module.title}</p>
      <h1>{session.title}</h1>
      <p class="learning-duration">
        <Fragment set:html={clockIcon} />
        <span>{session.stage[0].toUpperCase() + session.stage.slice(1)} · {session.minutes} min</span>
      </p>
    </div>

    <LearningCycle
      sessions={module.sessions}
      activeSessionId={session.id}
      className="runner-cycle"
    />

    <a class="runner-exit-link" href={withBase("/learn")}>Exit session</a>
  </header>

  {session.kind === "content" && session.stage === "speak" && speakingEntry ? (
    <section class="embedded-speaking-session" data-speaking-session aria-label={session.title}>
      <MissionPlayer entry={speakingEntry} relatedHref={withBase(`/a2/${module.unitSlug}`)} relatedTitle={module.title} />
      <p class="runner-saved-note" data-saved-note>
        Your step, notes, and result are saved on this device. Audio stays in this tab only.
      </p>
    </section>
  ) : session.kind === "content" ? (
    <section class="content-session-card" data-content-session aria-labelledby="content-session-title">
      <p class="learning-label">{session.stage === "speak" ? "Speak aloud" : "Open the source"}</p>
      <h2 id="content-session-title">{session.title}</h2>
      <p>{stageDescriptions[session.stage]}</p>
      <div class="content-session-actions">
        <a class="learning-primary-button" href={contentHref}>
          {contentActionLabels[session.stage]}
          <Fragment set:html={chevronIcon} />
        </a>
        <button class="learning-outline-button" type="button" data-complete-content>
          {completeActionLabels[session.stage]}
        </button>
      </div>
      <p class="runner-saved-note" data-saved-note>Progress is saved on this device.</p>
    </section>
  ) : (
    <section class="runner-question-card" data-practice-session aria-labelledby="practice-question">
      <div class="question-progress">
        <span data-question-count>Preparing your practice set…</span>
        <div
          class="question-progress-track"
          role="progressbar"
          aria-label="Practice progress"
          aria-valuemin="1"
          aria-valuemax="1"
          aria-valuenow="1"
          data-question-progress-track
        >
          <span class="question-progress-fill" data-question-progress style="width: 0%" />
        </div>
      </div>

      <p class="pack-update-notice" data-pack-update-notice role="status" hidden>
        This practice content changed, so the saved set restarted with the newest questions.
      </p>

      <p class="question-objective" data-question-objective>Get ready to answer</p>
      <h2 id="practice-question" data-question-prompt tabindex="-1">Loading your first question…</h2>
      <p id="practice-question-lt" lang="lt" data-question-lt hidden></p>

      <fieldset class="answer-fieldset" data-answer-container aria-labelledby="practice-question"></fieldset>

      <div class="feedback-panel" data-feedback role="status" aria-live="polite" hidden>
        <strong data-feedback-title></strong>
        <p data-feedback-copy></p>
        <p class="lt-text" lang="lt" data-feedback-lt></p>
      </div>

      <div class="runner-actions">
        <button class="learning-outline-button" type="button" data-toggle-hint aria-expanded="false" aria-controls="practice-question-lt">
          LT&nbsp; Show hint
        </button>
        <button class="learning-text-action" type="button" data-skip-item>Skip for now</button>
        <button class="answer-action primary" type="button" data-check-answer disabled>
          <span>Check answer</span>
          <Fragment set:html={chevronIcon} />
        </button>
      </div>
      <p class="runner-saved-note" data-saved-note>Each answer is saved on this device.</p>

      <noscript>
        <p>Interactive practice needs JavaScript. Open the related A2 lesson from the course map instead.</p>
      </noscript>
    </section>
  )}

  {session.kind === "practice" && (
    <section class="session-complete-card repair-card" data-repair-card aria-labelledby="repair-title" tabindex="-1" hidden>
      <div class="session-score" data-repair-score>0 / 0</div>
      <p class="learning-label">One short repair loop</p>
      <h2 id="repair-title">Make the mistakes stick</h2>
      <p data-repair-copy>Correct the answers you missed, then the next step will unlock.</p>
      <div class="complete-actions">
        <button class="learning-primary-button" type="button" data-start-repair>
          <span data-repair-action>Repair mistakes</span>
          <Fragment set:html={chevronIcon} />
        </button>
        <a class="learning-text-action" href={withBase("/learn")}>Save and return later</a>
      </div>
    </section>
  )}

  <section class="session-complete-card" data-session-complete aria-labelledby="session-complete-title" tabindex="-1" hidden>
    <div class="session-score" data-session-score hidden>0 / 0</div>
    <p class="learning-label">Session saved</p>
    <h2 id="session-complete-title" data-complete-title>Step complete</h2>
    <p data-complete-copy>Your next focused step is ready.</p>
    <div class="complete-actions">
      <a class="learning-primary-button" href={nextHref} data-continue-link>
        <span data-continue-label>{nextSessionId ? "Continue to next step" : "Return to your path"}</span>
        <Fragment set:html={chevronIcon} />
      </a>
      {session.kind === "content" && contentHref && (
        <a class="learning-outline-button" href={contentHref}>Open source again</a>
      )}
      {session.kind === "practice" && (
        <>
          <button class="learning-outline-button" type="button" data-retry-pack>Retry this set</button>
          <button class="learning-text-action" type="button" data-new-pack>Create a new set</button>
        </>
      )}
    </div>
  </section>

  <script is:inline type="application/json" data-runner-data set:html={runnerData} />
</section>

<script>
  import {
    beginPracticeRepair,
    beginPracticeRun,
    completeLearningSession,
    isLearningSessionUnlocked,
    nextPracticeAttempt,
    readLearningProgress,
    saveLearningResponse,
    startLearningSession,
    writeLearningProgress,
  } from "../lib/learning-progress";
  import {
    generatePracticePack,
    getPracticeItems,
    practiceCatalog,
    scorePracticeItem,
    type PracticeItem,
    type PracticeMode,
    type PracticePack,
  } from "../lib/practice";

  type RunnerSession = {
    id: string;
    kind: "content" | "practice";
    stage: "context" | "learn" | "practice" | "speak" | "review";
    title: string;
    minutes: number;
    skillRefs: string[];
    unitId?: string;
    unitIds?: string[];
    mode?: "guided" | "standard" | "review" | "checkpoint";
    count?: number;
  };

  type RunnerData = {
    revision: number;
    module: { id: string; order: number; title: string };
    moduleSessions: Array<{
      id: string;
      stage: RunnerSession["stage"];
      revision: number;
      required: boolean;
    }>;
    pathSessions: Array<{ id: string; revision: number; required: boolean }>;
    session: RunnerSession;
    nextSessionId: string | null;
    nextHref: string;
    dashboardHref: string;
  };

  const SKIPPED_RESPONSE = "__skipped__";

  const setText = (root: Element, selector: string, value: string) => {
    const element = root.querySelector(selector);
    if (element) element.textContent = value;
  };

  const asElement = <T extends Element>(root: Element, selector: string) =>
    root.querySelector(selector) as T | null;

  document.querySelectorAll("[data-session-runner]").forEach((root) => {
    const dataElement = root.querySelector("[data-runner-data]");
    let data: RunnerData | null = null;

    try {
      data = JSON.parse(dataElement?.textContent || "null") as RunnerData | null;
    } catch {
      data = null;
    }

    if (!data) return;

    const session = data.session;
    const contentView = asElement<HTMLElement>(root, "[data-content-session]");
    const speakingView = asElement<HTMLElement>(root, "[data-speaking-session]");
    const practiceView = asElement<HTMLElement>(root, "[data-practice-session]");
    const completeView = asElement<HTMLElement>(root, "[data-session-complete]");
    const completeButton = asElement<HTMLButtonElement>(root, "[data-complete-content]");
    const scoreElement = asElement<HTMLElement>(root, "[data-session-score]");
    const continueLink = asElement<HTMLAnchorElement>(root, "[data-continue-link]");
    const continueLabel = asElement<HTMLElement>(root, "[data-continue-label]");
    const savedNotes = [...root.querySelectorAll("[data-saved-note]")];
    const pageStartedAt = Date.now();
    const isFreshRequest = new URL(window.location.href).searchParams.get("fresh") === "1";
    let progress = readLearningProgress(window.localStorage);
    const sessionIsUnlocked = isLearningSessionUnlocked(
      data.pathSessions,
      progress,
      session.id,
    );

    if (!sessionIsUnlocked) {
      window.location.replace(data.dashboardHref);
      return;
    }

    const sessionRecordOnEntry = progress.sessions[session.id];
    const sessionWasCompletedOnEntry = sessionRecordOnEntry?.status === "completed" &&
      sessionRecordOnEntry.revision === data.revision;
    const activeRecordOnEntry = progress.activeSessionId
      ? progress.sessions[progress.activeSessionId]
      : undefined;
    const canAdvancePath = !progress.activeSessionId ||
      progress.activeSessionId === session.id ||
      activeRecordOnEntry?.status === "completed";

    const persist = () => {
      const saved = writeLearningProgress(window.localStorage, progress);
      savedNotes.forEach((note) => {
        note.textContent = saved
          ? "Progress is saved on this device."
          : "This browser did not allow progress to be saved.";
      });
      window.dispatchEvent(new CustomEvent("english-library:progress"));
    };

    const completedMinutes = () => {
      const record = progress.sessions[session.id];
      const startedAt = record?.practiceRun?.startedAt ?? (
        sessionWasCompletedOnEntry ? new Date(pageStartedAt).toISOString() : record?.startedAt
      );
      const elapsedMinutes = startedAt
        ? Math.ceil(Math.max(0, Date.now() - Date.parse(startedAt)) / 60_000)
        : 1;
      return Math.max(1, Math.min(session.minutes, elapsedMinutes));
    };

    const syncCycle = () => {
      root.querySelectorAll("[data-cycle-session]").forEach((step) => {
        const stepId = (step as HTMLElement).dataset.cycleSession || "";
        const stepProgress = progress.sessions[stepId];
        const stepRevision = data.moduleSessions.find((item) => item.id === stepId)?.revision;
        const completed = stepProgress?.status === "completed" &&
          stepProgress.revision === stepRevision;
        const current = !completed && stepId === session.id;
        const status = step.querySelector("[data-cycle-status]");
        step.classList.toggle("completed", completed);
        step.classList.toggle("current", current);
        if (status) status.textContent = completed ? "Done" : current ? "In progress" : "Upcoming";
      });
    };

    const showCompletion = (score?: number, total?: number) => {
      if (contentView) contentView.hidden = true;
      if (speakingView) speakingView.hidden = true;
      if (practiceView) practiceView.hidden = true;
      if (completeView) completeView.hidden = false;
      if (scoreElement) {
        const hasScore = Number.isFinite(score) && Number.isFinite(total);
        scoreElement.hidden = !hasScore;
        if (hasScore) scoreElement.textContent = `${score} / ${total}`;
      }
      if (score !== undefined && total) {
        const percentage = Math.round((score / total) * 100);
        setText(root, "[data-complete-title]", percentage >= 75 ? "Strong work" : "Practice saved");
        setText(
          root,
          "[data-complete-copy]",
          percentage >= 75
            ? `You answered ${score} of ${total} correctly. Continue while the language is active.`
            : `You answered ${score} of ${total} correctly. Review the feedback, then retry or continue.`,
        );
      }
      const currentModuleIndex = data.moduleSessions.findIndex((item) => item.id === session.id);
      const nextIncompleteInModule = data.moduleSessions
        .slice(currentModuleIndex + 1)
        .find((item) => item.required && (
          progress.sessions[item.id]?.status !== "completed" ||
          progress.sessions[item.id]?.revision !== item.revision
        ));
      if (continueLink && (!canAdvancePath || sessionWasCompletedOnEntry)) {
        continueLink.href = data.dashboardHref;
        if (continueLabel) continueLabel.textContent = "Return to your path";
      } else if (continueLink && nextIncompleteInModule) {
        continueLink.href = `${data.dashboardHref.replace(/\/$/, "")}/${nextIncompleteInModule.id}`;
        if (continueLabel) continueLabel.textContent = "Continue to next step";
      }
      syncCycle();
    };

    progress = startLearningSession(progress, session.id, data.revision);
    persist();
    syncCycle();

    if (session.kind === "content") {
      if (progress.sessions[session.id]?.status === "completed" && !isFreshRequest) {
        showCompletion();
      }

      completeButton?.addEventListener("click", () => {
        progress = completeLearningSession(
          progress,
          session.id,
          {
            revision: data?.revision,
            minutes: completedMinutes(),
            activityType: session.stage === "speak" ? "speaking" : "content",
            ...(!sessionWasCompletedOnEntry && canAdvancePath
              ? { nextSessionId: data?.nextSessionId }
              : {}),
          },
        );
        persist();
        showCompletion();
        completeView?.focus({ preventScroll: true });
      });

      root.addEventListener("english-library:speaking-complete", () => {
        if (session.stage !== "speak") return;
        progress = completeLearningSession(
          progress,
          session.id,
          {
            revision: data?.revision,
            minutes: completedMinutes(),
            activityType: "speaking",
            ...(!sessionWasCompletedOnEntry && canAdvancePath
              ? { nextSessionId: data?.nextSessionId }
              : {}),
          },
        );
        persist();
        showCompletion();
        completeView?.focus({ preventScroll: true });
      });

      return;
    }

    if ((!session.unitId && !session.unitIds?.length) || !session.mode || !practiceView) return;

    const answerContainer = asElement<HTMLElement>(root, "[data-answer-container]");
    const promptElement = asElement<HTMLElement>(root, "[data-question-prompt]");
    const ltPromptElement = asElement<HTMLElement>(root, "[data-question-lt]");
    const progressFill = asElement<HTMLElement>(root, "[data-question-progress]");
    const progressTrack = asElement<HTMLElement>(root, "[data-question-progress-track]");
    const feedback = asElement<HTMLElement>(root, "[data-feedback]");
    const feedbackLt = asElement<HTMLElement>(root, "[data-feedback-lt]");
    const hintButton = asElement<HTMLButtonElement>(root, "[data-toggle-hint]");
    const skipButton = asElement<HTMLButtonElement>(root, "[data-skip-item]");
    const checkButton = asElement<HTMLButtonElement>(root, "[data-check-answer]");
    const checkButtonLabel = checkButton?.querySelector("span");
    const retryButton = asElement<HTMLButtonElement>(root, "[data-retry-pack]");
    const newPackButton = asElement<HTMLButtonElement>(root, "[data-new-pack]");
    const packUpdateNotice = asElement<HTMLElement>(root, "[data-pack-update-notice]");
    const repairView = asElement<HTMLElement>(root, "[data-repair-card]");
    const startRepairButton = asElement<HTMLButtonElement>(root, "[data-start-repair]");
    const supportedMode: PracticeMode = session.mode;
    const requestedUnitIds = session.unitIds?.length
      ? session.unitIds
      : [session.unitId as string];
    const availableCount = requestedUnitIds.reduce(
      (total, unitId) => total + getPracticeItems(unitId).length,
      0,
    );
    const requestedCount = Math.min(session.count ?? availableCount, availableCount);
    const availableItems = requestedUnitIds.flatMap((unitId) => getPracticeItems(unitId));
    const availableItemIds = new Set(availableItems.map((item) => item.id));
    const availableObjectiveIds = new Set(availableItems.map((item) => item.objectiveId));
    const initialPriorityItemIds = progress.mistakeItemIds.filter((id) => availableItemIds.has(id));
    const initialTargetObjectiveIds = Object.entries(progress.skills)
      .filter(([id, skill]) =>
        availableObjectiveIds.has(id) &&
        (skill.strength < 0.8 || Date.parse(skill.dueAt) <= Date.now())
      )
      .sort((left, right) => {
        const dueDifference = Date.parse(left[1].dueAt) - Date.parse(right[1].dueAt);
        return dueDifference || left[1].strength - right[1].strength || right[1].lapses - left[1].lapses;
      })
      .map(([id]) => id);
    let pack!: PracticePack;
    let packRecentItemIds: string[] = [];
    let packWasUpdated = false;
    let currentIndex = 0;
    let selectedResponse = "";
    let checked = false;
    let answerWasCorrect = false;
    let runResponses: Record<string, string> = {};

    const createPack = (
      attempt: number,
      recentItemIds: readonly string[],
      targetObjectiveIds: readonly string[] = initialTargetObjectiveIds,
      priorityItemIds: readonly string[] = initialPriorityItemIds,
    ) =>
      generatePracticePack({
        ...(session.unitIds?.length
          ? { unitIds: session.unitIds }
          : { unitId: session.unitId as string }),
        mode: supportedMode,
        count: requestedCount,
        attempt,
        recentItemIds,
        targetObjectiveIds,
        priorityItemIds,
      });

    const resetToPack = (targetPack: PracticePack, recentItemIds: readonly string[]) => {
      packRecentItemIds = [...recentItemIds];
      progress = beginPracticeRun(
        progress,
        session.id,
        {
          attempt: targetPack.attempt,
          recentItemIds: packRecentItemIds,
          packId: targetPack.id,
          itemRefs: targetPack.items.map((item) => ({
            id: item.id,
            revision: item.revision,
          })),
          targetObjectiveIds: targetPack.targetObjectiveIds,
          priorityItemIds: targetPack.priorityItemIds,
        },
        data?.revision ?? 1,
      );
      persist();
    };

    const beginPack = (attempt: number, recentItemIds: readonly string[]) => {
      pack = createPack(attempt, recentItemIds);
      resetToPack(pack, recentItemIds);
      return pack;
    };

    if (isFreshRequest) {
      progress = nextPracticeAttempt(progress, session.id);
      const cleanUrl = new URL(window.location.href);
      cleanUrl.searchParams.delete("fresh");
      window.history.replaceState({}, "", `${cleanUrl.pathname}${cleanUrl.search}${cleanUrl.hash}`);
    }

    const savedRun = !isFreshRequest
      ? progress.sessions[session.id]?.practiceRun
      : undefined;
    const hasSavedCompletion = !isFreshRequest &&
      !savedRun &&
      progress.sessions[session.id]?.status === "completed" &&
      progress.sessions[session.id]?.revision === data.revision;
    if (hasSavedCompletion) {
      const attempt = (progress.practiceAttempts[session.id] ?? 0) + 1;
      packRecentItemIds = [...progress.recentItemIds];
      pack = createPack(attempt, packRecentItemIds);
    } else if (savedRun) {
      packRecentItemIds = [...savedRun.recentItemIds];
      pack = createPack(
        savedRun.attempt,
        packRecentItemIds,
        savedRun.targetObjectiveIds,
        savedRun.priorityItemIds,
      );
      if (pack.id !== savedRun.packId) {
        const itemsById = new Map(
          requestedUnitIds
            .flatMap((unitId) => getPracticeItems(unitId))
            .map((item) => [item.id, item] as const),
        );
        const restoredItems = savedRun.itemRefs.flatMap((itemRef) => {
          const item = itemsById.get(itemRef.id);
          return item?.revision === itemRef.revision ? [item] : [];
        });

        if (
          savedRun.itemRefs.length === requestedCount &&
          restoredItems.length === requestedCount
        ) {
          pack = {
            ...pack,
            id: savedRun.packId,
            attempt: savedRun.attempt,
            targetObjectiveIds: [...savedRun.targetObjectiveIds],
            priorityItemIds: [...savedRun.priorityItemIds],
            items: restoredItems,
          };
        } else {
          packWasUpdated = true;
          beginPack(savedRun.attempt, packRecentItemIds);
        }
      }
    } else {
      const attempt = (progress.practiceAttempts[session.id] ?? 0) + 1;
      beginPack(attempt, progress.recentItemIds);
    }
    if (packUpdateNotice) packUpdateNotice.hidden = !packWasUpdated;

    const objectiveLabel = (item: PracticeItem) =>
      practiceCatalog.units
        .flatMap((unit) => unit.objectives)
        .find((objective) => objective.id === item.objectiveId)?.label.en
      ?? (item.type === "single-choice" ? "Choose the best answer" : "Complete the sentence");

    const currentRun = () => progress.sessions[session.id]?.practiceRun;
    const isRepairPhase = () => currentRun()?.phase === "repair";
    const activeItems = () => {
      const run = currentRun();
      if (run?.phase !== "repair") return pack.items;
      const repairIds = new Set(run.repairItemIds);
      return pack.items.filter((item) => repairIds.has(item.id));
    };
    const currentItem = () => activeItems()[currentIndex];

    const setChoiceState = (input: HTMLInputElement, item: PracticeItem, resultCorrect?: boolean) => {
      const choiceId = input.dataset.choiceId || "";
      const isSelected = choiceId === selectedResponse;
      const isCorrectChoice = item.type === "single-choice" && choiceId === item.answer.choiceId;
      const choice = input.closest(".answer-choice");
      choice?.classList.toggle("selected", isSelected && !checked);
      choice?.classList.toggle("correct", checked && isCorrectChoice);
      choice?.classList.toggle("incorrect", checked && isSelected && resultCorrect === false);
      input.checked = isSelected;
      input.disabled = checked;
    };

    const renderAnswers = (item: PracticeItem) => {
      if (!answerContainer) return;
      answerContainer.replaceChildren();

      if (item.type === "single-choice") {
        answerContainer.classList.add("answer-choice-list");

        item.choices.forEach((choice) => {
          const choiceLabel = document.createElement("label");
          const input = document.createElement("input");
          const marker = document.createElement("span");
          const choiceText = document.createElement("span");
          choiceLabel.className = "answer-choice";
          input.className = "answer-choice-input";
          input.type = "radio";
          input.name = `answer-${session.id}-${item.id}`;
          input.value = choice.id;
          input.dataset.choiceId = choice.id;
          marker.className = "answer-choice-marker";
          marker.setAttribute("aria-hidden", "true");
          choiceText.textContent = choice.text;
          choiceLabel.append(input, marker, choiceText);
          input.addEventListener("change", () => {
            if (checked) return;
            selectedResponse = choice.id;
            answerContainer.querySelectorAll<HTMLInputElement>("[data-choice-id]").forEach((candidate) => {
              setChoiceState(candidate, item);
            });
            if (checkButton) checkButton.disabled = false;
          });
          answerContainer.appendChild(choiceLabel);
        });
        return;
      }

      answerContainer.classList.remove("answer-choice-list");
      const label = document.createElement("label");
      const input = document.createElement("input");
      label.className = "question-objective";
      label.textContent = "Your answer";
      input.className = "fill-answer";
      input.type = "text";
      input.autocomplete = "off";
      input.spellcheck = false;
      input.setAttribute("aria-label", "Your answer");
      input.addEventListener("input", () => {
        if (checked) return;
        selectedResponse = input.value;
        if (checkButton) checkButton.disabled = !selectedResponse.trim();
      });
      input.addEventListener("keydown", (event) => {
        if (event.key !== "Enter" || !selectedResponse.trim()) return;
        event.preventDefault();
        checkButton?.click();
      });
      label.appendChild(input);
      answerContainer.appendChild(label);
      window.requestAnimationFrame(() => input.focus());
    };

    const renderItem = () => {
      const item = currentItem();
      if (!item) return;
      selectedResponse = "";
      checked = false;
      answerWasCorrect = false;
      const items = activeItems();
      const phaseLabel = isRepairPhase() ? "Repair" : "Question";
      setText(root, "[data-question-count]", `${phaseLabel} ${currentIndex + 1} of ${items.length}`);
      setText(root, "[data-question-objective]", objectiveLabel(item));
      setText(root, "[data-question-prompt]", item.prompt.en);
      if (ltPromptElement) {
        ltPromptElement.textContent = item.prompt.lt;
        ltPromptElement.hidden = true;
      }
      if (hintButton) {
        hintButton.setAttribute("aria-expanded", "false");
        hintButton.textContent = "LT  Show hint";
      }
      if (feedback) {
        feedback.hidden = true;
        feedback.classList.remove("correct");
      }
      if (feedbackLt) feedbackLt.textContent = "";
      if (progressFill) progressFill.style.width = `${((currentIndex + 1) / items.length) * 100}%`;
      if (progressTrack) {
        progressTrack.setAttribute("aria-valuemax", String(items.length));
        progressTrack.setAttribute("aria-valuenow", String(currentIndex + 1));
        progressTrack.setAttribute("aria-valuetext", `${phaseLabel} ${currentIndex + 1} of ${items.length}`);
      }
      if (checkButton) checkButton.disabled = true;
      if (checkButtonLabel) checkButtonLabel.textContent = "Check answer";
      if (skipButton) skipButton.hidden = isRepairPhase();
      renderAnswers(item);
      promptElement?.focus({ preventScroll: true });
    };

    const scoreRun = () => {
      let score = 0;
      const skillResults: Record<string, { score: number; total: number }> = {};
      pack.items.forEach((item) => {
        const response = runResponses[item.id];
        const correct = Boolean(
          response &&
          response !== SKIPPED_RESPONSE &&
          scorePracticeItem(item, response).correct,
        );
        const result = skillResults[item.objectiveId] ?? { score: 0, total: 0 };
        result.total += 1;
        if (correct) {
          score += 1;
          result.score += 1;
        }
        skillResults[item.objectiveId] = result;
      });
      return { score, skillResults };
    };

    const completePack = (
      score: number,
      total: number,
      skillResults: Record<string, { score: number; total: number }>,
      missedItemIds: string[],
      repaired = false,
    ) => {
      const missedSet = new Set(missedItemIds);
      progress = completeLearningSession(
        progress,
        session.id,
        {
          revision: data?.revision,
          score,
          total,
          skillRefs: Object.keys(skillResults),
          skillResults,
          itemIds: pack.items
            .filter((item) => repaired || !missedSet.has(item.id))
            .map((item) => item.id),
          mistakeItemIds: repaired ? [] : missedItemIds,
          minutes: completedMinutes(),
          activityType: "practice",
          ...(!sessionWasCompletedOnEntry && canAdvancePath
            ? { nextSessionId: data?.nextSessionId }
            : {}),
        },
      );
      persist();
      if (repairView) repairView.hidden = true;
      showCompletion(score, total);
      if (missedItemIds.length) {
        setText(root, "[data-complete-title]", "Mistakes repaired");
        setText(
          root,
          "[data-complete-copy]",
          `You corrected ${missedItemIds.length} ${missedItemIds.length === 1 ? "answer" : "answers"}. We will bring ${missedItemIds.length === 1 ? "it" : "them"} back in a future review so the learning lasts.`,
        );
      }
      completeView?.focus({ preventScroll: true });
    };

    const finishPack = () => {
      if (isRepairPhase()) {
        const run = currentRun();
        if (!run?.firstPassSkillResults || run.firstPassScore === undefined || run.firstPassTotal === undefined) {
          resetToPack(pack, packRecentItemIds);
          runResponses = {};
          currentIndex = 0;
          renderItem();
          return;
        }
        completePack(
          run.firstPassScore,
          run.firstPassTotal,
          run.firstPassSkillResults,
          run.repairItemIds,
          true,
        );
        return;
      }

      const { score, skillResults } = scoreRun();
      const missedItemIds = pack.items
        .filter((item) => {
          const response = runResponses[item.id];
          return !response || response === SKIPPED_RESPONSE || !scorePracticeItem(item, response).correct;
        })
        .map((item) => item.id);

      if (missedItemIds.length) {
        progress = beginPracticeRepair(
          progress,
          session.id,
          {
            repairItemIds: missedItemIds,
            firstPassScore: score,
            firstPassTotal: pack.items.length,
            firstPassSkillResults: skillResults,
          },
        );
        persist();
        runResponses = {};
        currentIndex = 0;
        practiceView.hidden = true;
        if (repairView) {
          repairView.hidden = false;
          setText(root, "[data-repair-score]", `${score} / ${pack.items.length}`);
          setText(
            root,
            "[data-repair-copy]",
            `${missedItemIds.length} ${missedItemIds.length === 1 ? "answer needs" : "answers need"} one more try. Correct ${missedItemIds.length === 1 ? "it" : "them"} now to unlock the next step.`,
          );
          repairView.focus({ preventScroll: true });
        }
        return;
      }

      completePack(score, pack.items.length, skillResults, []);
    };

    const continuePractice = () => {
      if (currentIndex >= activeItems().length - 1) {
        finishPack();
        return;
      }
      currentIndex += 1;
      renderItem();
    };

    const saveResponse = (item: PracticeItem, response: string) => {
      runResponses[item.id] = response;
      progress = saveLearningResponse(progress, session.id, item.id, response);
      persist();
    };

    checkButton?.addEventListener("click", () => {
      if (checked) {
        if (isRepairPhase() && !answerWasCorrect) {
          renderItem();
        } else {
          continuePractice();
        }
        return;
      }

      const item = currentItem();
      if (!item || !selectedResponse.trim()) return;
      const result = scorePracticeItem(item, selectedResponse);
      checked = true;
      answerWasCorrect = result.correct;
      if (!isRepairPhase() || result.correct) {
        saveResponse(item, selectedResponse);
      }
      if (feedback) {
        feedback.hidden = false;
        feedback.classList.toggle("correct", result.correct);
      }
      setText(root, "[data-feedback-title]", result.correct ? "Correct" : `Not yet · Answer: ${result.expected.join(" / ")}`);
      setText(root, "[data-feedback-copy]", result.rationale.en);
      if (feedbackLt) feedbackLt.textContent = result.rationale.lt;
      if (item.type === "single-choice" && answerContainer) {
        answerContainer.querySelectorAll<HTMLInputElement>("[data-choice-id]").forEach((input) => {
          setChoiceState(input, item, result.correct);
        });
      } else {
        const input = answerContainer?.querySelector("input");
        if (input) {
          input.readOnly = true;
          input.setAttribute("aria-invalid", String(!result.correct));
        }
      }
      if (checkButtonLabel) {
        checkButtonLabel.textContent = isRepairPhase() && !result.correct
          ? "Try again"
          : currentIndex === activeItems().length - 1
            ? (isRepairPhase() ? "Finish repair" : "See results")
            : "Continue";
      }
      if (skipButton) skipButton.hidden = true;
    });

    skipButton?.addEventListener("click", () => {
      if (isRepairPhase()) return;
      const item = currentItem();
      if (!item) return;
      saveResponse(item, SKIPPED_RESPONSE);
      continuePractice();
    });

    hintButton?.addEventListener("click", () => {
      if (!ltPromptElement) return;
      const willShow = ltPromptElement.hidden;
      ltPromptElement.hidden = !willShow;
      hintButton.setAttribute("aria-expanded", String(willShow));
      hintButton.textContent = willShow ? "LT  Hide hint" : "LT  Show hint";
    });

    retryButton?.addEventListener("click", () => {
      resetToPack(pack, packRecentItemIds);
      runResponses = {};
      currentIndex = 0;
      if (completeView) completeView.hidden = true;
      if (repairView) repairView.hidden = true;
      practiceView.hidden = false;
      renderItem();
    });

    newPackButton?.addEventListener("click", () => {
      progress = nextPracticeAttempt(progress, session.id);
      const attempt = (progress.practiceAttempts[session.id] ?? 0) + 1;
      beginPack(attempt, progress.recentItemIds);
      runResponses = {};
      currentIndex = 0;
      if (completeView) completeView.hidden = true;
      if (repairView) repairView.hidden = true;
      practiceView.hidden = false;
      renderItem();
    });

    startRepairButton?.addEventListener("click", () => {
      const repairItems = activeItems();
      if (!repairItems.length) return;
      const savedResponses = progress.sessions[session.id]?.responses ?? {};
      runResponses = Object.fromEntries(
        repairItems
          .filter((item) => typeof savedResponses[item.id] === "string")
          .map((item) => [item.id, savedResponses[item.id]]),
      );
      const firstUnansweredIndex = repairItems.findIndex((item) => !(item.id in runResponses));
      currentIndex = Math.max(0, firstUnansweredIndex);
      if (repairView) repairView.hidden = true;
      practiceView.hidden = false;
      renderItem();
    });

    if (hasSavedCompletion) {
      showCompletion(
        progress.sessions[session.id].score,
        progress.sessions[session.id].total,
      );
    } else {
      const savedResponses = progress.sessions[session.id]?.responses ?? {};
      const items = activeItems();
      runResponses = Object.fromEntries(
        items
          .filter((item) => typeof savedResponses[item.id] === "string")
          .map((item) => [item.id, savedResponses[item.id]]),
      );
      const firstUnansweredIndex = items.findIndex((item) => !(item.id in runResponses));
      if (isRepairPhase() && !Object.keys(runResponses).length) {
        practiceView.hidden = true;
        if (repairView) {
          repairView.hidden = false;
          const run = currentRun();
          setText(root, "[data-repair-score]", `${run?.firstPassScore ?? 0} / ${run?.firstPassTotal ?? pack.items.length}`);
          setText(
            root,
            "[data-repair-copy]",
            `${items.length} ${items.length === 1 ? "answer needs" : "answers need"} one more try. Correct ${items.length === 1 ? "it" : "them"} to unlock the next step.`,
          );
        }
      } else if (firstUnansweredIndex < 0 && items.length > 0) {
        finishPack();
      } else {
        currentIndex = Math.max(0, firstUnansweredIndex);
        renderItem();
      }
    }
  });
</script>

