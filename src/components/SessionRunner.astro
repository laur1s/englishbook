    padding: 0;
    border: 0;
  }

  .embedded-speaking-session {
    display: grid;
    gap: 0.85rem;
  }

  .repair-card {
    border-color: color-mix(in srgb, var(--accent) 28%, var(--line));
  }

  .runner-actions > .learning-outline-button {
    width: auto;
  }
</style>
