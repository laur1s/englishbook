{
  "schemaVersion":1,"unitId":"unit-14","contentVersion":2,"title":"Unit 14: Pronouns and Personal Connections",
  "objectives":[{"id":"u14.pronouns","label":{"en":"Use object and possessive pronouns","lt":"Vartoti objektinius ir savybinius įvardžius"}},{"id":"u14.reflexive","label":{"en":"Use common reflexive pronouns","lt":"Vartoti dažnus sangrąžinius įvardžius"}}],
  "items":[
    {"id":"u14.pronouns.001","revision":1,"objectiveId":"u14.pronouns","type":"single-choice","difficulty":1,"prompt":{"en":"This bicycle is ___.","lt":"Šis dviratis yra mano."},"choices":[{"id":"mine","text":"mine"},{"id":"my","text":"my"},{"id":"me","text":"me"}],"answer":{"choiceId":"mine"},"rationale":{"en":"Mine replaces my bicycle.","lt":"Mine pakeičia junginį my bicycle."},"sourceRefs":[{"lesson":"unit-14","exercise":2}]},
    {"id":"u14.pronouns.002","revision":1,"objectiveId":"u14.pronouns","type":"single-choice","difficulty":1,"prompt":{"en":"I work with Marta. I work with ___.","lt":"Dirbu su Marta. Dirbu su ja."},"choices":[{"id":"her","text":"her"},{"id":"hers","text":"hers"},{"id":"she","text":"she"}],"answer":{"choiceId":"her"},"rationale":{"en":"Use the object pronoun her after with.","lt":"Po with vartojame objektinį įvardį her."},"sourceRefs":[{"lesson":"unit-14","exercise":2}]},
    {"id":"u14.pronouns.003","revision":1,"objectiveId":"u14.pronouns","type":"fill-blank","difficulty":1,"prompt":{"en":"Please send ___ the photo. (I)","lt":"Prašau atsiųsti man nuotrauką."},"answer":{"accepted":["me"],"caseSensitive":false},"rationale":{"en":"Me is the object form of I.","lt":"Me yra įvardžio I objektinė forma."},"sourceRefs":[{"lesson":"unit-14","exercise":2}]},
    {"id":"u14.pronouns.004","revision":1,"objectiveId":"u14.pronouns","type":"fill-blank","difficulty":2,"prompt":{"en":"Their flat is larger than ___. (our flat)","lt":"Jų butas didesnis už mūsų."},"answer":{"accepted":["ours"],"caseSensitive":false},"rationale":{"en":"Ours replaces our flat.","lt":"Ours pakeičia junginį our flat."},"sourceRefs":[{"lesson":"unit-14","exercise":2}]},
    {"id":"u14.pronouns.005","revision":1,"objectiveId":"u14.pronouns","type":"single-choice","difficulty":2,"prompt":{"en":"My parents invited my sister and me. They invited ___.","lt":"Tėvai pakvietė seserį ir mane. Jie pakvietė mus."},"choices":[{"id":"our","text":"our"},{"id":"ours","text":"ours"},{"id":"us","text":"us"}],"answer":{"choiceId":"us"},"rationale":{"en":"Us is the object pronoun for my sister and me.","lt":"Us yra objektinis įvardis, pakeičiantis my sister and me."},"sourceRefs":[{"lesson":"unit-14","exercise":3}]},
    {"id":"u14.pronouns.006","revision":1,"objectiveId":"u14.pronouns","type":"single-choice","difficulty":2,"prompt":{"en":"That table belongs to them. It is ___.","lt":"Tas stalas priklauso jiems. Jis yra jų."},"choices":[{"id":"their","text":"their"},{"id":"theirs","text":"theirs"},{"id":"them","text":"them"}],"answer":{"choiceId":"theirs"},"rationale":{"en":"Theirs stands alone as a possessive pronoun.","lt":"Theirs vartojamas savarankiškai kaip savybinis įvardis."},"sourceRefs":[{"lesson":"unit-14","exercise":3}]},
    {"id":"u14.pronouns.007","revision":1,"objectiveId":"u14.pronouns","type":"fill-blank","difficulty":3,"prompt":{"en":"Correct one word: Come with we.","lt":"Ištaisykite vieną žodį: Come with we."},"answer":{"accepted":["us"],"caseSensitive":false},"rationale":{"en":"A preposition takes the object form us.","lt":"Po prielinksnio vartojama objektinė forma us."},"sourceRefs":[{"lesson":"unit-14","exercise":5}]},
    {"id":"u14.pronouns.008","revision":1,"objectiveId":"u14.pronouns","type":"fill-blank","difficulty":3,"prompt":{"en":"Correct one word: Those bags are our.","lt":"Ištaisykite vieną žodį: Those bags are our."},"answer":{"accepted":["ours"],"caseSensitive":false},"rationale":{"en":"Without a following noun, use ours.","lt":"Kai po įvardžio nėra daiktavardžio, vartojame ours."},"sourceRefs":[{"lesson":"unit-14","exercise":5}]},
    {"id":"u14.reflexive.009","revision":1,"objectiveId":"u14.reflexive","type":"single-choice","difficulty":1,"prompt":{"en":"We made the meal by ___.","lt":"Mes patys pagaminome valgį."},"choices":[{"id":"our","text":"our"},{"id":"ourselves","text":"ourselves"},{"id":"us","text":"us"}],"answer":{"choiceId":"ourselves"},"rationale":{"en":"Ourselves refers back to we.","lt":"Ourselves nurodo atgal į veiksnį we."},"sourceRefs":[{"lesson":"unit-14","exercise":2}]},
    {"id":"u14.reflexive.010","revision":1,"objectiveId":"u14.reflexive","type":"fill-blank","difficulty":1,"prompt":{"en":"Did you paint the room ___?","lt":"Ar pats / pati išdažei kambarį?"},"answer":{"accepted":["yourself"],"caseSensitive":false},"rationale":{"en":"Yourself matches singular you.","lt":"Yourself dera su vienaskaitos you."},"sourceRefs":[{"lesson":"unit-14","exercise":2}]},
    {"id":"u14.reflexive.011","revision":1,"objectiveId":"u14.reflexive","type":"single-choice","difficulty":2,"prompt":{"en":"Jonas repaired the bicycle without help.","lt":"Jonas sutaisė dviratį be pagalbos."},"choices":[{"id":"him","text":"Jonas repaired it him."},{"id":"himself","text":"Jonas repaired it himself."},{"id":"his","text":"Jonas repaired it his."}],"answer":{"choiceId":"himself"},"rationale":{"en":"Himself shows Jonas did it without help.","lt":"Himself rodo, kad Jonas tai padarė pats."},"sourceRefs":[{"lesson":"unit-14","exercise":3}]},
    {"id":"u14.reflexive.012","revision":1,"objectiveId":"u14.reflexive","type":"fill-blank","difficulty":2,"prompt":{"en":"Ugnė hurt ___, so she did not cook.","lt":"Ugnė susižeidė, todėl negamino."},"answer":{"accepted":["herself"],"caseSensitive":false},"rationale":{"en":"Herself refers back to Ugnė.","lt":"Herself nurodo atgal į Ugnę."},"sourceRefs":[{"lesson":"unit-14","exercise":4}]},
    {"id":"u14.reflexive.013","revision":1,"objectiveId":"u14.reflexive","type":"single-choice","difficulty":2,"prompt":{"en":"Who made dinner after Ugnė was hurt?","lt":"Kas pagamino vakarienę, kai Ugnė susižeidė?"},"choices":[{"id":"neighbor","text":"The neighbour alone"},{"id":"sam-writer","text":"Sam and the writer"},{"id":"ugne","text":"Ugnė"}],"answer":{"choiceId":"sam-writer"},"rationale":{"en":"The text says Sam and the writer made dinner themselves.","lt":"Tekste sakoma, kad Samas ir pasakotojas patys pagamino vakarienę."},"sourceRefs":[{"lesson":"unit-14","exercise":4}]},
    {"id":"u14.reflexive.014","revision":1,"objectiveId":"u14.reflexive","type":"fill-blank","difficulty":2,"prompt":{"en":"Correct: I fixed it myselves.","lt":"Ištaisykite: I fixed it myselves."},"answer":{"accepted":["I fixed it myself","I fixed it myself."],"caseSensitive":false},"rationale":{"en":"Myself is the reflexive form for I.","lt":"Myself yra sangrąžinė forma, deranti su I."},"sourceRefs":[{"lesson":"unit-14","exercise":5}]},
    {"id":"u14.reflexive.015","revision":1,"objectiveId":"u14.reflexive","type":"single-choice","difficulty":3,"prompt":{"en":"Choose the sentence meaning no one helped them.","lt":"Pasirinkite sakinį, reiškiantį, kad niekas jiems nepadėjo."},"choices":[{"id":"object","text":"They made it for them."},{"id":"possessive","text":"The work is theirs."},{"id":"reflexive","text":"They made it themselves."}],"answer":{"choiceId":"reflexive"},"rationale":{"en":"The reflexive form adds the meaning without help.","lt":"Sangrąžinė forma prideda reikšmę „be pagalbos“."},"sourceRefs":[{"lesson":"unit-14","exercise":6}]},
    {"id":"u14.reflexive.016","revision":1,"objectiveId":"u14.reflexive","type":"fill-blank","difficulty":3,"prompt":{"en":"Complete: My sister and I took the photo ___.","lt":"Mes su sese pačios / patys padarėme nuotrauką."},"answer":{"accepted":["ourselves"],"caseSensitive":false},"rationale":{"en":"Ourselves matches a group including the speaker.","lt":"Ourselves dera su grupe, kurioje yra kalbėtojas."},"sourceRefs":[{"lesson":"unit-14","exercise":6}]}
  ]
}
